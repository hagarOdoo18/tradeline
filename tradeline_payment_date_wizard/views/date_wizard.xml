<odoo>
    <data>
        <record model="ir.ui.view" id="date_wizard_form_view">
          <field name="name">date.wizard.form.view</field>
          <field name="model">payment.data.wizard</field>
          <field name="arch" type="xml">
              <form string="Date Payment Range">
                <sheet>
                    <group>
                        <group>
                            <field name="start_date"/>
                        </group>
                        <group>
                            <field name="end_date"/>
                        </group>
                    </group>
                </sheet>
                <footer>
                    <button name="get_payment_range" string="Payments in Range" type="object" class="oe_highlight" />
                </footer>
              </form>
          </field>
        </record>


           <record id="date_wizard_action" model="ir.actions.act_window">
        <field name="name">Date Payment Range</field>
        <field name="res_model">payment.data.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
        <!-- This Menu Item must have a parent and an action -->
        <menuitem id="menu_date_wizard_action" name="Payment Date Range" parent="account.menu_finance_receivables" action="date_wizard_action" sequence="111"/>
    </data>
</odoo>