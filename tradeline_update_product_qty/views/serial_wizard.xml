<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>


        <record id="view_update_product_qty_wizard_form" model="ir.ui.view">
            <field name="name">update.product.qty.wizard.form</field>
            <field name="model">update.product.qty.wizard</field>
            <field name="arch" type="xml">
                <form string="Upload Product Price List Sheet">
                    <sheet>
                        <h3>
                            Upload  Qty List Sheet
                        </h3>
                        <group>
                            <group>
                                <field name="company_id"/>
                                <field name="stock_ids" widget="many2many_tags" />
                            </group>
                            <group>
                                <field name="product_ids" widget="many2many_tags"/>
                                <field name="qty"/>
                            </group>

                        </group>
                    </sheet>
                    <footer>
                        <button name="create_adjust"
                                string="Update QTY" type="object" class="btn-primary"/>
                        <button string="Cancel" class="btn-default" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>


        <record id="view_update_product_qty_wizard_action" model="ir.actions.act_window">
            <field name="name">update.product.qty.wizard.action</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">update.product.qty.wizard</field>
            <field name="view_mode">form</field>
            <field name="view_id" ref="view_update_product_qty_wizard_form"/>
            <field name="target">new</field>
        </record>



        <menuitem id="update_product_qty_wizard_menu" name="Update Product QTY"
                  parent="stock.menu_stock_inventory_control" action="view_update_product_qty_wizard_action" groups="tradeline_update_product_qty.group_update_product_qty"
                  sequence="5"/>


    </data>
</odoo>