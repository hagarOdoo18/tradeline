<odoo>
    <record id="view_import_transfer_excel_form" model="ir.ui.view">
        <field name="name">import.transfer.excel.form</field>
        <field name="model">import.transfer.excel</field>
        <field name="arch" type="xml">
            <form string="Import Excel">
                <group>
                    <field name="file" filename="filename"/>
                </group>
                <group string="Preview" >
                    <field name="preview_line_ids">
                        <list readonly="1" create="0" edit="0" delete="0">
                            <field name="itemcode"/>
                            <field name="product_id"/>
                            <field name="quantity"/>
                        </list>
                    </field>
                </group>
                <footer>
                    <button name="action_preview" type="object"
                            string="Preview" class="btn-secondary"/>
                    <button name="action_import" type="object"
                            string="Import" class="btn-primary"
                            />
                    <button string="Cancel" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>