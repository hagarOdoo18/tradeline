<odoo>
    <record id="view_product_upload_excel_form" model="ir.ui.view">
        <field name="name">product.upload.excel.form</field>
        <field name="model">product.upload.excel</field>
        <field name="arch" type="xml">
            <form string="Upload Products from Excel">
                <sheet>
                    <group>
                        <field name="file" filename="filename"/>
                    </group>
                </sheet>
                <footer>
                    <button string="Import" type="object" name="action_import_products" class="btn-primary"/>
                    <button string="Cancel" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_product_upload_excel" model="ir.actions.act_window">
        <field name="name">Upload Products from Excel</field>
        <field name="res_model">product.upload.excel</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_product_upload_excel" name="Upload Products  from Excel" parent="stock.menu_stock_inventory_control" action="action_product_upload_excel"/>
</odoo>
