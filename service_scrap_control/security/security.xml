<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="module_category_service_scrap_control" model="ir.module.category">
            <field name="name">Service Scrap Control</field>
            <field name="sequence">35</field>
        </record>

        <record id="group_approval_scrap" model="res.groups">
            <field name="name">Approve Scrap</field>
            <field name="category_id" ref="module_category_service_scrap_control"/>
        </record>

        <record id="group_return_picking_internal" model="res.groups">
            <field name="name">Enable return transfer</field>
            <field name="category_id" ref="module_category_service_scrap_control"/>
        </record>

        <record id="group_picking_scrap" model="res.groups">
            <field name="name">Enable In\out scrap</field>
            <field name="category_id" ref="module_category_service_scrap_control"/>
        </record>

        <record id="group_picking_scrap_transfer" model="res.groups">
            <field name="name">Enable transfer scrap</field>
            <field name="category_id" ref="module_category_service_scrap_control"/>
        </record>

        <record id="group_scrap_inventory" model="res.groups">
            <field name="name">Scrap Inventory</field>
            <field name="category_id" ref="module_category_service_scrap_control"/>
        </record>

        <record id="group_service_scrap_control" model="res.groups">
            <field name="name">Service Scrap Control</field>
            <field name="category_id" ref="module_category_service_scrap_control"/>
            <field name="implied_ids" eval="[
                (4, ref('stock.group_stock_user')),
                (4, ref('service_scrap_control.group_approval_scrap')),
                (4, ref('service_scrap_control.group_return_picking_internal')),
                (4, ref('service_scrap_control.group_picking_scrap')),
                (4, ref('service_scrap_control.group_picking_scrap_transfer')),
                (4, ref('service_scrap_control.group_scrap_inventory'))
            ]"/>
        </record>

        <record id="stock.menu_stock_scrap" model="ir.ui.menu">
            <field name="groups_id" eval="[(4, ref('service_scrap_control.group_scrap_inventory'))]"/>
        </record>
    </data>
</odoo>
