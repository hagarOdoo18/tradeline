<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="stock_scrap_form_view_service_scrap" model="ir.ui.view">
            <field name="name">stock.scrap.form.service.scrap</field>
            <field name="model">stock.scrap</field>
            <field name="inherit_id" ref="stock.stock_scrap_form_view"/>
            <field name="arch" type="xml">
                <xpath expr="//header/button[@name='action_validate']" position="before">
                    <button
                        name="request_request"
                        string="Request Scrap"
                        type="object"
                        class="btn-secondary"
                        groups="service_scrap_control.group_return_picking_internal"
                        invisible="state != 'draft' or not service_flow_scope"
                    />
                    <button
                        name="function_approve_scrap"
                        string="Approve Scrap"
                        type="object"
                        class="oe_highlight"
                        groups="service_scrap_control.group_approval_scrap"
                        invisible="state not in ('draft', 'witting') or not service_flow_scope"
                    />
                </xpath>

                <xpath expr="//header/button[@name='action_validate']" position="attributes">
                    <attribute name="invisible">(service_flow_scope and state != 'approve' and not vendor_scrap) or (not service_flow_scope and state != 'draft')</attribute>
                </xpath>

                <xpath expr="//field[@name='state']" position="attributes">
                    <attribute name="statusbar_visible">draft,witting,approve,done</attribute>
                </xpath>

                <xpath expr="//field[@name='should_replenish']" position="after">
                    <field name="service_flow_scope" invisible="1"/>
                    <field name="vendor_scrap" readonly="1" invisible="not service_flow_scope"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
