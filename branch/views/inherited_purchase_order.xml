<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="purchase_order_form_inherit_branch" model="ir.ui.view">
            <field name="name">purchase.order.form.inherit.branch</field>
            <field name="model">purchase.order</field>
            <field name="inherit_id" ref="purchase.purchase_order_form" />
            <field name="arch" type="xml">

                <xpath expr="//header" position="inside">
                <button name="action_remove_taxes"
                        string="Remove Taxes"
                        type="object"
                        class="btn-warning"/>
            </xpath>
                   <xpath expr="//form" position="attributes">
                <attribute name="create">false</attribute>
            </xpath>
                <field name="incoterm_id" position="after">
                    <field name="branch_id" force_save="1"/>
                </field>
                <xpath expr="//field[@name='order_line']" position="attributes">
                    <attribute name="context">{'default_branch_id' : branch_id}</attribute>
                    <attribute name="readonly">state != 'draft'</attribute>
                </xpath>
                  <xpath expr="//button[@name='button_cancel']" position="attributes">
                <attribute name="groups">branch.action_cancel_purchase</attribute>
            </xpath>
                <xpath expr="//button[@name='button_done']" position="attributes">
                <attribute name="groups">branch.action_done_purchase</attribute>
            </xpath>
                <xpath expr="//button[@name='button_confirm'][1]" position="attributes">
                <attribute name="groups">branch.action_confirm_purchase</attribute>
            </xpath>
                 <xpath expr="//button[@name='button_confirm'][2]" position="attributes">
                <attribute name="groups">branch.action_confirm_purchase</attribute>
            </xpath>
                <xpath expr="//button[@name='action_create_invoice'][1]" position="attributes">
                <attribute name="groups">branch.action_create_bill_purchase</attribute>
            </xpath>
                <xpath expr="//button[@name='action_create_invoice'][2]" position="attributes">
                <attribute name="groups">branch.action_create_bill_purchase</attribute>
            </xpath>
                <xpath expr="//button[@name='action_rfq_send'][1]" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
                <xpath expr="//button[@name='action_bill_matching']" position="attributes">
                <attribute name="groups">branch.action_bill_matching_purchase</attribute>
            </xpath>
                <xpath expr="//button[@name='action_rfq_send'][2]" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            </field>
        </record>



        <record id="view_purchase_order_filter_inherit_branch" model="ir.ui.view">
            <field name="name">view.purchase.order.filter.inherit.branch</field>
            <field name="model">purchase.order</field>
            <field name="inherit_id" ref="purchase.view_purchase_order_filter" />
            <field name="arch" type="xml">
                <xpath expr="//group" position="inside">
                    <filter string="Branch" name="branch" domain="[]" context="{'group_by':'branch_id'}" />
                </xpath>
            </field>
        </record>

        <record id="purchase_order_branch_view_tree" model="ir.ui.view">
            <field name="name">purchase.order.inherit.list</field>
            <field name="model">purchase.order</field>
            <field name="inherit_id" ref="purchase.purchase_order_view_tree" />
            <field name="arch" type="xml">
                <field name="company_id" position="after">
                    <field name="branch_id" optional="hide" />
                </field>

            </field>
        </record>



        <record id="purchase_order_branch_view_list1" model="ir.ui.view">
            <field name="name">purchase.order.inherit.list1</field>
            <field name="model">purchase.order</field>
            <field name="inherit_id" ref="purchase.purchase_order_kpis_tree" />

            <field name="arch" type="xml">
                <field name="company_id" position="after">
                    <field name="branch_id" optional="hide" />
                </field>

            </field>
        </record>


          <record id="purchase.action_purchase_batch_bills" model="ir.actions.server">
        <field name="name">Create Vendor Bills</field>
        <field name="model_id" ref="purchase.model_purchase_order"/>
        <field name="binding_model_id" ref="purchase.model_purchase_order"/>
        <field name='groups_id' eval="[(4, ref('branch.action_create_bill_purchase'))]"/>
        <field name="state">code</field>
        <field name="code">
            if records:
                action = records.action_create_invoice()
        </field>
    </record>
    </data>
</odoo>