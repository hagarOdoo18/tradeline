<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Sale order Inherit Form View to Modify it -->
        <record id="view_order_form_inherit_branch" model="ir.ui.view">
            <field name="name">view.order.form.inherit.branch</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_order_form"/>
            <field name="arch" type="xml">

                  <xpath expr="//div[@name='button_box']" position="inside">
                    <button
                        type="object"
                        name="action_view_payments"
                        class="oe_stat_button"
                        icon="fa-money">
                        <field name="payment_count" widget="statinfo" string="Payments"/>
                    </button>
                </xpath>

                  <xpath expr="//header" position="inside">
                    <button
                        name="action_register_payment_so"
                        type="object"
                        string="Register Payment"
                        class="btn-primary"

                    />
                </xpath>


            <xpath expr="//group[@name='sale_total']" position="inside">
                <field name="amount_paid" readonly="1"/>
                <field name="amount_due" readonly="1"/>
            </xpath>
                 <xpath expr="//field[@name='partner_id']" position="after">
                    <!-- Add your fields or attributes here -->

                            <field name="branch_id" readonly="not allowed_branch" options   ="{'no_edit': True, 'no_create': True, 'no_open': True}"/>
                            <field name="warehouse_id" readonly="1" force_save="1" options="{'no_edit': True, 'no_create': True, 'no_open': True}"/>

                </xpath>
                <xpath expr="//list//field[@name='product_template_id']" position="attributes">
                    <attribute name="options">{'no_edit': True, 'no_create': True, 'no_open': True}</attribute>
                </xpath>
                 <xpath expr="//button[@name='action_confirm'][1]" position="attributes">
                <attribute name="groups">branch.group_allow_confirm_sales</attribute>
            </xpath>
                <xpath expr="//button[@name='action_confirm'][2]" position="attributes">
                <attribute name="groups">branch.group_allow_confirm_sales</attribute>
            </xpath>
              <xpath expr="//button[@name='action_quotation_send'][1]" position="attributes">
                            <attribute name="groups">branch.group_allow_action_quotation_send</attribute>
                        </xpath>
                 <xpath expr="//button[@name='action_quotation_send'][2]" position="attributes">
                            <attribute name="invisible">1</attribute>
                        </xpath>

            </field>
        </record>


        <!-- Sale order Inherit search View to Modify it -->
        <record id="view_sales_order_filter_inherit_branch" model="ir.ui.view">
            <field name="name">view.sales.order.filter.inherit.branch</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_sales_order_filter"/>
            <field name="arch" type="xml">
                <xpath expr="//group" position="inside">
                        <filter string="Branch" name="branch" domain="[]" context="{'group_by':'branch_id'}"/>
                </xpath>
            </field>
        </record>

        <record id="sale_order_branch_view_list" model="ir.ui.view" >
            <field name="name">sale.order.inherit.list</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_order_tree" />
            <field name="arch" type="xml">
                <field name="company_id" position="after">
                    <field name="branch_id" optional="show"/>
                </field>
            </field>
        </record>

        <record id="sale_order_branch_view_list1" model="ir.ui.view" >
            <field name="name">sale.order.inherit.list1</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_quotation_tree_with_onboarding" />
            <field name="arch" type="xml">
                <field name="company_id" position="after">
                    <field name="branch_id" optional="show"/>
                </field>
            </field>
        </record>

        <record id="view_pos_order_form_discount_reason" model="ir.ui.view">
        <field name="name">pos.order.form.discount.reason.gift</field>
        <field name="model">pos.order</field>
        <field name="inherit_id" ref="point_of_sale.view_pos_pos_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="branch_id" readonly="1"/>

            </xpath>
        </field>

    </record>

         <record id="view_pos_config_form_auto_invoice" model="ir.ui.view">
        <field name="name">pos.config.form.auto.invoice</field>
        <field name="model">pos.config</field>
        <field name="inherit_id" ref="point_of_sale.pos_config_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//setting[@id='other_devices']" position="after">
                <setting string="Branch" help="Select Branch">
                    <field name="branch_id"/>
                </setting>

            </xpath>
        </field>
    </record>

    </data>
</odoo>