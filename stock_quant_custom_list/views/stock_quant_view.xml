<odoo>
    <data>

        <!-- security group for the menu & access -->
        <record id="view_stock_quant_tree_custom" model="ir.ui.view">
            <field name="name">stock.quant.tree.custom</field>
            <field name="model">stock.quant</field>
            <field name="arch" type="xml">
                <list string="Apple Stock Report" >
                    <field name="location_id" string="Store Name"/>
                    <field name="family_id" string="Family"/>
                    <field name="category_id" string="Category"/>
                    <field name="vendor_id" string="Vendor"/>
                    <field name="product_id" string="Product name"/>
                    <field name="default_code" string="Item Code"/>
                    <field name="reserved_quantity" string="Reserved Quantity"/>
                    <field name="lot_id" string="Lot/Serial Number"/>
                    <field name="quantity" string="On Hand"/>
                </list>
            </field>
        </record>

        <!-- action for the view -->
        <record id="action_stock_quant_custom" model="ir.actions.act_window">
            <field name="name">Apple Stock Report</field>
            <field name="res_model">stock.quant</field>
            <field name="view_mode">list</field>
            <field name="domain">[('location_id.usage','=','internal')]</field>
            <field name="view_id" ref="view_stock_quant_tree_custom"/>
        </record>

        <!-- menuitem restricted by the custom group -->
        <menuitem id="menu_stock_quant_custom"
                  name="Apple Stock Report"
                  parent="stock.menu_warehouse_report"
                  action="action_stock_quant_custom"
                  groups="stock_quant_custom_list.group_stock_quant_custom_user"/>

    </data>
</odoo>
