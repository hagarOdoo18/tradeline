<odoo>
  <data>
    <!-- Inherit Form View to Modify it -->


        <record id="view_product_point_wizard_form" model="ir.ui.view">
            <field name="name">product.point.wizard.form</field>
            <field name="model">product.point.wizard</field>
            <field name="arch" type="xml">
                <form string="Update Product Point">
                    <sheet>
                        <h3>
                           Update Product Point
                        </h3>
                        <group>

                            <group>
                                <field name="date_from"/>
                                <field name="date_to"/>
                                <field name="field" widget="radio" />
                                <field name="product_exel_Sheet"/>

                            </group>
                        </group>
                    </sheet>
                    <footer>
                        <button name="compute_product_point"
                                string="Update Invoice Product Point" type="object" class="btn-primary"/>
                        <button name="import_excel"
                                string="Update Product Point" type="object" class="btn-primary"/>
                        <button string="Cancel" class="btn-default" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>


        <record id="view_update_product_point_wizard_action" model="ir.actions.act_window">
            <field name="name">Update Product Point</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">product.point.wizard</field>
            <field name="view_mode">form</field>
            <field name="view_id" ref="view_product_point_wizard_form"/>
            <field name="target">new</field>
        </record>



         <menuitem id="update_product_point_wizard_menu" name="Update Product Point"
                  parent="stock.menu_stock_inventory_control" action="view_update_product_point_wizard_action" groups="tradeline_invoice_line_product_point.group_update_product_point"
                  sequence="6"/>




  </data>
</odoo>