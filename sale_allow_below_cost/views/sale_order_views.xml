<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══════════════════════════════════════════════════════════════════
         Sale Order Line – add a visual indicator when price < cost
    ═══════════════════════════════════════════════════════════════════ -->
    <record id="sale_order_line_tree_below_cost" model="ir.ui.view">
        <field name="name">sale.order.line.tree.below.cost</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <!-- Add decoration-warning on the order line tree -->
            <xpath expr="//field[@name='order_line']/list" position="attributes">
                <attribute name="decoration-warning">is_below_cost == True</attribute>
            </xpath>

            <!-- Add the below-cost flag and tooltip column (optional – hidden by default) -->
            <xpath expr="//field[@name='order_line']/list//field[@name='price_unit']"
                   position="after">
                <field name="is_below_cost" column_invisible="1"/>


            </xpath>

            <!-- Banner on the order form itself when any line is below cost -->

        </field>
    </record>

</odoo>
