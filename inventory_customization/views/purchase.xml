<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="purchase_order_inh_domain" model="ir.ui.view">
            <field name="name">purchase.order.inh.domain.form</field>
            <field name="model">purchase.order</field>
            <field name="inherit_id" ref="purchase.purchase_order_form"/>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">

                <xpath expr="//list//field[@name='product_id']" position="attributes">
                    <attribute name="domain">[('purchase_ok', '=', True), '|', ('company_id', '=', False), ('company_id', 'parent_of', parent.company_id), ('vendor_id', '=', parent.partner_id)]</attribute>
                </xpath>
            </field>
        </record>
    </data>
</odoo>