<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="stock_lot_form_inherit" model="ir.ui.view">
            <field name="name">stock.lot.inh.form</field>
            <field name="model">stock.lot</field>
            <field name="inherit_id" ref="stock_account.view_production_lot_form_stock_account"/>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <xpath expr="//label[@for='standard_price']" position="attributes">
                    <attribute name="groups">inventory_customization.group_product_serial_admin</attribute>
                </xpath>
                <xpath expr="//field[@name='standard_price']" position="attributes">
                    <attribute name="groups">inventory_customization.group_product_serial_admin</attribute>
                </xpath>
                <xpath expr="//label[@for='avg_cost']" position="attributes">
                    <attribute name="groups">inventory_customization.group_product_serial_admin</attribute>
                </xpath>
                <xpath expr="//field[@name='avg_cost']" position="attributes">
                    <attribute name="groups">inventory_customization.group_product_serial_admin</attribute>
                </xpath>
                <xpath expr="//label[@for='total_value']" position="attributes">
                    <attribute name="groups">inventory_customization.group_product_serial_admin</attribute>
                </xpath>
                <xpath expr="//field[@name='total_value']" position="attributes">
                    <attribute name="groups">inventory_customization.group_product_serial_admin</attribute>
                </xpath>
            </field>
        </record>

         <record id="stock_lot_form_product_inherit" model="ir.ui.view">
            <field name="name">stock.lot.inh.form.product</field>
            <field name="model">stock.lot</field>
            <field name="inherit_id" ref="stock.view_production_lot_form"/>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='product_id']" position="attributes">
                    <attribute name="groups">inventory_customization.group_product_serial_admin</attribute>
                </xpath>
                <xpath expr="//field[@name='location_id']" position="attributes">
                    <attribute name="groups">inventory_customization.group_product_serial_admin</attribute>
                </xpath>

            </field>
        </record>
        <record id="stock_valuation_layer_form_product_inherit" model="ir.ui.view">
            <field name="name">stock.valuation.layer.inh.form.product</field>
            <field name="model">stock.valuation.layer</field>
            <field name="inherit_id" ref="stock_account.stock_valuation_layer_tree"/>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='unit_cost']" position="after">
                    <field name="lst_price"/>
                </xpath>


            </field>
        </record>
    </data>
</odoo>