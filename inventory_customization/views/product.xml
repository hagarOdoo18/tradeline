<odoo>
  <data>
    <!-- explicit list view definition -->



    <record id="product_family_inherit" model="ir.ui.view">
            <field name="name">product family</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="product.product_template_only_form_view" />
            <field name="arch" type="xml">
                <xpath expr="//field[@name='barcode']" position="after" >
                  <field name="family_id"/>
                  <field name="sub_categ_id"/>


                </xpath>
            </field>
    </record>


    <record id="product_list_barcode_view" model="ir.ui.view">
        <field name="name">product barcode</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_tree_view" />
        <field name="arch" type="xml">
            <xpath expr="//list" position="replace" >
                <list>
                  <field name="categ_id"/>
                  <field name="sub_categ_id"/>
                  <field name="family_id"/>
                  <field name="name"/>
                  <field name="list_price"/>
                  <field name="standard_price"/>
                  <field name="qty_available"/>
                  <field name="virtual_available"/>
                </list>
            </xpath>
        </field>
    </record>
      <record id="product_product_list_barcode_view" model="ir.ui.view">
        <field name="name">product barcode</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_product_tree_view" />
        <field name="arch" type="xml">

            <xpath expr="//list" position="replace" >
                <list>
                  <field name="categ_id"/>
                  <field name="sub_categ_id"/>
                  <field name="family_id"/>
                  <field name="default_code"/>
                  <field name="barcode"/>
                  <field name="name"/>
                  <field name="display_name"/>
                  <field name="product_template_variant_value_ids"  widget="many2many_tags" groups="product.group_product_variant" readonly="1"/>
                  <field name="lst_price"/>
                  <field name="standard_price"/>
                  <field name="qty_available"/>
                  <field name="virtual_available"/>
                  <field name="vendor_id"/>
                </list>
            </xpath>
        </field>
    </record>

      <record id="product_vendor_view" model="ir.ui.view">
            <field name="name">product Vendor</field>
            <field name="model">product.product</field>
            <field name="inherit_id" ref="product.product_normal_form_view" />
            <field name="arch" type="xml">
                <xpath expr="//field[@name='barcode']" position="after" >
                  <field name="vendor_id" force_save="1" readonly="1"/>
                    <field name="product_point"/>
                  <field name="product_incentive"/>
                  <field name="product_notes" groups='inventory_customization.group_menu_product_notes'/>
                </xpath>
            </field>
        </record>

       <record id="server_action_product_vendor_update" model="ir.actions.server">
        <field name="name">Update Vendor</field>
        <field name="model_id" ref="product.model_product_template_attribute_line"/>
        <field name="binding_model_id" ref="product.model_product_template_attribute_line"/>
        <field name="state">code</field>
       <field name="binding_view_types">form,list</field>

        <field name="code">
            if records:
                action = records.action_update_vendor()
        </field>
    </record>
       <record id="stock.in_picking" model="ir.ui.menu">
            <field name="groups_id" eval="[(6, 0, [ ref('inventory_customization.group_receipt_menu')])]"/>
        </record>
      <record id="stock.out_picking" model="ir.ui.menu">
            <field name="groups_id" eval="[(6, 0, [ ref('inventory_customization.group_delivery_menu')])]"/>
        </record>
    <record id="stock.int_picking" model="ir.ui.menu">
                <field name="groups_id" eval="[(6, 0, [ ref('inventory_customization.group_transfer_menu')])]"/>
            </record>
      <record id="stock_landed_costs.menu_stock_landed_cost" model="ir.ui.menu">
                <field name="groups_id" eval="[(6, 0, [ ref('inventory_customization.group_cost_menu')])]"/>
            </record>
    <record id="stock.menu_action_inventory_tree" model="ir.ui.menu">
                <field name="groups_id" eval="[(6, 0, [ ref('inventory_customization.group_inventory_menu')])]"/>
            </record>
      <record id="stock.menu_stock_scrap" model="ir.ui.menu">
                <field name="groups_id" eval="[(6, 0, [ ref('inventory_customization.group_scrap_menu')])]"/>
            </record>
      <record id="stock.stock_move_menu" model="ir.ui.menu">
                <field name="groups_id" eval="[(6, 0, [ ref('inventory_customization.group_moves_analysis_menu')])]"/>
            </record>
      <record id="stock.menu_product_stock" model="ir.ui.menu">
                <field name="groups_id" eval="[(6, 0, [ ref('inventory_customization.group_product_stock_menu')])]"/>
            </record>
      <record id="stock.menu_valuation" model="ir.ui.menu">
                <field name="groups_id" eval="[(6, 0, [ ref('inventory_customization.group_locations_menu')])]"/>
            </record>
 <record id="stock.stock_move_line_menu" model="ir.ui.menu">
                <field name="groups_id" eval="[(6, 0, [ ref('inventory_customization.group_stock_move_line_menu')])]"/>
            </record>
      <record id="stock.stock_move_line_menu" model="ir.ui.menu">
                <field name="groups_id" eval="[(6, 0, [ ref('inventory_customization.group_stock_move_line_menu')])]"/>
            </record>
 <record id="stock.stock_move_menu" model="ir.ui.menu">
                <field name="groups_id" eval="[(6, 0, [ ref('inventory_customization.group_stock_move_menu')])]"/>
            </record>
 <record id="stock_account.menu_valuation" model="ir.ui.menu">
                <field name="groups_id" eval="[(6, 0, [ ref('inventory_customization.group_menu_valuation')])]"/>
            </record>
<record id="stock.stock_picking_type_menu" model="ir.ui.menu">
                <field name="groups_id" eval="[(6, 0, [ ref('inventory_customization.group_menu_overview')])]"/>
            </record>
<record id="stock.menu_procurement_compute" model="ir.ui.menu">
                <field name="groups_id" eval="[(6, 0, [ ref('inventory_customization.group_menu_procurement_compute')])]"/>
            </record>


  </data>
</odoo>