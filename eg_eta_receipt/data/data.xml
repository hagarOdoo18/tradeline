<odoo>
    <data>

        <record model="ir.cron" id="ir_cron_autosend_eta">
        <field name="name">Auto-Send Eta</field>
        <field name="interval_number">1</field>
        <field name="interval_type">hours</field>
        <field name="active">True</field>
        <field name="model_id" ref="point_of_sale.model_pos_order" />
        <field name="state">code</field>
        <field name="code">model.auto_send()</field>
    </record>
         <record id="server_action_send_eta" model="ir.actions.server">
        <field name="name">Send Eta</field>
        <field name="model_id" ref="point_of_sale.model_pos_order"/>
        <field name="binding_model_id" ref="point_of_sale.model_pos_order" />
        <field name="state">code</field>
        <field name="code">
            for rec in records:
                if not rec.e_invoice_sent:
                    rec.action_send_electronic_invoice()
        </field>
    </record>

          <record id="server_action_eta_state" model="ir.actions.server">
        <field name="name">Get State Eta</field>
        <field name="model_id" ref="point_of_sale.model_pos_order"/>
        <field name="binding_model_id" ref="point_of_sale.model_pos_order" />
        <field name="state">code</field>
        <field name="code">
            for rec in records:
                if  rec.e_invoice_sent:
                    rec.action_update_electronic_invoice_status()
        </field>
    </record>


    </data>
</odoo>