<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- =========================
         FORM VIEW
    ========================== -->
    <record id="e_invoice_view_move_form_inherit" model="ir.ui.view">
        <field name="name">e_invoice.account.move.form.inherit</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">

            <!-- Buttons -->
            <xpath expr="//button[@name='preview_invoice']" position="before">

                <!-- Flags -->
                <field name="e_invoice_sent" invisible="1"/>
                <field name="valid_flag" invisible="1"/>
                <field name="submitted_flag" invisible="1"/>
                <field name="invalid_flag" invisible="1"/>
                <field name="cancelled_flag" invisible="1"/>
                <field name="expired_flag" invisible="1"/>
                <field name="hide_sent_button" invisible="1"/>
                <field name="hide_cancel_button" invisible="1"/>

                <button name="action_send_electronic_invoice"
                        type="object"
                        string="Sync E-Invoice"
                        icon="fa-paper-plane"
                        class="btn btn-warning"
                        groups="egyptian_electronic_invoice.group_e_invoice_sync"
                        invisible="hide_sent_button or move_type not in ('out_invoice','out_refund')"/>

                <button name="action_cancel_electronic_invoice"
                        type="object"
                        string="Cancel E-Invoice"
                        icon="fa-close"
                        class="btn btn-danger"
                        groups="account.group_account_invoice"
                        invisible="hide_cancel_button"/>
            </xpath>

            <!-- Reset to draft -->
            <xpath expr="//button[@name='button_draft']" position="replace">
                <button name="button_draft"
                        type="object"
                        string="Reset to Draft"
                        groups="account.group_account_invoice"
                        invisible="state != 'cancel' or not hide_cancel_button"/>
            </xpath>

            <!-- Dates -->
            <xpath expr="//field[@name='invoice_date']" position="after">
                <field name="expiration_duration"
                       invisible="valid_flag or move_type != 'out_invoice'"/>
                <field name="document_id"
                       invisible="not document_id"/>
            </xpath>

            <!-- Status buttons -->
            <xpath expr="//div[hasclass('oe_button_box')]" position="inside">

                <button string="E-I Valid"
                        icon="fa-check-circle"
                        invisible="not valid_flag"
                        style="background-color:green;color:white"/>

                <button string="E-I Invalid"
                        icon="fa-times-circle"
                        invisible="not invalid_flag"
                        style="background-color:orange;color:white"/>

                <button string="E-I Expired"
                        icon="fa-lock"
                        invisible="not expired_flag"
                        style="background-color:red;color:white"/>

                <button string="E-I Submitted"
                        icon="fa-upload"
                        invisible="not submitted_flag"
                        style="background-color:#00A09D;color:white"/>

                <button string="E-I Cancelled"
                        icon="fa-times"
                        invisible="not cancelled_flag"
                        style="background-color:gray;color:white"/>
            </xpath>

            <!-- Notebook -->
            <xpath expr="//notebook" position="inside">
                <page string="E-Invoice Details"
                      invisible="move_type not in ('out_invoice','out_refund')">

                    <group>
                        <group>
                            <field name="e_invoice_status" readonly="1"/>
                            <field name="e_invoice_uuid" readonly="1"/>
                            <field name="e_invoice_date" readonly="1"/>
                        </group>

                        <group>
                            <field name="e_invoice_url" widget="url" readonly="1"/>
                            <field name="e_invoice_issue"
                                   invisible="e_invoice_status != 'Invalid'"/>
                        </group>
                    </group>

                </page>
            </xpath>

        </field>
    </record>

    <!-- =========================
         TREE VIEW
    ========================== -->
    <record id="e_invoice_view_move_tree_inherit" model="ir.ui.view">
        <field name="name">e_invoice.account.move.tree.inherit</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_tree"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='state']" position="after">
                <field name="e_invoice_status"/>
                <field name="expiration_duration"/>
                <field name="expired_flag" invisible="1"/>
                <field name="invalid_flag" invisible="1"/>
            </xpath>

            <xpath expr="//list" position="attributes">
                <attribute name="decoration-success">e_invoice_status == 'Valid'</attribute>
                <attribute name="decoration-primary">e_invoice_status == 'Submitted'</attribute>
                <attribute name="decoration-danger">expired_flag</attribute>
                <attribute name="decoration-warning">invalid_flag</attribute>
                <attribute name="decoration-muted">e_invoice_status == 'Cancelled'</attribute>
            </xpath>

        </field>
    </record>

