<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Invoice Form -->
        <record id="e_invoice_view_move_form_inherit" model="ir.ui.view">
            <field name="name">e_invoice.account.move.form.inherit</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
                <xpath expr="//button[@name='preview_invoice']" position="before">
                    <!--Flag Fields-->
                    <field name="e_invoice_sent" invisible="1"/>
                    <field name="valid_flag" invisible="1"/>
                    <field name="submitted_flag" invisible="1"/>
                    <field name="invalid_flag" invisible="1"/>
                    <field name="cancelled_flag" invisible="1"/>
                    <field name="hide_sent_button" invisible="1"/>
                    <field name="hide_cancel_button" invisible="1"/>
                    <field name="expired_flag" invisible="1"/>
                    <button type="object" class="btn btn-warning"
                            icon="fa-paper-plane" string="Sync E-Invoice"
                            groups="egyptian_electronic_invoice.group_e_invoice_sync"
                            name="action_send_electronic_invoice"
                            invisible="hide_sent_button != False"/>
                    <button type="object" class="btn btn-danger"
                            icon="fa-close" string="Cancel Invoice"
                            groups="account.group_account_invoice"
                            name="action_cancel_electronic_invoice"
                            invisible="hide_sent_button != False"/>
                </xpath>

                <xpath expr="//button[@name='button_draft']" position="replace">
                    <button name="button_draft" string="Reset to Draft" type="object"
                            groups="account.group_account_invoice"
                            invisible="show_reset_to_draft_button != True or hide_cancel_button != True"
                            data-hotkey="q"/>
                </xpath>

                <xpath expr="//field[@name='invoice_date']" position="after">
                    <field name="expiration_duration"
                           invisible="valid_flag == True or move_type != 'out_invoice'"/>
                    <field name="document_id" invisible="document_id == False"/>
                </xpath>

                <xpath expr="//widget" position="before">
                    <widget name="web_ribbon" title="E-I Valid" bg_color="bg-success" style="margin-top:40px;font-size:10px;"
                            invisible="valid_flag != True"/>
                    <widget name="web_ribbon" title="E-I Invalid" bg_color="bg-warning" style="margin-top:40px;font-size:10px;"
                            invisible="invalid_flag != True"/>
                    <widget name="web_ribbon" title="E-I Expired" bg_color="bg-danger" style="margin-top:40px;"
                            invisible="expired_flag != True"/>
                    <widget name="web_ribbon" title="E-I Submitted" bg_color="bg-primary" style="margin-top:40px;"
                            invisible="submitted_flag != True"/>
                    <widget name="web_ribbon" title="Cancelled" bg_color="bg-dark" style="margin-top:40px;"
                            invisible="cancelled_flag != True"/>
                </xpath>

                <xpath expr="//notebook" position="inside">
                    <page string="E-Invoice Details"
                          invisible="move_type not in ('out_invoice','out_refund')">
                        <button type="object" name="action_generate_eta_json" string="Generate Json"
                                icon="fa-cogs" class="btn btn-dark"
                                groups="egyptian_electronic_invoice.group_e_invoice_dev_tools"
                                invisible="valid_flag == True"/>
                        <button type="object" name="action_sign_invoice" string="Sign Document"
                                icon="fa-edit" class="btn btn-dark"
                                groups="egyptian_electronic_invoice.group_e_invoice_dev_tools"
                                invisible="valid_flag == True"/>
                        <group>
                            <group>
                                <field name="e_invoice_so_ref" force_save="1" readonly="valid_flag == True"/>
                                <field name="e_invoice_so_desc" force_save="1" readonly="valid_flag == True"/>
                                <field name="e_invoice_po_ref" force_save="1" readonly="valid_flag == True"/>
                                <field name="e_invoice_po_desc" force_save="1" readonly="valid_flag == True"/>
                                <field name="e_invoice_pref_no" force_save="1" readonly="valid_flag == True"/>
                                <field name="e_invoice_credit_src" force_save="1" readonly="1"/>
                                <field name="show_results"/>
                                <field name="invoice_signed" readonly="1" force_save="1" invisible="1"/>
                                <field name="use_static_signature" invisible="1" readonly="valid_flag == True"
                                       groups="egyptian_electronic_invoice.group_e_invoice_dev_tools"/>
                                <label for="static_sign_url" invisible="use_static_signature == False"/>
                                <div class="o_row" invisible="use_static_signature == False">
                                    <field name="static_sign_url" widget="url"/>
                                    <button type="object" name="get_signature_value"
                                            icon="fa-refresh" class="btn btn-dark"/>
                                </div>
                                <label for="static_signature" invisible="use_static_signature == False"/>
                                <field name="static_signature" invisible="use_static_signature == False" class="oe_edit_only" nolabel="1"
                                       readonly="valid_flag == True"/>
                            </group>
                            <group>
                                <field name="e_invoice_date" readonly="1" force_save="1"/>
                                <field name="e_invoice_cancel_date" readonly="1" force_save="1"
                                       invisible="e_invoice_status != 'Cancelled'"/>
                                <field name="e_invoice_uuid" readonly="1" force_save="1"/>
                                <field name="e_invoice_url" widget="url" force_save="1" readonly="1"/>
                                <label for="e_invoice_status"/>
                                <div class="o_row">
                                    <field name="e_invoice_status" readonly="1" force_save="1"/>
                                    <button type="object" class="btn btn-info" context="{'show_result':1}"
                                            icon="fa-refresh" string="Update Status"
                                            name="action_update_electronic_invoice_status"
                                            invisible="e_invoice_uuid == False or e_invoice_status == 'Cancelled'"/>
                                </div>
                                <field name="e_invoice_issue" invisible="e_invoice_status != 'Invalid'"/>
                                <label for="e_invoice_pdf" invisible="e_invoice_status != 'Valid' or e_invoice_status == 'Cancelled'"/>
                                <div class="o_row" invisible="e_invoice_status != 'Valid' or e_invoice_status == 'Cancelled'">
                                    <field name="pdf_name" invisible="1"/>
                                    <field name="e_invoice_pdf" readonly="1" force_save="1" filename="pdf_name"/>
                                    <button type="object" class="btn btn-info"
                                            icon="fa-refresh" string="Update PDF"
                                            name="action_update_electronic_invoice_pdf"
                                            invisible="e_invoice_uuid == False or e_invoice_pdf == False"/>
                                    <button type="object" class="btn btn-info"
                                            icon="fa-download" string="Get PDF"
                                            name="action_update_electronic_invoice_pdf"
                                            invisible="e_invoice_uuid == False or e_invoice_pdf != False"/>
                                </div>
                            </group>
                        </group>
                        <label for="e_invoice_canonical" groups="egyptian_electronic_invoice.group_e_invoice_dev_tools"
                               style="font-weight:bold"/>
                        <field name="e_invoice_canonical" readonly="1"
                               groups="egyptian_electronic_invoice.group_e_invoice_dev_tools"/>
                        <label for="e_invoice_json" groups="egyptian_electronic_invoice.group_e_invoice_dev_tools"
                               style="font-weight:bold;"/>
                        <field name="e_invoice_json" readonly="1"
                               groups="egyptian_electronic_invoice.group_e_invoice_dev_tools"/>
                    </page>
                </xpath>
            </field>
        </record>

        <!-- Invoice Tree -->
        <record id="e_invoice_view_invoice_tree_inherit" model="ir.ui.view">
            <field name="name">e_invoice.account.move.tree.inherit</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_invoice_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='move_type']" position="after">
                    <field name="e_invoice_status" widget="badge" optional="show"
                           decoration-info="e_invoice_status == 'Draft'"
                           decoration-success="e_invoice_status == 'Valid'"
                           decoration-primary="e_invoice_status == 'Submitted'"
                           decoration-muted="e_invoice_status == 'Cancelled'"
                           decoration-danger="expired_flag == True"
                           decoration-warning="e_invoice_status == 'Invalid' or (e_invoice_sent== False and expiration_duration!= 0)"/>
                    <field name="expiration_duration" optional="hide"/>
                    <field name="expired_flag" invisible="1"/>
                    <field name="e_invoice_sent" invisible="1"/>
                </xpath>
            </field>
        </record>

        <!-- Invoice Filters -->
        <record id="e_invoice_view_account_invoice_filter_inherit" model="ir.ui.view">
            <field name="name">e_invoice.account.move.search.inherit</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_account_invoice_filter"/>
            <field name="arch" type="xml">
                <xpath expr="//group" position="before">
                    <separator/>
                    <filter name="submitted" string="Submitted Sync"
                            domain="[('move_type', '=', ('out_invoice', 'out_refund')),('e_invoice_status','=', 'Submitted')]"/>
                    <filter name="valid" string="Valid Sync"
                            domain="[('move_type', '=', ('out_invoice', 'out_refund')),('e_invoice_status','=', 'Valid')]"/>
                    <filter name="invalid" string="Invalid Sync"
                            domain="[('move_type', '=', ('out_invoice', 'out_refund')),('e_invoice_status','=', 'Invalid')]"/>
                </xpath>
            </field>
        </record>

        <!-- Journal Form -->
        <record id="e_invoice_view_account_journal_form_inherit" model="ir.ui.view">
            <field name="name">e_invoice.account.journal.form.inherit</field>
            <field name="model">account.journal</field>
            <field name="inherit_id" ref="account.view_account_journal_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='code']" position="after">
                    <field name="eta_branch"/>
                    <field name="eta_branch_code_id"/>
                </xpath>
            </field>
        </record>
    </data>

    <!-- Server Actions -->
    <data noupdate="1">
        <record id="ir_action_invoice_sync_multi" model="ir.actions.server">
            <field name="name">E-invoice: Sync documents</field>
            <field name="type">ir.actions.server</field>
            <field name="model_id" ref="account.model_account_move"/>
            <field name="state">code</field>
            <field name="code">
                if records:
                    action = model.multi_invoice_sync()
            </field>
            <field name="binding_model_id" ref="account.model_account_move"/>
            <field name="binding_view_types">list</field>
            <field name="groups_id" eval="[(4, ref('egyptian_electronic_invoice.group_e_invoice_sync'))]"/>
        </record>

        <record id="ir_action_invoice_update_status_multi" model="ir.actions.server">
            <field name="name">E-invoice: Update Status</field>
            <field name="type">ir.actions.server</field>
            <field name="model_id" ref="account.model_account_move"/>
            <field name="state">code</field>
            <field name="code">
                if records:
                    action = model.multi_update_status()
            </field>
            <field name="binding_model_id" ref="account.model_account_move"/>
            <field name="binding_view_types">list</field>
            <field name="groups_id" eval="[(4, ref('egyptian_electronic_invoice.group_e_invoice_sync'))]"/>
        </record>

        <record id="ir_action_invoice_cancel_multi" model="ir.actions.server">
            <field name="name">E-invoice: Cancel documents</field>
            <field name="type">ir.actions.server</field>
            <field name="model_id" ref="account.model_account_move"/>
            <field name="state">code</field>
            <field name="code">
                if records:
                    action = model.multi_invoice_cancel()
            </field>
            <field name="binding_model_id" ref="account.model_account_move"/>
            <field name="binding_view_types">list</field>
            <field name="groups_id" eval="[(4, ref('egyptian_electronic_invoice.group_e_invoice_sync'))]"/>
        </record>
    </data>

    <!-- Cron Jobs -->
<data >
    <record id="ir_cron_document_posted_sync" model="ir.cron">
        <field name="name">E-Invoice: Automatic sync posted documents Cron</field>
        <field name="active">0</field>
        <field name="interval_number">1</field>
        <field name="interval_type">minutes</field>
        <field name="nextcall" eval="(DateTime.now().replace(hour=0, minute=0, second=0) + timedelta(days=1)).strftime('%Y-%m-%d %H:%M:%S')"/>
        <field name="model_id" ref="account.model_account_move"/>
        <field name="code">
            model.cron_send_invoices()
        </field>
        <field name="state">code</field>
    </record>

    <record id="ir_cron_document_update_status_sync" model="ir.cron">
        <field name="name">E-Invoice: Automatic update Synced documents Cron</field>
        <field name="active">1</field>
        <field name="interval_number">1</field>
        <field name="interval_type">hours</field>
        <field name="nextcall" eval="(DateTime.now().replace(hour=0, minute=0, second=0) + timedelta(hours=1)).strftime('%Y-%m-%d %H:%M:%S')"/>
        <field name="model_id" ref="account.model_account_move"/>
        <field name="code">
            model.search([('state','=','posted'),('e_invoice_sent','=',True),('e_invoice_status','=',('Submitted'))],limit=2).action_update_electronic_invoice_status()
        </field>
        <field name="state">code</field>
    </record>
</data>
</odoo>
