    <!-- =========================
         SERVER ACTION
    ========================== -->
    <record id="ir_action_move_sync_multi" model="ir.actions.server">
        <field name="name">E-Invoice: Sync documents</field>
        <field name="type">ir.actions.server</field>
        <field name="model_id" ref="account.model_account_move"/>
        <field name="binding_model_id" ref="account.model_account_move"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
if records:
    records.action_send_electronic_invoice()
        </field>
        <field name="groups_id" eval="[(4, ref('egyptian_electronic_invoice.group_e_invoice_sync'))]"/>
    </record>

    <!-- =========================
         CRON
    ========================== -->
    <record id="ir_cron_e_invoice_auto_sync" model="ir.cron">
        <field name="name">E-Invoice: Auto Sync</field>
        <field name="active">1</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="model_id" ref="account.model_account_move"/>
        <field name="state">code</field>
        <field name="code">
model.search([
    ('state','=','posted'),
    ('move_type','in',('out_invoice','out_refund')),
    ('e_invoice_sent','=',False)
]).action_send_electronic_invoice()
        </field>
    </record>

