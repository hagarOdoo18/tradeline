<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Link Bill -->
        <record id="link_bill_wizard_form_view" model="ir.ui.view">
            <field name="name">link.bill.wizard.form.view</field>
            <field name="model">link.bill.wizard</field>
            <field name="arch" type="xml">
                <form string="Link">
                    <sheet>
                        <field name="document_id" readonly="1"/>
                        <group>
                            <group>
                                <field name="partner_id" required="1"/>
                                <field name="bill_id" required="1" domain="[('move_type', '=', 'in_invoice'),('partner_id', '=', partner_id)]"/>
                            </group>
                        </group>
                    </sheet>
                    <footer>
                        <button name="action_link" class="oe_highlight" type="object"
                                string="Link Bill" icon="fa-link"/>
                        <button string="Close" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>
        <record id="action_link_bill_wizard" model="ir.actions.act_window">
            <field name="name">Link Bill</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">link.bill.wizard</field>
            <field name="view_mode">form</field>
            <field name="view_id" ref="link_bill_wizard_form_view"/>
            <field name="target">new</field>
        </record>
        <!-- Reject Bill Reason-->
        <record id="reject_bill_reason_wizard_form_view" model="ir.ui.view">
            <field name="name">reject.bill.wizard.form.view</field>
            <field name="model">link.bill.wizard</field>
            <field name="arch" type="xml">
                <form string="Reject Document Reason">
                    <sheet>
                        <field name="document_id" readonly="1"/>
                        <group>
                            <group>
                                <field name="reject_reason"/>
                            </group>
                        </group>
                    </sheet>
                    <footer>
                        <button name="action_reject_reason" class="btn-danger" type="object" string="Reject Document" icon="fa-file"/>
                        <button string="Close" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>
        <record id="action_reject_bill_reason_wizard" model="ir.actions.act_window">
            <field name="name">Reject Document Reason</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">link.bill.wizard</field>
            <field name="view_mode">form</field>
            <field name="view_id" ref="reject_bill_reason_wizard_form_view"/>
            <field name="target">new</field>
        </record>
    </data>
</odoo>