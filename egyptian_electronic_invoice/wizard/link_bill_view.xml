<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="link_bill_wizard_form_view" model="ir.ui.view">
            <field name="name">link.bill.wizard.form.view</field>
            <field name="model">link.bill.wizard</field>
            <field name="arch" type="xml">
                <form string="Link">
                    <sheet>
                        <field name="document_id" readonly="1"/>
                       <group>
                           <group>
                               <field name="partner_id"/>
                               <field name="bill_id" domain="[('type', '=', 'in_invoice'),('partner_id', '=', partner_id)]"/>
                           </group>
                       </group>
                    </sheet>
                    <footer>
                        <button name="action_link" class="oe_highlight" type="object"
                                string="Link Bill" icon="fa-link"/>
                        <button string="Close" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>
        <record id="action_link_bill_wizard" model="ir.actions.act_window">
            <field name="name">Link Bill</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">link.bill.wizard</field>
            <field name="view_mode">form</field>
            <field name="view_id" ref="link_bill_wizard_form_view"/>
            <field name="target">new</field>
        </record>
    </data>
</odoo>