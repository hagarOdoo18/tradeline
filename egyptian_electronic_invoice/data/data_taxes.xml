<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Tax template for sale and purchase -->
        <record id="tax_group_14" model="account.tax.group">
            <field name="name">Additional Taxes 14%</field>
            <field name="country_id" ref="base.eg"/>
        </record>
        <record id="tax_group_withholding_tax" model="account.tax.group">
            <field name="name">Withholding tax (WHT)</field>
            <field name="country_id" ref="base.eg"/>
        </record>
    </data>
    <data>
        <record id="additional_taxes_14_template" model="account.tax">
            <field name="name">ضريبة القيمه المضافه(14%)</field>
            <field name="description">ضريبة القيمه المضافه(14%)</field>
            <field name="amount">14</field>
            <field name="active">True</field>
            <field name="type_tax_use">sale</field>
            <field name="country_id" ref="base.eg"/>
            <field name="tax_group_id" ref="egyptian_electronic_invoice.tax_group_14"/>
            <field name="type_code_id" ref="egyptian_electronic_invoice.default_tax_type"/>
            <field name="sub_type_code_id" ref="egyptian_electronic_invoice.default_tax_sub_type"/>
        </record>
         <record id="additional_withholding_tax_template" model="account.tax">
            <field name="name">الخصم تحت حساب الضريبه</field>
            <field name="description">الخصم تحت حساب الضريبه</field>
            <field name="amount">-1</field>
            <field name="active">True</field>
            <field name="type_tax_use">sale</field>
             <field name="country_id" ref="base.eg"/>
            <field name="tax_group_id" ref="egyptian_electronic_invoice.tax_group_withholding_tax"/>
            <field name="type_code_id" ref="egyptian_electronic_invoice.default_tax_type_t4"/>
            <field name="sub_type_code_id" ref="egyptian_electronic_invoice.default_tax_sub_type_t4"/>
        </record>
    </data>

</odoo>
