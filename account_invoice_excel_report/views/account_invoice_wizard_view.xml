
<odoo>
    <record id="view_account_invoice_wizard" model="ir.ui.view">
        <field name="name">account.invoice.wizard.form</field>
        <field name="model">account.invoice.wizard</field>
        <field name="arch" type="xml">
            <form string="Invoice Excel Report">
                <group>
                    <field name="partner_id"/>
                    <field name="branch_id"/>
                    <field name="journal_ids" widget="many2many_tags"/>
                    <field name="invoice_number"/>
                    <field name="date_from"/>
                    <field name="date_to"/>
                </group>
                <footer>
                    <button name="action_export_excel" type="object" string="Export Excel" class="btn-primary"/>
                    <button string="Close" special="cancel"/>
                </footer>
                <group attrs="{'invisible':[('excel_file','=',False)]}">
                    <field name="file_name"/>
                    <field name="excel_file" filename="file_name"/>
                </group>
            </form>
        </field>
    </record>

       <record id="action_invoice_wizard" model="ir.actions.act_window">
        <field name="name">Account Invoice Report</field>
        <field name="res_model">account.invoice.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_invoice_report"
              name="Account Invoice Report"
          parent="account.menu_finance_receivables"
              action="action_invoice_wizard"/>
</odoo>
