
<odoo>
    <record id="view_invoice_excel_wizard_form" model="ir.ui.view">
        <field name="name">account.invoice.excel.wizard.form</field>
        <field name="model">account.invoice.wizard2</field>
        <field name="arch" type="xml">
            <form string="Export Branches &amp; Payments">
                <group>
                    <field name="date_from"/>
                    <field name="date_to"/>
                </group>
                <footer>
                    <button name="action_export_excel" type="object"
                            string="Export Excel" class="btn-primary"/>
                    <button string="Cancel" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_invoice_excel_wizard" model="ir.actions.act_window">
        <field name="name">Branches &amp; Payment Excel</field>
        <field name="res_model">account.invoice.wizard2</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_invoice_excel_report"
              name="Invoice Excel Report"
          parent="account.menu_finance_receivables"
              action="action_invoice_excel_wizard"/>
</odoo>
