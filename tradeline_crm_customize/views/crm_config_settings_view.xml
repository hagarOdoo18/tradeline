<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="crm_config_setting_view_new" model="ir.ui.view">
        <field name="name">crm.config.setting.view.new</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('settings')]/div[@data-key='crm']" position="inside">
                    <div>
                        <h2>Crm Mail Template Settings</h2>

                        <div class="row o_settings_container">
                            <div class="col-6 o_setting_box">
                                <div class="o_setting_right_pane">
                                    <label for="eamil_to_branch_template_id" />
                                    <br />
                                    <field name="eamil_to_branch_template_id" class="oe_inline" />
                                </div>
                                <div class="o_setting_left_pane"></div>
                            </div>
                            <div class="col-6 o_setting_box">
                                <div class="o_setting_right_pane">
                                    <label for="eamil_to_agent_won_template_id" />
                                    <br />
                                    <field name="eamil_to_agent_won_template_id" class="oe_inline" />
                                </div>
                                <div class="o_setting_left_pane"></div>
                            </div>
                        </div>
                        <div class="row o_settings_container">
                            <div class="col-6 o_setting_box">
                                <div class="o_setting_right_pane">
                                    <label for="eamil_to_agent_lost_template_id" />
                                    <br />
                                    <field name="eamil_to_agent_lost_template_id" class="oe_inline" />
                                </div>
                                <div class="o_setting_left_pane"></div>
                            </div>
                            <div class="col-6 o_setting_box">
                                <div class="o_setting_right_pane">
                                    <label for="eamil_to_agent_canceled_template_id" />
                                    <br />
                                    <field name="eamil_to_agent_canceled_template_id" class="oe_inline" />
                                </div>
                                <div class="o_setting_left_pane"></div>
                            </div>
                        </div>
                                                <div class="row o_settings_container">
                            <div class="col-6 o_setting_box">
                                <div class="o_setting_right_pane">
                                    <label for="eamil_to_agent_refunded_template_id" />
                                    <br />
                                    <field name="eamil_to_agent_refunded_template_id" class="oe_inline" />
                                </div>
                                <div class="o_setting_left_pane"></div>
                            </div>
                        </div>
                    </div>
                    <div>
                        <h2>Crm Mail Template Settings ( Admin )</h2>

                        <div class="row o_settings_container">
                            <div class="col-6 o_setting_box">
                                <div class="o_setting_right_pane">
                                    <label for="eamil_to_branch_template_id_admin" />
                                    <br />
                                    <field name="eamil_to_branch_template_id_admin" class="oe_inline" />
                                </div>
                                <div class="o_setting_left_pane"></div>
                            </div>
                            <div class="col-6 o_setting_box">
                                <div class="o_setting_right_pane">
                                    <label for="eamil_to_agent_won_template_id_admin" />
                                    <br />
                                    <field name="eamil_to_agent_won_template_id_admin" class="oe_inline" />
                                </div>
                                <div class="o_setting_left_pane"></div>
                            </div>
                        </div>
                        <div class="row o_settings_container">
                            <div class="col-6 o_setting_box">
                                <div class="o_setting_right_pane">
                                    <label for="eamil_to_agent_lost_template_id_admin" />
                                    <br />
                                    <field name="eamil_to_agent_lost_template_id_admin" class="oe_inline" />
                                </div>
                                <div class="o_setting_left_pane"></div>
                            </div>
                            <div class="col-6 o_setting_box">
                                <div class="o_setting_right_pane">
                                    <label for="eamil_to_agent_canceled_template_id_admin" />
                                    <br />
                                    <field name="eamil_to_agent_canceled_template_id_admin" class="oe_inline" />
                                </div>
                                <div class="o_setting_left_pane"></div>
                            </div>
                        </div>
                                                <div class="row o_settings_container">
                            <div class="col-6 o_setting_box">
                                <div class="o_setting_right_pane">
                                    <label for="eamil_to_agent_refunded_template_id_admin" />
                                    <br />
                                    <field name="eamil_to_agent_refunded_template_id_admin" class="oe_inline" />
                                </div>
                                <div class="o_setting_left_pane"></div>
                            </div>
                        </div>
                    </div>

            </xpath>
        </field>
    </record>
</odoo>
