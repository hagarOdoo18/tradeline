<odoo>
    <record id="view_picking_form_inherit_serial_upload" model="ir.ui.view">
        <field name="name">stock.picking.form.inherit.serial.upload</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_open_upload_serial_excel_wizard"
                        string="Upload Transfer Serials"
                        type="object"
                        class="oe_highlight"
                        invisible="picking_type_code !=  'internal'"/>
            </xpath>
        </field>
    </record>
</odoo>
