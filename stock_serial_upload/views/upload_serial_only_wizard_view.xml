<odoo>
    <record id="view_upload_serial_only_wizard_form" model="ir.ui.view">
        <field name="name">upload.serial.only.wizard.form</field>
        <field name="model">upload.serial.only.wizard</field>
        <field name="arch" type="xml">
            <form string="Upload Serials (Internal)">
                <group>
                    <field name="picking_id" readonly="1"/>
                    <field name="file" filename="filename"/>
                    <field name="filename" invisible="1"/>
                </group>
                <footer>
                    <button name="action_upload_serials" string="Upload" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_upload_serial_only_wizard" model="ir.actions.act_window">
        <field name="name">Upload Serials</field>
        <field name="res_model">upload.serial.only.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
