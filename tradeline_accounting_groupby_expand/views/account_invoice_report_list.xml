<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_account_invoice_report_list_cost_basis" model="ir.ui.view">
            <field name="name">account.invoice.report.list.cost.basis</field>
            <field name="model">account.invoice.report</field>
            <field name="inherit_id" search="[('model', '=', 'account.invoice.report'), ('type', 'in', ['list', 'tree'])]"/>
            <field name="arch" type="xml">
                <xpath expr="//list/field[last()]" position="after">
                    <field name="inventory_cost_method" string="Cost Method" optional="show"/>
                    <field name="inventory_unit_cost_used" string="Unit Cost Used" optional="show"/>
                    <field name="inventory_unit_cost_untaxed_used" string="Unit Cost Untaxed Used" optional="show"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
