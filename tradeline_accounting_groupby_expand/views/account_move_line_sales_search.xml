<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_account_move_line_sales_search_groupby_expanded" model="ir.ui.view">
            <field name="name">account.move.line.sales.search.groupby.expanded</field>
            <field name="model">account.move.line</field>
            <field name="inherit_id" ref="sales_invoice_lines_view.view_account_move_line_sales_search"/>
            <field name="arch" type="xml">
                <xpath expr="//search/field[1]" position="before">
                    <field name="product_search_text" string="Product"/>
                </xpath>
                <xpath expr="//search/field[not(@name='product_id')][1]" position="before">
                    <xpath expr="//search/field[@name='product_id'][1]" position="move"/>
                </xpath>
                <xpath expr="//search/field[@name='product_id'][1]" position="before">
                    <xpath expr="//search/field[@name='product_search_text'][1]" position="move"/>
                </xpath>
                <xpath expr="//search/separator[1]" position="before">
                    <filter name="tradeline_time_ranges_move_line_date" string="Date" date="date">
                        <filter name="tradeline_move_line_date_last_7_days" string="Last 7 Days"
                                domain="[('date', '&gt;=', (context_today() - relativedelta(days=6)).strftime('%%Y-%%m-%%d')), ('date', '&lt;=', context_today().strftime('%%Y-%%m-%%d'))]"/>
                        <filter name="tradeline_move_line_date_last_30_days" string="Last 30 Days"
                                domain="[('date', '&gt;=', (context_today() - relativedelta(days=29)).strftime('%%Y-%%m-%%d')), ('date', '&lt;=', context_today().strftime('%%Y-%%m-%%d'))]"/>
                        <filter name="tradeline_move_line_date_last_365_days" string="Last 365 Days"
                                domain="[('date', '&gt;=', (context_today() - relativedelta(days=364)).strftime('%%Y-%%m-%%d')), ('date', '&lt;=', context_today().strftime('%%Y-%%m-%%d'))]"/>
                        <filter name="tradeline_move_line_date_today" string="Today"
                                domain="[('date', '&gt;=', context_today().strftime('%%Y-%%m-%%d')), ('date', '&lt;=', context_today().strftime('%%Y-%%m-%%d'))]"/>
                        <filter name="tradeline_move_line_date_this_week" string="This Week"
                                domain="[('date', '&gt;=', (context_today() - relativedelta(days=context_today().weekday())).strftime('%%Y-%%m-%%d')), ('date', '&lt;=', context_today().strftime('%%Y-%%m-%%d'))]"/>
                        <filter name="tradeline_move_line_date_this_month" string="This Month"
                                domain="[('date', '&gt;=', (context_today() + relativedelta(day=1)).strftime('%%Y-%%m-%%d')), ('date', '&lt;=', context_today().strftime('%%Y-%%m-%%d'))]"/>
                        <filter name="tradeline_move_line_date_this_quarter" string="This Quarter"
                                domain="[('date', '&gt;=', (context_today() + relativedelta(month=((context_today().month - 1) // 3) * 3 + 1, day=1)).strftime('%%Y-%%m-%%d')), ('date', '&lt;=', context_today().strftime('%%Y-%%m-%%d'))]"/>
                        <filter name="tradeline_move_line_date_this_year" string="This Year"
                                domain="[('date', '&gt;=', (context_today() + relativedelta(month=1, day=1)).strftime('%%Y-%%m-%%d')), ('date', '&lt;=', context_today().strftime('%%Y-%%m-%%d'))]"/>
                        <filter name="tradeline_move_line_date_yesterday" string="Yesterday"
                                domain="[('date', '&gt;=', (context_today() - relativedelta(days=1)).strftime('%%Y-%%m-%%d')), ('date', '&lt;=', (context_today() - relativedelta(days=1)).strftime('%%Y-%%m-%%d'))]"/>
                        <filter name="tradeline_move_line_date_last_week" string="Last Week"
                                domain="[('date', '&gt;=', (context_today() - relativedelta(days=context_today().weekday() + 7)).strftime('%%Y-%%m-%%d')), ('date', '&lt;=', (context_today() - relativedelta(days=context_today().weekday() + 1)).strftime('%%Y-%%m-%%d'))]"/>
                        <filter name="tradeline_move_line_date_last_month" string="Last Month"
                                domain="[('date', '&gt;=', (context_today() + relativedelta(months=-1, day=1)).strftime('%%Y-%%m-%%d')), ('date', '&lt;=', (context_today() + relativedelta(day=1, days=-1)).strftime('%%Y-%%m-%%d'))]"/>
                        <filter name="tradeline_move_line_date_last_quarter" string="Last Quarter"
                                domain="[('date', '&gt;=', (context_today() + relativedelta(month=((context_today().month - 1) // 3) * 3 + 1, day=1, months=-3)).strftime('%%Y-%%m-%%d')), ('date', '&lt;=', (context_today() + relativedelta(month=((context_today().month - 1) // 3) * 3 + 1, day=1, days=-1)).strftime('%%Y-%%m-%%d'))]"/>
                        <filter name="tradeline_move_line_date_last_year" string="Last Year"
                                domain="[('date', '&gt;=', (context_today() + relativedelta(years=-1, month=1, day=1)).strftime('%%Y-%%m-%%d')), ('date', '&lt;=', (context_today() + relativedelta(years=-1, month=12, day=31)).strftime('%%Y-%%m-%%d'))]"/>
                    </filter>
                    <filter name="tradeline_time_ranges_move_line_invoice_date" string="Invoice Date" date="invoice_date">
                        <filter name="tradeline_move_line_invoice_date_last_7_days" string="Last 7 Days"
                                domain="[('invoice_date', '&gt;=', (context_today() - relativedelta(days=6)).strftime('%%Y-%%m-%%d')), ('invoice_date', '&lt;=', context_today().strftime('%%Y-%%m-%%d'))]"/>
                        <filter name="tradeline_move_line_invoice_date_last_30_days" string="Last 30 Days"
                                domain="[('invoice_date', '&gt;=', (context_today() - relativedelta(days=29)).strftime('%%Y-%%m-%%d')), ('invoice_date', '&lt;=', context_today().strftime('%%Y-%%m-%%d'))]"/>
                        <filter name="tradeline_move_line_invoice_date_last_365_days" string="Last 365 Days"
                                domain="[('invoice_date', '&gt;=', (context_today() - relativedelta(days=364)).strftime('%%Y-%%m-%%d')), ('invoice_date', '&lt;=', context_today().strftime('%%Y-%%m-%%d'))]"/>
                        <filter name="tradeline_move_line_invoice_date_today" string="Today"
                                domain="[('invoice_date', '&gt;=', context_today().strftime('%%Y-%%m-%%d')), ('invoice_date', '&lt;=', context_today().strftime('%%Y-%%m-%%d'))]"/>
                        <filter name="tradeline_move_line_invoice_date_this_week" string="This Week"
                                domain="[('invoice_date', '&gt;=', (context_today() - relativedelta(days=context_today().weekday())).strftime('%%Y-%%m-%%d')), ('invoice_date', '&lt;=', context_today().strftime('%%Y-%%m-%%d'))]"/>
                        <filter name="tradeline_move_line_invoice_date_this_month" string="This Month"
                                domain="[('invoice_date', '&gt;=', (context_today() + relativedelta(day=1)).strftime('%%Y-%%m-%%d')), ('invoice_date', '&lt;=', context_today().strftime('%%Y-%%m-%%d'))]"/>
                        <filter name="tradeline_move_line_invoice_date_this_quarter" string="This Quarter"
                                domain="[('invoice_date', '&gt;=', (context_today() + relativedelta(month=((context_today().month - 1) // 3) * 3 + 1, day=1)).strftime('%%Y-%%m-%%d')), ('invoice_date', '&lt;=', context_today().strftime('%%Y-%%m-%%d'))]"/>
                        <filter name="tradeline_move_line_invoice_date_this_year" string="This Year"
                                domain="[('invoice_date', '&gt;=', (context_today() + relativedelta(month=1, day=1)).strftime('%%Y-%%m-%%d')), ('invoice_date', '&lt;=', context_today().strftime('%%Y-%%m-%%d'))]"/>
                        <filter name="tradeline_move_line_invoice_date_yesterday" string="Yesterday"
                                domain="[('invoice_date', '&gt;=', (context_today() - relativedelta(days=1)).strftime('%%Y-%%m-%%d')), ('invoice_date', '&lt;=', (context_today() - relativedelta(days=1)).strftime('%%Y-%%m-%%d'))]"/>
                        <filter name="tradeline_move_line_invoice_date_last_week" string="Last Week"
                                domain="[('invoice_date', '&gt;=', (context_today() - relativedelta(days=context_today().weekday() + 7)).strftime('%%Y-%%m-%%d')), ('invoice_date', '&lt;=', (context_today() - relativedelta(days=context_today().weekday() + 1)).strftime('%%Y-%%m-%%d'))]"/>
                        <filter name="tradeline_move_line_invoice_date_last_month" string="Last Month"
                                domain="[('invoice_date', '&gt;=', (context_today() + relativedelta(months=-1, day=1)).strftime('%%Y-%%m-%%d')), ('invoice_date', '&lt;=', (context_today() + relativedelta(day=1, days=-1)).strftime('%%Y-%%m-%%d'))]"/>
                        <filter name="tradeline_move_line_invoice_date_last_quarter" string="Last Quarter"
                                domain="[('invoice_date', '&gt;=', (context_today() + relativedelta(month=((context_today().month - 1) // 3) * 3 + 1, day=1, months=-3)).strftime('%%Y-%%m-%%d')), ('invoice_date', '&lt;=', (context_today() + relativedelta(month=((context_today().month - 1) // 3) * 3 + 1, day=1, days=-1)).strftime('%%Y-%%m-%%d'))]"/>
                        <filter name="tradeline_move_line_invoice_date_last_year" string="Last Year"
                                domain="[('invoice_date', '&gt;=', (context_today() + relativedelta(years=-1, month=1, day=1)).strftime('%%Y-%%m-%%d')), ('invoice_date', '&lt;=', (context_today() + relativedelta(years=-1, month=12, day=31)).strftime('%%Y-%%m-%%d'))]"/>
                    </filter>
                    <separator/>
                </xpath>
                <xpath expr="//search/group[1]" position="replace">
                    <group expand="0" string="Group By">
                        <filter name="group_by_branch_id" string="Branch" context="{'group_by': 'branch_id'}"/>
                        <filter name="group_by_channel_id" string="Channel" context="{'group_by': 'channel_id'}"/>
                        <filter name="group_by_company_id" string="Company" context="{'group_by': 'company_id'}"/>
                        <filter name="group_by_currency_id" string="Currency" context="{'group_by': 'currency_id'}"/>
                        <filter name="group_by_partner_id" string="Customer" context="{'group_by': 'partner_id'}"/>
                        <filter name="group_by_date" string="Date" context="{'group_by': 'date:month'}"/>
                        <filter name="group_by_family_id" string="Family" context="{'group_by': 'family_id'}"/>
                        <filter name="group_by_move_id" string="Invoice" context="{'group_by': 'move_id'}"/>
                        <filter name="group_by_move_name" string="Invoice Reference" context="{'group_by': 'move_name'}"/>
                        <filter name="group_by_item_code" string="Item Code" context="{'group_by': 'item_code'}"/>
                        <filter name="group_by_move_type" string="Move Type" context="{'group_by': 'move_type'}"/>
                        <filter name="group_by_product_id" string="Product" context="{'group_by': 'product_id'}"/>
                        <filter name="group_by_categ_id" string="Product Category" context="{'group_by': 'categ_id'}"/>
                        <filter name="group_by_sales_rep_id" string="Sales Rep" context="{'group_by': 'sales_rep_id'}"/>
                        <filter name="group_by_vendor_id" string="Vendor" context="{'group_by': 'vendor_id'}"/>
                    </group>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
