<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_account_move_line_sales_search_groupby_expanded" model="ir.ui.view">
            <field name="name">account.move.line.sales.search.groupby.expanded</field>
            <field name="model">account.move.line</field>
            <field name="inherit_id" ref="sales_invoice_lines_view.view_account_move_line_sales_search"/>
            <field name="arch" type="xml">
                <xpath expr="//search/separator[1]" position="before">
                    <filter
                        name="tradeline_time_based_on_move_line"
                        string="Based On"
                    >
                        <filter
                            name="tradeline_move_line_based_on_date"
                            string="Date"
                            context="{'tradeline_time_based_on': 'date'}"
                        />
                        <filter
                            name="tradeline_move_line_based_on_invoice_date"
                            string="Invoice Date"
                            context="{'tradeline_time_based_on': 'invoice_date'}"
                        />
                    </filter>
                    <filter
                        name="tradeline_time_ranges_move_line_date"
                        string="Range"
                    >
                        <filter
                            name="tradeline_move_line_date_last_7_days"
                            string="Last 7 Days"
                            context="{'tradeline_time_range': 'last_7_days'}"
                        />
                        <filter
                            name="tradeline_move_line_date_last_30_days"
                            string="Last 30 Days"
                            context="{'tradeline_time_range': 'last_30_days'}"
                        />
                        <filter
                            name="tradeline_move_line_date_last_365_days"
                            string="Last 365 Days"
                            context="{'tradeline_time_range': 'last_365_days'}"
                        />
                        <filter
                            name="tradeline_move_line_date_today"
                            string="Today"
                            context="{'tradeline_time_range': 'today'}"
                        />
                        <filter
                            name="tradeline_move_line_date_this_week"
                            string="This Week"
                            context="{'tradeline_time_range': 'this_week'}"
                        />
                        <filter
                            name="tradeline_move_line_date_this_month"
                            string="This Month"
                            context="{'tradeline_time_range': 'this_month'}"
                        />
                        <filter
                            name="tradeline_move_line_date_this_quarter"
                            string="This Quarter"
                            context="{'tradeline_time_range': 'this_quarter'}"
                        />
                        <filter
                            name="tradeline_move_line_date_this_year"
                            string="This Year"
                            context="{'tradeline_time_range': 'this_year'}"
                        />
                        <filter
                            name="tradeline_move_line_date_yesterday"
                            string="Yesterday"
                            context="{'tradeline_time_range': 'yesterday'}"
                        />
                        <filter
                            name="tradeline_move_line_date_last_week"
                            string="Last Week"
                            context="{'tradeline_time_range': 'last_week'}"
                        />
                        <filter
                            name="tradeline_move_line_date_last_month"
                            string="Last Month"
                            context="{'tradeline_time_range': 'last_month'}"
                        />
                        <filter
                            name="tradeline_move_line_date_last_quarter"
                            string="Last Quarter"
                            context="{'tradeline_time_range': 'last_quarter'}"
                        />
                        <filter
                            name="tradeline_move_line_date_last_year"
                            string="Last Year"
                            context="{'tradeline_time_range': 'last_year'}"
                        />
                    </filter>
                    <filter
                        name="tradeline_time_compare_move_line"
                        string="Compare To"
                    >
                        <filter
                            name="tradeline_move_line_compare_none"
                            string="No Comparison"
                            context="{'tradeline_time_compare': 'none', 'tradeline_time_compare_output': 'current'}"
                        />
                        <filter
                            name="tradeline_move_line_compare_previous_period"
                            string="Previous Period"
                            context="{'tradeline_time_compare': 'previous_period', 'tradeline_time_compare_output': 'delta'}"
                        />
                        <filter
                            name="tradeline_move_line_compare_previous_year"
                            string="Previous Year"
                            context="{'tradeline_time_compare': 'previous_year', 'tradeline_time_compare_output': 'delta'}"
                        />
                    </filter>
                    <separator/>
                </xpath>
                <xpath expr="//search/group[1]" position="replace">
                    <group expand="0" string="Group By">
                        <filter name="group_by_branch_id" string="Branch" context="{'group_by': 'branch_id'}"/>
                        <filter name="group_by_channel_id" string="Channel" context="{'group_by': 'channel_id'}"/>
                        <filter name="group_by_company_id" string="Company" context="{'group_by': 'company_id'}"/>
                        <filter name="group_by_currency_id" string="Currency" context="{'group_by': 'currency_id'}"/>
                        <filter name="group_by_partner_id" string="Customer" context="{'group_by': 'partner_id'}"/>
                        <filter name="group_by_date" string="Date" context="{'group_by': 'date:month'}"/>
                        <filter name="group_by_family_id" string="Family" context="{'group_by': 'family_id'}"/>
                        <filter name="group_by_move_id" string="Invoice" context="{'group_by': 'move_id'}"/>
                        <filter name="group_by_move_name" string="Invoice Reference" context="{'group_by': 'move_name'}"/>
                        <filter name="group_by_item_code" string="Item Code" context="{'group_by': 'item_code'}"/>
                        <filter name="group_by_move_type" string="Move Type" context="{'group_by': 'move_type'}"/>
                        <filter name="group_by_product_id" string="Product" context="{'group_by': 'product_id'}"/>
                        <filter name="group_by_categ_id" string="Product Category" context="{'group_by': 'categ_id'}"/>
                        <filter name="group_by_sales_rep_id" string="Sales Rep" context="{'group_by': 'sales_rep_id'}"/>
                        <filter name="group_by_vendor_id" string="Vendor" context="{'group_by': 'vendor_id'}"/>
                    </group>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
