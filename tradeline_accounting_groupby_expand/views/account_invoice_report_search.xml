<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_account_invoice_report_search_groupby_expanded" model="ir.ui.view">
            <field name="name">account.invoice.report.search.groupby.expanded</field>
            <field name="model">account.invoice.report</field>
            <field name="inherit_id" search="[('model', '=', 'account.invoice.report'), ('type', '=', 'search')]"/>
            <field name="arch" type="xml">
                <xpath expr="//search/group[1]" position="replace">
                    <group expand="0" string="Group By">
                        <filter name="group_by_branch_id" string="Branch" context="{'group_by': 'branch_id'}"/>
                        <filter name="group_by_company_id" string="Company" context="{'group_by': 'company_id'}"/>
                        <filter name="group_by_company_currency_id" string="Company Currency" context="{'group_by': 'company_currency_id'}"/>
                        <filter name="group_by_country_id" string="Country" context="{'group_by': 'country_id'}"/>
                        <filter name="group_by_currency_id" string="Currency" context="{'group_by': 'currency_id'}"/>
                        <filter name="group_by_discount_id" string="Discount Reason" context="{'group_by': 'discount_id'}"/>
                        <filter name="group_by_invoice_date_due" string="Due Date" context="{'group_by': 'invoice_date_due:month'}"/>
                        <filter name="group_by_family_id" string="Family" context="{'group_by': 'family_id'}"/>
                        <filter name="group_by_fiscal_position_id" string="Fiscal Position" context="{'group_by': 'fiscal_position_id'}"/>
                        <filter name="group_by_invoice_date" string="Invoice Date" context="{'group_by': 'invoice_date:month'}"/>
                        <filter name="group_by_invoice_number" string="Invoice Number" context="{'group_by': 'invoice_number'}"/>
                        <filter name="group_by_state" string="Invoice Status" context="{'group_by': 'state'}"/>
                        <filter name="group_by_journal_id" string="Journal" context="{'group_by': 'journal_id'}"/>
                        <filter name="group_by_commercial_partner_id" string="Main Partner" context="{'group_by': 'commercial_partner_id'}"/>
                        <filter name="group_by_move_id" string="Move" context="{'group_by': 'move_id'}"/>
                        <filter name="group_by_move_type" string="Move Type" context="{'group_by': 'move_type'}"/>
                        <filter name="group_by_partner_id" string="Partner" context="{'group_by': 'partner_id'}"/>
                        <filter name="group_by_preferred_payment_method_line_id" string="Payment Method" context="{'group_by': 'preferred_payment_method_line_id'}"/>
                        <filter name="group_by_payment_state" string="Payment Status" context="{'group_by': 'payment_state'}"/>
                        <filter name="group_by_point" string="Point" context="{'group_by': 'point'}"/>
                        <filter name="group_by_pricelist_id" string="Pricelist" context="{'group_by': 'pricelist_id'}"/>
                        <filter name="group_by_product_id" string="Product" context="{'group_by': 'product_id'}"/>
                        <filter name="group_by_product_categ_id" string="Product Category" context="{'group_by': 'product_categ_id'}"/>
                        <filter name="group_by_reference_number" string="Reference Number" context="{'group_by': 'reference_number'}"/>
                        <filter name="group_by_account_id" string="Revenue/Expense Account" context="{'group_by': 'account_id'}"/>
                        <filter name="group_by_sales_rep_id" string="Sales Rep" context="{'group_by': 'sales_rep_id'}"/>
                        <filter name="group_by_team_id" string="Sales Team" context="{'group_by': 'team_id'}"/>
                        <filter name="group_by_invoice_user_id" string="Salesperson" context="{'group_by': 'invoice_user_id'}"/>
                        <filter name="group_by_product_uom_id" string="Unit of Measure" context="{'group_by': 'product_uom_id'}"/>
                        <filter name="group_by_vendor_id" string="Vendor" context="{'group_by': 'vendor_id'}"/>
                    </group>
                </xpath>
            </field>
        </record>

        <record id="view_account_invoice_report_search_time_ranges" model="ir.ui.view">
            <field name="name">account.invoice.report.search.time.ranges</field>
            <field name="model">account.invoice.report</field>
            <field name="inherit_id" search="[('model', '=', 'account.invoice.report'), ('type', '=', 'search')]"/>
            <field name="arch" type="xml">
                <xpath expr="//search/filter[@date][1]" position="before">
                    <separator/>
                    <filter
                        name="tradeline_time_based_on_invoice_report"
                        string="Based On"
                    >
                        <filter
                            name="tradeline_based_on_invoice_date"
                            string="Invoice Date"
                            context="{'tradeline_time_based_on': 'invoice_date'}"
                        />
                        <filter
                            name="tradeline_based_on_due_date"
                            string="Due Date"
                            context="{'tradeline_time_based_on': 'invoice_date_due'}"
                        />
                    </filter>
                    <filter
                        name="tradeline_time_ranges_invoice_date"
                        string="Range"
                    >
                        <filter
                            name="tradeline_invoice_date_last_7_days"
                            string="Last 7 Days"
                            context="{'tradeline_time_range': 'last_7_days'}"
                        />
                        <filter
                            name="tradeline_invoice_date_last_30_days"
                            string="Last 30 Days"
                            context="{'tradeline_time_range': 'last_30_days'}"
                        />
                        <filter
                            name="tradeline_invoice_date_last_365_days"
                            string="Last 365 Days"
                            context="{'tradeline_time_range': 'last_365_days'}"
                        />
                        <filter
                            name="tradeline_invoice_date_today"
                            string="Today"
                            context="{'tradeline_time_range': 'today'}"
                        />
                        <filter
                            name="tradeline_invoice_date_this_week"
                            string="This Week"
                            context="{'tradeline_time_range': 'this_week'}"
                        />
                        <filter
                            name="tradeline_invoice_date_this_month"
                            string="This Month"
                            context="{'tradeline_time_range': 'this_month'}"
                        />
                        <filter
                            name="tradeline_invoice_date_this_quarter"
                            string="This Quarter"
                            context="{'tradeline_time_range': 'this_quarter'}"
                        />
                        <filter
                            name="tradeline_invoice_date_this_year"
                            string="This Year"
                            context="{'tradeline_time_range': 'this_year'}"
                        />
                        <filter
                            name="tradeline_invoice_date_yesterday"
                            string="Yesterday"
                            context="{'tradeline_time_range': 'yesterday'}"
                        />
                        <filter
                            name="tradeline_invoice_date_last_week"
                            string="Last Week"
                            context="{'tradeline_time_range': 'last_week'}"
                        />
                        <filter
                            name="tradeline_invoice_date_last_month"
                            string="Last Month"
                            context="{'tradeline_time_range': 'last_month'}"
                        />
                        <filter
                            name="tradeline_invoice_date_last_quarter"
                            string="Last Quarter"
                            context="{'tradeline_time_range': 'last_quarter'}"
                        />
                        <filter
                            name="tradeline_invoice_date_last_year"
                            string="Last Year"
                            context="{'tradeline_time_range': 'last_year'}"
                        />
                    </filter>
                    <filter
                        name="tradeline_time_compare_invoice_report"
                        string="Compare To"
                    >
                        <filter
                            name="tradeline_compare_none"
                            string="No Comparison"
                            context="{'tradeline_time_compare': 'none', 'tradeline_time_compare_output': 'current'}"
                        />
                        <filter
                            name="tradeline_compare_previous_period"
                            string="Previous Period"
                            context="{'tradeline_time_compare': 'previous_period', 'tradeline_time_compare_output': 'delta'}"
                        />
                        <filter
                            name="tradeline_compare_previous_year"
                            string="Previous Year"
                            context="{'tradeline_time_compare': 'previous_year', 'tradeline_time_compare_output': 'delta'}"
                        />
                    </filter>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
