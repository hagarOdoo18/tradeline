<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_tradeline_sale_order_line_report_list" model="ir.ui.view">
        <field name="name">tradeline.sale.order.line.report.list</field>
        <field name="model">sale.order.line</field>
        <field name="arch" type="xml">
            <list string="Sales Order Lines" create="false">
                <field name="seq"/>
                <field name="invoice_type"/>
                <field name="number_order"/>
                <field name="order_date"/>
                <field name="confirmation_date" optional="hide"/>
                <field name="description_product"/>
                <field name="name" string="Name"/>
                <field name="order_partner_id"/>
                <field name="mobile_customer" optional="show"/>
                <field name="phone_customer" optional="hide"/>
                <field name="sequence" optional="hide"/>
                <field name="store_name"/>
                <field name="sales_rep_name"/>
                <field name="product_id"/>
                <field name="item_code_product" optional="show"/>
                <field name="upc" optional="show"/>
                <field name="categ_product" optional="show"/>
                <field name="family_name"/>
                <field name="warranty_name"/>
                <field name="vendor_name_product"/>
                <field name="tax_id" widget="many2many_tags"/>
                <field name="payment_journal"/>
                <field name="payment_amount"/>
                <field name="amount_due"/>
                <field name="note" optional="hide"/>
                <field name="quantity_product" sum="Quantity"/>
                <field name="qty_delivered" sum="Delivered" optional="show"/>
                <field name="qty_invoiced" sum="Invoiced" optional="show"/>
                <field name="price_unit"/>
                <field name="discount" optional="show"/>
                <field name="price_subtotal" sum="Subtotal"/>
                <field name="amount_total_line" sum="Total"/>
                <field name="status_quotation"/>
                <field name="status_sale"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="action_tradeline_sale_order_line_report" model="ir.actions.act_window">
        <field name="name">Sales Order Lines</field>
        <field name="res_model">sale.order.line</field>
        <field name="view_mode">pivot,list</field>
        <field name="view_id" ref="view_tradeline_sale_order_line_report_list"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No sale order lines found.</p>
        </field>
    </record>

    <menuitem
        id="menu_tradeline_sale_order_line_report"
        name="Sales Order Lines"
        parent="sale.sale_order_menu"
        action="action_tradeline_sale_order_line_report"
        groups="tradeline_sale_order_line_report_18.group_sale_order_line"
        sequence="60"/>
</odoo>
