<odoo>
    <record id="view_picking_form_inherit_barcodes" model="ir.ui.view">
        <field name="name">stock.picking.form.download.barcodes</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <header position="inside">
                <button name="action_open_barcode_download_wizard"
                        type="object"
                        string="Download Barcodes"
                        class="btn-primary"/>
            </header>
        </field>
    </record>
</odoo>
