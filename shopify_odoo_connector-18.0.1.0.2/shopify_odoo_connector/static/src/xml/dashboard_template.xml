<?xml version="1.0" encoding="UTF-8" ?>
<!--Template for shopify dashboard-->
<template id="template" xml:space="preserve">
    <t t-name="ShopifyDashboard">
        <div class="accounts-dashboard-wrap">
            <div class="o_dashboards col-xs-12 col-sm-12 col-lg-12 col-md-12"
                 style="background-color: #F1F7F7;">
                <div class="content-header">
                    <div class="container-fluid">
                        <div style="width: 100%; height: 60px;"/>
                        <div class="row" id="all_details"
                             style="margin-top: 0px; display: flex; justify-content: space-around;">
                            <div class="col-xl-3 col-lg-6"
                                 style="margin-bottom: 30px; border-radius: 15px; background-color: #b87333;">
                                <div class="card l-bg-cherry"
                                     id="ttl_customers"
                                     t-on-click="view_customer">
                                    <div class="card-statistic-3 p-4"
                                         style="cursor: pointer;">
                                        <h2 class="text-right">
                                            <i class="fa fa-users"/>
                                        </h2>
                                        <div class="mb-4">
                                            <h5 class="card-title mb-0">Total Customers</h5>
                                        </div>
                                        <div class="row align-items-center mb-2 d-flex">
                                            <div class="col-8">
                                                    <t t-esc="state.customer"/>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-xl-3 col-lg-6"
                                 style="margin-bottom: 30px; border-radius: 15px; background-color: silver;">
                                <div class="card l-bg-cherry"
                                     id="ttl_products"
                                     t-on-click="view_products">
                                    <div class="card-statistic-3 p-4"
                                         style="cursor: pointer;">
                                        <h2 class="text-right">
                                            <img style="width: 22px; height: 22px;"
                                                 src="https://cdn-icons-png.flaticon.com/512/3114/3114633.png"/>
                                        </h2>
                                        <div class="mb-4">
                                            <h5 class="card-title mb-0">Total Products</h5>
                                        </div>
                                        <div class="row align-items-center mb-2 d-flex">
                                            <div class="col-8">
                                                <t t-esc="state.product"/>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-xl-3 col-lg-6"
                                 style="margin-bottom: 30px; border-radius: 15px; background-color: gold;">
                                <div class="card l-bg-cherry" id="ttl_orders"
                                     t-on-click="view_orders">
                                    <div class="card-statistic-3 p-4"
                                         style="cursor: pointer;">
                                        <h2 class="text-right">
                                            <i class="fa fa-shopping-cart"/>
                                        </h2>
                                        <div class="mb-4">
                                            <h5 class="card-title mb-0">Total Orders</h5>
                                        </div>
                                        <div class="row align-items-center mb-2 d-flex">
                                            <div class="col-8">
                                                <t t-esc="state.order"/>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="container-fluid" style="">
                                            <div class="row" id="dashboard"
                                                 style="margin-top: 60px; display: flex; justify-content: space-evenly;">
                                                <t t-foreach="this.state.outputs"
                                                   t-as="rec"
                                                   t-key="rec.id">
                                                <div class='col'
                                                     style='border: 2px  black; background-color: white; border-radius: 15px; max-width: 410px; width: 410px; height: 370px; margin-left: 0px; margin-bottom: 50px;'>
                                                <div t-att-id="rec.consumer_key"
                                                     style='border: 0px solid black; border-radius: 15px; width: 380px; height: 300px; margin-top: 0px;'/>
                                                    <div class='buttons'
                                                         style=' display: flex; justify-content: space-around;'>
                                                        <button class='customer'
                                                                value="rec.id"
                                                                style='border: 1px #b87333; background-color: #b87333; color: solid black; border-radius: 10px; width: 100px; height: 50px;'
                                                                t-on-click.prevent="() => this.view_customer(rec.id)">
                                                            Customers (<span
                                                                t-esc="rec.customer"/>
                                                            )
                                                        </button>
                                                        <button class='product'
                                                                value="rec.id"
                                                                style='border: 1px silver; background-color: silver; color: solid black; border-radius: 10px; width: 100px; height: 50px;'
                                                                t-on-click.prevent="() => this.view_products(rec.id)">
                                                            Products (<span
                                                                t-esc="rec.product"/>
                                                            )
                                                        </button>
                                                        <button class='order'
                                                                value="rec.id"
                                                                style='border: 1px gold; background-color: gold; color: solid black; border-radius: 10px; width: 100px; height: 50px;'
                                                                t-on-click.prevent="() => this.view_orders(rec.id)">
                                                            Orders (<span
                                                                t-esc="rec.order"/>
                                                            )
                                                        </button>
                                                    </div>
                                                </div>
                                            </t>
                                            </div>
                                        </div>

                </div>
            </div>
        </div>
    </t>
</template>