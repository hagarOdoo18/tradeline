<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <!--    Tree view for job cron-->
    <record id="job_cron_view_tree" model="ir.ui.view">
        <field name="name">job.cron.view.tree</field>
        <field name="model">job.cron</field>
        <field name="arch" type="xml">
            <list create="0">
                <field name="model_id"/>
                <field name="function"/>
                <field name="data"/>
                <field name="state"/>
            </list>
        </field>
    </record>
    <!--Job Cron form view-->
    <record id="job_cron_views_form" model="ir.ui.view">
        <field name="name">job.cron.view.form</field>
        <field name="model">job.cron</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="instance_id"/>
                            <field name="function"/>
                        </group>
                        <group>
                            <field name="data"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
<!--    Search view.-->
    <record id="job_cron_view_search" model="ir.ui.view">
        <field name="model">job.cron</field>
        <field name="arch" type="xml">
            <search string="search">
                <field name="model_id"/>
                <separator/>
                <filter string="Pending" name="pending" domain="[('state','=','pending')]"/>
                <filter string="Done" name="done" domain="[('state','=','done')]"/>
                <group>
                    <filter string="State" name="state" context="{'group_by':'state'}"/>
                    <filter string="Model" name="model_id" context="{'group_by':'model_id'}"/>
                </group>
            </search>
        </field>
    </record>
    <!--    Action for job cron-->
    <record id="job_cron_action" model="ir.actions.act_window">
        <field name="name">Jobs</field>
        <field name="res_model">job.cron</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_pending': 1}</field>
    </record>
    <!--    Menu for shopify job cron-->
    <menuitem id="job_cron_menu" name="Jobs"
              parent="shopify_odoo_connector.shopify_configuration_menu_root"
              action="job_cron_action"
              sequence="50"/>
</odoo>
