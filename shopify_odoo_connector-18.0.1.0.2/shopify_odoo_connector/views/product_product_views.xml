<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--    inherited form view of product.product-->
    <record id="product_normal_form_view" model="ir.ui.view">
        <field name="name">
            product.normal.view.form.inherit.shopify.odoo.connector
        </field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_normal_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='shopify_product']" position="after">
                <field name="shopify_variant" invisible="1"/>
            </xpath>
        </field>
    </record>
    <!--    action to view shopify product variants-->
    <record id="product_product_action" model="ir.actions.act_window">
        <field name="name">Shopify Products Variants</field>
        <field name="res_model">product.product</field>
        <field name="domain">[('shopify_sync_ids', '!=', False)]</field>
        <field name="view_mode">list,form</field>
        <field name="target">current</field>
        <field name="view_id" ref="product.product_product_tree_view"/>
        <field name="context">{'create': False}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_empty_folder">
                No Products Variant found
            </p>
        </field>
    </record>
    <!--    menu for shopify product variants-->
    <menuitem id="product_product_menu" name="Product Variants"
              parent="shopify_odoo_connector.product_template_menu_root"
              sequence="2"
              action="product_product_action"/>
</odoo>
