<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================================================================
         Pricelist Import Wizard — Form View
         ================================================================ -->
    <record id="view_pricelist_import_wizard_form" model="ir.ui.view">
        <field name="name">pricelist.import.wizard.form</field>
        <field name="model">pricelist.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Import Pricelist Items">

                <!-- ── HEADER ─────────────────────────────────────────── -->
                <header>
                    <!-- Step 1: Draft → Preview -->
                    <button name="action_preview"
                            string="Preview"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"
                            icon="fa-eye"/>

                    <!-- Step 2: Preview → Import -->
                    <button name="action_import"
                            string="Import"
                            type="object"
                            class="btn-primary"
                            confirm="Are you sure you want to import all valid rows?"
                            invisible="state != 'preview'"
                            icon="fa-upload"/>

                    <!-- Reset from preview -->
                    <button name="action_reset"
                            string="Reset"
                            type="object"
                            class="btn-secondary"
                            invisible="state not in ('preview', 'done')"
                            icon="fa-refresh"/>

                    <!-- Close from any state -->
                    <button name="action_close"
                            string="Close"
                            type="object"
                            class="btn-secondary"
                            icon="fa-times"/>

                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,preview,done"/>
                </header>

                <sheet>

                    <!-- ── PRICELIST INFO BANNER ──────────────────────── -->
                    <div class="oe_title">
                        <h1>
                            <field name="pricelist_id" readonly="1" options="{'no_open': True}"/>
                        </h1>
                    </div>

                    <group>
                        <group string="Pricelist Info">
                            <field name="currency_id"/>
                            <field name="company_id"/>
                        </group>
                        <group string="Fixed Defaults">
                            <field name="applied_on"
                                   widget="radio"
                                   options="{'horizontal': true}"/>
                            <field name="compute_price"
                                   widget="radio"
                                   options="{'horizontal': true}"/>
                        </group>
                    </group>

                    <!-- ── FILE UPLOAD (draft only) ───────────────────── -->
                    <group string="Import File" invisible="state != 'draft'">
                        <group>
                            <field name="import_file"
                                   widget="binary"
                                   filename="import_file_name"
                                   string="Spreadsheet (.xlsx / .xls / .csv)"/>
                            <field name="import_file_name" invisible="1"/>
                        </group>
                        <group>
                            <field name="date_start"/>
                            <field name="date_end"/>
                            <field name="overwrite_existing"/>
                        </group>
                        <!-- Template hint -->

                    </group>

                    <!-- ── OPTIONS (still editable in preview) ───────── -->
                    <group string="Import Options" invisible="state == 'draft'">
                        <group>
                            <field name="date_start"/>
                            <field name="date_end"/>
                        </group>
                        <group>
                            <field name="overwrite_existing"/>
                        </group>
                    </group>

                    <!-- ── SUMMARY BANNER ────────────────────────────── -->


                    <!-- ── PREVIEW TABLE ──────────────────────────────── -->
                    <notebook invisible="state == 'draft'">
                        <page string="Preview Lines" name="preview_lines">
                            <field name="preview_line_ids"
                                   readonly="1"
                                   widget="one2many_list"
                                   noupdate="1">
                                <list decoration-danger="status == 'error'"
                                      decoration-success="status == 'ok'"
                                      >
                                    <field name="item_code"/>
                                    <field name="product_name"/>
                                    <field name="product_tmpl_id" optional="show"/>
                                    <field name="fixed_price" string="Fixed Price"/>
                                    <field name="status" widget="badge"
                                           decoration-success="status == 'ok'"
                                           decoration-danger="status == 'error'"/>
                                    <field name="error_message"
                                           optional="show"
                                           string="Error"/>
                                </list>
                            </field>
                        </page>
                    </notebook>

                </sheet>
            </form>
        </field>
    </record>

    <!-- ================================================================
         Action to open the wizard
         ================================================================ -->
    <record id="action_pricelist_import_wizard" model="ir.actions.act_window">
        <field name="name">Import Items from File</field>
        <field name="res_model">pricelist.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_pricelist_import_wizard_form"/>
        <field name="target">new</field>
        <field name="context">{'active_id': active_id}</field>
    </record>

</odoo>
