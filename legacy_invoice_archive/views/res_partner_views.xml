<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_form_legacy_invoice_archive" model="ir.ui.view">
        <field name="name">res.partner.form.legacy.invoice.archive</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button class="oe_stat_button"
                        type="object"
                        name="action_open_legacy_invoices"
                        icon="fa-archive"
                        groups="account.group_account_readonly">
                    <field name="legacy_invoice_count" string="Legacy Invoices" widget="statinfo"/>
                </button>
            </xpath>
        </field>
    </record>
</odoo>