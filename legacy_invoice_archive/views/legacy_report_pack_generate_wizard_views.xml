<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_legacy_report_pack_generate_wizard_form" model="ir.ui.view">
        <field name="name">legacy.report.pack.generate.wizard.form</field>
        <field name="model">legacy.report.pack.generate.wizard</field>
        <field name="arch" type="xml">
            <form string="Generate Legacy Report" create="false" edit="false">
                <group>
                    <field name="report_pack_id"/>
                    <field name="output_format"/>
                </group>
                <group string="Invoice Filters">
                    <group>
                        <field name="date_from"/>
                        <field name="date_to"/>
                    </group>
                    <group>
                        <field name="invoice_type"/>
                        <field name="invoice_state"/>
                    </group>
                </group>
                <footer>
                    <button string="Generate" type="object" name="action_generate" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
