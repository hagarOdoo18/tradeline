<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_legacy_invoice_list" model="ir.ui.view">
        <field name="name">legacy.invoice.list</field>
        <field name="model">legacy.invoice</field>
        <field name="arch" type="xml">
            <list string="Legacy Invoices" create="false" edit="false" delete="false" export_xlsx="1">
                <field name="invoice_date"/>
                <field name="number"/>
                <field name="source_name" optional="show"/>
                <field name="source_partner_name" string="Legacy Customer" optional="show"/>
                <field name="source_partner_code" string="Customer Code" optional="show"/>
                <field name="source_partner_type" string="Customer Type" optional="show"/>
                <field name="source_partner_mobile" string="Customer Mobile" optional="show"/>
                <field name="source_partner_tax_id" string="Tax ID" optional="show"/>
                <field name="source_partner_national_id" string="National ID" optional="show"/>
                <field name="source_sales_rep_name" optional="show"/>
                <field name="source_sales_rep_code" optional="show"/>
                <field name="source_team_name" optional="show"/>
                <field name="source_reference_number" optional="show"/>
                <field name="source_po_ref" string="Invoice PO Ref (Raw)" optional="show"/>
                <field name="legacy_po_id" string="Linked PO (Open)" optional="show"/>
                <button name="action_open_legacy_po" type="object" string="Open Linked PO" invisible="not legacy_po_id"/>
                <field name="discount_reason_normalized" optional="show"/>
                <field name="source_journal_name" optional="show"/>
                <field name="source_payment_term_name" optional="show"/>
                <field name="payment_journal_summary" optional="show"/>
                <field name="payment_method_summary" optional="show"/>
                <field name="partner_id"/>
                <field name="state"/>
                <field name="invoice_type" optional="show"/>
                <field name="amount_total" sum="Total"/>
                <field name="amount_residual" sum="Residual" optional="show"/>
                <field name="line_count" optional="show"/>
                <field name="attachment_count" optional="show"/>
                <field name="source_db" optional="hide"/>
                <field name="source_id" optional="hide"/>
                <field name="import_batch_id" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_legacy_invoice_search" model="ir.ui.view">
        <field name="name">legacy.invoice.search</field>
        <field name="model">legacy.invoice</field>
        <field name="arch" type="xml">
            <search string="Legacy Invoices">
                <field name="smart_search" string="Smart Search"/>
                <field name="number" string="Invoice Number" filter_domain="[('number','ilike', self)]"/>
                <field name="source_name" string="Source Document"/>
                <field name="partner_id" string="Partner"/>
                <field name="source_partner_name" string="Legacy Customer"/>
                <field name="source_partner_code" string="Customer Code"/>
                <field name="source_partner_type" string="Customer Type"/>
                <field name="source_partner_mobile" string="Customer Mobile"/>
                <field name="source_partner_tax_id" string="Tax ID"/>
                <field name="source_partner_national_id" string="National ID"/>
                <field name="source_sales_rep_name" string="Sales Rep"/>
                <field name="source_sales_rep_code" string="Sales Rep Code"/>
                <field name="source_team_name" string="Sales Team"/>
                <field name="discount_reason_normalized" string="Discount Reason"/>
                <field name="payment_journal_summary" string="Payment Journal"/>
                <field name="payment_method_summary" string="Payment Method"/>
                <field name="source_journal_name" string="Journal"/>
                <field name="source_payment_term_name" string="Payment Terms"/>
                <field name="source_fiscal_position_name" string="Fiscal Position"/>
                <field name="source_partner_bank_name" string="Bank Account"/>
                <field name="source_reference_number" string="Reference #"/>
                <field name="source_po_ref" string="Invoice PO Ref (Raw)"/>
                <field name="legacy_po_id" string="Linked PO (Open)"/>
                <field name="source_tradeline_month" string="Tradeline Month"/>
                <field name="source_tradeline_year" string="Tradeline Year"/>
                <field name="product_summary" string="Product / Item"/>
                <field name="serial_summary" string="Serial Number"/>
                <field name="number"
                        string="Product / Item Code"
                        filter_domain="['|',
                             ('line_ids.name','ilike', self),
                             ('line_ids.item_code','ilike', self)]"/>
                <field name="number"
                       string="Serial Number"
                       filter_domain="['|',
                            ('serial_ref_ids.lot_name','ilike', self),
                            ('serial_ref_ids.item_code','ilike', self)]"/>
                <field name="number"
                        string="Payment Ref / Method"
                        filter_domain="['|','|',
                             ('payment_link_ids.reference','ilike', self),
                             ('payment_link_ids.payment_method_name','ilike', self),
                             ('payment_link_ids.journal_name','ilike', self)]"/>
                <field name="invoice_date"/>
                <field name="state"/>
                <field name="invoice_type"/>
                <field name="source_db"/>
                <field name="source_id"/>
                <separator/>
                <filter name="tradeline_time_ranges_legacy_invoice_date" string="Invoice Date" date="invoice_date"/>
                <separator/>
                <filter name="filter_paid" string="Paid" domain="[('state', '=', 'paid')]"/>
                <filter name="filter_open" string="Open" domain="[('state', '=', 'open')]"/>
                <filter name="filter_cancel" string="Cancelled" domain="[('state', '=', 'cancel')]"/>
                <filter name="filter_has_serial" string="With Serials" domain="[('serial_ref_ids', '!=', False)]"/>
                <filter name="filter_has_payment" string="With Payments" domain="[('payment_link_ids', '!=', False)]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter name="group_partner" string="Customer" context="{'group_by': 'partner_id'}"/>
                    <filter name="group_customer_type" string="Customer Type" context="{'group_by': 'source_partner_type'}"/>
                    <filter name="group_state" string="State" context="{'group_by': 'state'}"/>
                    <filter name="group_month" string="Month" context="{'group_by': 'invoice_date:month'}"/>
                    <filter name="group_type" string="Type" context="{'group_by': 'invoice_type'}"/>
                    <filter name="group_discount_reason" string="Discount Reason" context="{'group_by': 'discount_reason_normalized'}"/>
                    <filter name="group_sales_rep" string="Sales Rep" context="{'group_by': 'source_sales_rep_name'}"/>
                    <filter name="group_sales_rep_code" string="Sales Rep Code" context="{'group_by': 'source_sales_rep_code'}"/>
                    <filter name="group_sales_team" string="Sales Team" context="{'group_by': 'source_team_name'}"/>
                    <filter name="group_journal" string="Journal" context="{'group_by': 'source_journal_name'}"/>
                    <filter name="group_payment_terms" string="Payment Terms" context="{'group_by': 'source_payment_term_name'}"/>
                    <filter name="group_tradeline_month" string="Tradeline Month" context="{'group_by': 'source_tradeline_month'}"/>
                    <filter name="group_tradeline_year" string="Tradeline Year" context="{'group_by': 'source_tradeline_year'}"/>
                    <filter name="group_payment_method" string="Payment Method" context="{'group_by': 'payment_method_summary'}"/>
                    <filter name="group_payment_journal" string="Payment Journal" context="{'group_by': 'payment_journal_summary'}"/>
                    <filter name="group_legacy_po" string="Linked PO (Open)" context="{'group_by': 'legacy_po_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_legacy_invoice_form" model="ir.ui.view">
        <field name="name">legacy.invoice.form</field>
        <field name="model">legacy.invoice</field>
        <field name="arch" type="xml">
            <form string="Legacy Invoice" create="false" edit="false" delete="false">
                <header>
                    <button name="%(action_report_legacy_invoice)d"
                            type="action"
                            string="Print Legacy Invoice"
                            class="btn-primary"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="number" readonly="1"/>
                        </h1>
                        <h2>
                            <field name="source_name" readonly="1"/>
                        </h2>
                    </div>
                    <group>
                        <group>
                            <field name="partner_id"/>
                            <field name="invoice_date"/>
                            <field name="due_date"/>
                            <field name="state"/>
                            <field name="invoice_type"/>
                            <field name="discount_reason_normalized"/>
                            <field name="discount_reason_source"/>
                            <field name="discount_reason_inferred"/>
                            <field name="source_sales_rep_name"/>
                            <field name="source_sales_rep_code"/>
                            <field name="source_team_name"/>
                            <field name="source_reference_number"/>
                            <field name="source_po_ref" string="Invoice PO Ref (Raw)"/>
                            <field name="legacy_po_id" string="Linked PO (Open)"/>
                            <button name="action_open_legacy_po"
                                    type="object"
                                    string="Open Linked PO"
                                    class="oe_link"
                                    invisible="not legacy_po_id"/>
                            <field name="source_offer"/>
                            <field name="source_sms_sent"/>
                            <field name="source_tradeline_month"/>
                            <field name="source_tradeline_year"/>
                        </group>
                        <group>
                            <field name="company_id"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="source_currency_name"/>
                            <field name="source_currency_rate"/>
                            <field name="source_journal_name"/>
                            <field name="source_payment_term_name"/>
                            <field name="source_fiscal_position_name"/>
                            <field name="source_partner_bank_name"/>
                            <field name="amount_untaxed"/>
                            <field name="amount_tax"/>
                            <field name="amount_total"/>
                            <field name="amount_residual"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="source_db"/>
                            <field name="source_model"/>
                            <field name="source_id"/>
                            <field name="source_partner_id"/>
                            <field name="source_partner_name"/>
                            <field name="source_partner_code"/>
                            <field name="source_partner_type"/>
                            <field name="source_partner_mobile"/>
                            <field name="source_partner_tax_id"/>
                            <field name="source_partner_national_id"/>
                        </group>
                        <group>
                            <field name="import_batch_id"/>
                            <field name="imported_at"/>
                            <field name="line_count"/>
                            <field name="attachment_count"/>
                            <field name="active"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Lines">
                            <field name="line_ids" readonly="1">
                                <list create="false" edit="false" delete="false">
                                    <field name="sequence" optional="hide"/>
                                    <field name="item_code" optional="show"/>
                                    <field name="product_id"/>
                                    <field name="name"/>
                                    <field name="quantity"/>
                                    <field name="uom_id" optional="show"/>
                                    <field name="price_unit"/>
                                    <field name="discount" optional="show"/>
                                    <field name="discount_reason_normalized" optional="show"/>
                                    <field name="source_account_analytic_name" optional="show"/>
                                    <field name="source_family_name" optional="show"/>
                                    <field name="source_line_sales_rep_name" optional="show"/>
                                    <field name="source_line_sales_rep_code" optional="show"/>
                                    <field name="source_pricelist_name" optional="show"/>
                                    <field name="source_vendor_name" optional="show"/>
                                    <field name="source_sub_category_name" optional="show"/>
                                    <field name="source_tax_text" optional="show"/>
                                    <field name="product_incentive" optional="show"/>
                                    <field name="product_point" optional="show"/>
                                    <field name="price_subtotal" sum="Subtotal"/>
                                    <field name="price_total" sum="Total"/>
                                    <field name="source_id" optional="hide"/>
                                </list>
                            </field>
                        </page>

                        <page string="Taxes">
                            <field name="tax_line_ids" readonly="1">
                                <list create="false" edit="false" delete="false">
                                    <field name="name"/>
                                    <field name="tax_id" optional="show"/>
                                    <field name="tax_group_id" optional="show"/>
                                    <field name="base_amount" sum="Base"/>
                                    <field name="amount" sum="Tax"/>
                                    <field name="source_id" optional="hide"/>
                                </list>
                            </field>
                        </page>

                        <page string="Payments">
                            <field name="payment_link_ids" readonly="1">
                                <list create="false" edit="false" delete="false">
                                    <field name="payment_date"/>
                                    <field name="name"/>
                                    <field name="reference" optional="show"/>
                                    <field name="journal_id" optional="show"/>
                                    <field name="journal_name" optional="show"/>
                                    <field name="journal_code" optional="hide"/>
                                    <field name="payment_method_name" string="Payment Method" optional="show"/>
                                    <field name="payment_method_code" optional="hide"/>
                                    <field name="amount" sum="Total"/>
                                    <field name="source_payment_id" optional="hide"/>
                                </list>
                            </field>
                        </page>

                        <page string="Attachments">
                            <field name="attachment_ids" readonly="1">
                                <list create="false" edit="false" delete="false">
                                    <field name="name"/>
                                    <field name="datas_fname" optional="show"/>
                                    <field name="mimetype" optional="show"/>
                                    <field name="file_size" optional="show"/>
                                    <field name="checksum" optional="hide"/>
                                    <field name="source_attachment_id" optional="hide"/>
                                </list>
                            </field>
                        </page>

                        <page string="Serial References">
                            <field name="serial_ref_ids" readonly="1">
                                <list create="false" edit="false" delete="false">
                                    <field name="lot_name"/>
                                    <field name="item_code" optional="show"/>
                                    <field name="qty_done"/>
                                    <field name="product_category_id" optional="show"/>
                                    <field name="match_status" optional="show"/>
                                    <field name="source_move_id" optional="hide"/>
                                    <field name="source_lot_id" optional="hide"/>
                                    <field name="source_move_line_id" optional="hide"/>
                                    <field name="source_picking_id" optional="hide"/>
                                </list>
                            </field>
                            <group>
                                <field name="print_notes"/>
                                <field name="notes_pos"/>
                                <field name="product_notes"/>
                            </group>
                        </page>

                        <page string="Customer Links">
                            <field name="customer_bridge_ids" readonly="1">
                                <list create="false" edit="false" delete="false">
                                    <field name="source_partner_id"/>
                                    <field name="source_partner_name"/>
                                    <field name="target_partner_id"/>
                                    <field name="match_method"/>
                                    <field name="match_status"/>
                                    <field name="confidence" optional="show"/>
                                </list>
                            </field>
                        </page>

                        <page string="Legacy Raw">
                            <group>
                                <field name="comment"/>
                                <field name="legacy_payload"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_legacy_invoice" model="ir.actions.act_window">
        <field name="name">Legacy Invoices</field>
        <field name="res_model">legacy.invoice</field>
        <field name="view_mode">list,form,pivot,graph</field>
        <field name="view_id" ref="view_legacy_invoice_list"/>
        <field name="search_view_id" ref="view_legacy_invoice_search"/>
        <field name="context">{'search_default_filter_open': 1, 'tradeline_groupby_expanded': 1, 'tradeline_time_ranges_native': 1, 'tradeline_time_ranges_ui_v2': 1}</field>
        <field name="help" type="html">
            <p>
                Read-only archive of Odoo 12 invoices, lines, payments, attachments, and serial references.
            </p>
        </field>
    </record>

    <menuitem id="menu_legacy_invoice"
              name="Legacy Invoices"
              parent="account.menu_finance_receivables"
              action="action_legacy_invoice"
              sequence="60"
              groups="account.group_account_readonly"/>
</odoo>
