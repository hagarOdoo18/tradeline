<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_legacy_invoice_analysis_list" model="ir.ui.view">
        <field name="name">legacy.invoice.line.analysis.list</field>
        <field name="model">legacy.invoice.line</field>
        <field name="arch" type="xml">
            <list string="Legacy Invoice Analysis" create="false" edit="false" delete="false" export_xlsx="1">
                <field name="invoice_date"/>
                <field name="due_date" optional="show"/>
                <field name="invoice_number"/>
                <field name="source_name" optional="show"/>
                <field name="partner_id"/>
                <field name="source_partner_name" optional="show"/>
                <field name="product_id"/>
                <field name="product_name" optional="show"/>
                <field name="item_code" optional="show"/>
                <field name="product_category_id" optional="show"/>
                <field name="source_sub_category_name" optional="show"/>
                <field name="source_family_name" optional="show"/>
                <field name="source_vendor_name" optional="show"/>
                <field name="cost_method" optional="show"/>
                <field name="source_sales_rep_name" optional="show"/>
                <field name="source_line_sales_rep_name" optional="show"/>
                <field name="source_team_name" optional="show"/>
                <field name="source_journal_name" optional="show"/>
                <field name="source_payment_term_name" optional="show"/>
                <field name="source_fiscal_position_name" optional="show"/>
                <field name="discount_reason_normalized" optional="show"/>
                <field name="source_po_ref" optional="show"/>
                <field name="legacy_po_id" optional="show"/>
                <field name="source_reference_number" optional="show"/>
                <field name="payment_journal_summary" optional="show"/>
                <field name="payment_method_summary" optional="show"/>
                <field name="source_account_analytic_name" optional="show"/>
                <field name="source_pricelist_name" optional="show"/>
                <field name="source_tax_text" optional="show"/>
                <field name="quantity" sum="Qty"/>
                <field name="product_incentive" sum="Incentive" optional="show"/>
                <field name="product_point" sum="Points" optional="show"/>
                <field name="amount_untaxed" sum="Untaxed"/>
                <field name="amount_tax" sum="Tax"/>
                <field name="amount_total" sum="Total"/>
                <field name="company_id" optional="show"/>
                <field name="company_currency_id" optional="hide"/>
                <field name="currency_id" optional="hide"/>
                <field name="source_currency_rate" optional="hide"/>
                <field name="source_tradeline_month" optional="hide"/>
                <field name="source_tradeline_year" optional="hide"/>
                <field name="source_offer" optional="hide"/>
                <field name="source_sms_sent" optional="hide"/>
                <field name="invoice_type" optional="show"/>
                <field name="state" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_legacy_invoice_analysis_search" model="ir.ui.view">
        <field name="name">legacy.invoice.line.analysis.search</field>
        <field name="model">legacy.invoice.line</field>
        <field name="arch" type="xml">
            <search string="Legacy Invoice Analysis">
                <field name="product_search_text" string="Product"/>
                <field name="product_id"/>
                <field name="product_name"/>
                <field name="item_code"/>
                <field name="cost_method"/>
                <field name="product_category_id" string="Product Category"/>
                <field name="discount_reason_normalized" string="Discount Reason"/>
                <field name="payment_journal_summary" string="Payment Journal"/>
                <field name="payment_method_summary" string="Payment Method"/>
                <field name="partner_id" string="Partner"/>
                <field name="source_partner_name" string="Legacy Partner"/>
                <field name="source_sales_rep_name" string="Sales Rep"/>
                <field name="source_line_sales_rep_name" string="Line Sales Rep"/>
                <field name="source_team_name" string="Sales Team"/>
                <field name="source_name" string="Source Document"/>
                <field name="source_reference_number" string="Reference #"/>
                <field name="source_po_ref" string="PO Ref"/>
                <field name="legacy_po_id" string="Legacy PO"/>
                <field name="source_offer" string="Offer"/>
                <field name="source_sms_sent" string="SMS Sent"/>
                <field name="source_journal_name" string="Journal"/>
                <field name="source_payment_term_name" string="Payment Terms"/>
                <field name="source_fiscal_position_name" string="Fiscal Position"/>
                <field name="source_partner_bank_name" string="Bank Account"/>
                <field name="source_account_analytic_name" string="Analytic Account"/>
                <field name="source_family_name" string="Product Family"/>
                <field name="source_pricelist_name" string="Pricelist"/>
                <field name="source_vendor_name" string="Vendor Name"/>
                <field name="source_sub_category_name" string="Sub Category"/>
                <field name="source_tax_text" string="Tax"/>
                <field name="source_tradeline_month" string="Tradeline Month"/>
                <field name="source_tradeline_year" string="Tradeline Year"/>
                <field name="company_id" string="Company"/>
                <field name="company_currency_id" string="Company Currency"/>
                <field name="currency_id" string="Currency"/>
                <field name="account_id" string="Revenue/Expense Account"/>
                <field name="uom_id" string="Unit of Measure"/>
                <field name="invoice_number"/>
                <field name="source_db" string="Source Db"/>
                <field name="invoice_date"/>
                <field name="due_date"/>
                <field name="state"/>
                <field name="invoice_type"/>
                <separator/>
                <filter name="tradeline_time_ranges_legacy_invoice_date" string="Invoice Date" date="invoice_date"/>
                <filter name="tradeline_time_ranges_legacy_due_date" string="Due Date" date="due_date"/>
                <separator/>
                <filter name="legacy_analysis_open" string="Open" domain="[('state', '=', 'open')]"/>
                <filter name="legacy_analysis_paid" string="Paid" domain="[('state', '=', 'paid')]"/>
                <filter name="legacy_analysis_cancel" string="Cancelled" domain="[('state', '=', 'cancel')]"/>
                <group expand="0" string="Group By">
                    <filter name="legacy_analysis_group_company" string="Company" context="{'group_by': 'company_id'}"/>
                    <filter name="legacy_analysis_group_company_currency" string="Company Currency" context="{'group_by': 'company_currency_id'}"/>
                    <filter name="legacy_analysis_group_currency" string="Currency" context="{'group_by': 'currency_id'}"/>
                    <filter name="legacy_analysis_group_due_date" string="Due Date" context="{'group_by': 'due_date:month'}"/>
                    <filter name="legacy_analysis_group_invoice_date" string="Invoice Date" context="{'group_by': 'invoice_date:month'}"/>
                    <filter name="legacy_analysis_group_invoice_number" string="Invoice Number" context="{'group_by': 'invoice_number'}"/>
                    <filter name="legacy_analysis_group_invoice_status" string="Invoice Status" context="{'group_by': 'state'}"/>
                    <filter name="legacy_analysis_group_product" string="Product" context="{'group_by': 'product_id'}"/>
                    <filter name="legacy_analysis_group_product_name" string="Product Name" context="{'group_by': 'product_name'}"/>
                    <filter name="legacy_analysis_group_item_code" string="Item Code" context="{'group_by': 'item_code'}"/>
                    <filter name="legacy_analysis_group_cost" string="Cost Method" context="{'group_by': 'cost_method'}"/>
                    <filter name="legacy_analysis_group_sub_category" string="Product Category" context="{'group_by': 'product_category_id'}"/>
                    <filter name="legacy_analysis_group_sub_category_name" string="Sub Category" context="{'group_by': 'source_sub_category_name'}"/>
                    <filter name="legacy_analysis_group_family" string="Product Family" context="{'group_by': 'source_family_name'}"/>
                    <filter name="legacy_analysis_group_discount_reason" string="Discount Reason" context="{'group_by': 'discount_reason_normalized'}"/>
                    <filter name="legacy_analysis_group_partner" string="Partner" context="{'group_by': 'partner_id'}"/>
                    <filter name="legacy_analysis_group_salesperson" string="Sales Rep" context="{'group_by': 'source_sales_rep_name'}"/>
                    <filter name="legacy_analysis_group_line_salesperson" string="Line Sales Rep" context="{'group_by': 'source_line_sales_rep_name'}"/>
                    <filter name="legacy_analysis_group_sales_team" string="Sales Team" context="{'group_by': 'source_team_name'}"/>
                    <filter name="legacy_analysis_group_journal" string="Journal" context="{'group_by': 'source_journal_name'}"/>
                    <filter name="legacy_analysis_group_payment_term" string="Payment Terms" context="{'group_by': 'source_payment_term_name'}"/>
                    <filter name="legacy_analysis_group_fiscal_position" string="Fiscal Position" context="{'group_by': 'source_fiscal_position_name'}"/>
                    <filter name="legacy_analysis_group_vendor" string="Vendor Name" context="{'group_by': 'source_vendor_name'}"/>
                    <filter name="legacy_analysis_group_pricelist" string="Pricelist" context="{'group_by': 'source_pricelist_name'}"/>
                    <filter name="legacy_analysis_group_analytic" string="Analytic Account" context="{'group_by': 'source_account_analytic_name'}"/>
                    <filter name="legacy_analysis_group_month" string="Invoice Month" context="{'group_by': 'invoice_date:month'}"/>
                    <filter name="legacy_analysis_group_tradeline_month" string="Tradeline Month" context="{'group_by': 'source_tradeline_month'}"/>
                    <filter name="legacy_analysis_group_tradeline_year" string="Tradeline Year" context="{'group_by': 'source_tradeline_year'}"/>
                    <filter name="legacy_analysis_group_type" string="Move Type" context="{'group_by': 'invoice_type'}"/>
                    <filter name="legacy_analysis_group_state" string="Invoice State" context="{'group_by': 'state'}"/>
                    <filter name="legacy_analysis_group_payment_method" string="Payment Method" context="{'group_by': 'payment_method_summary'}"/>
                    <filter name="legacy_analysis_group_payment_journal" string="Payment Journal" context="{'group_by': 'payment_journal_summary'}"/>
                    <filter name="legacy_analysis_group_source_db" string="Source Db" context="{'group_by': 'source_db'}"/>
                    <filter name="legacy_analysis_group_po" string="Legacy PO" context="{'group_by': 'legacy_po_id'}"/>
                    <filter name="legacy_analysis_group_account" string="Revenue/Expense Account" context="{'group_by': 'account_id'}"/>
                    <filter name="legacy_analysis_group_uom" string="Unit of Measure" context="{'group_by': 'uom_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_legacy_invoice_pivot" model="ir.ui.view">
        <field name="name">legacy.invoice.line.analysis.pivot</field>
        <field name="model">legacy.invoice.line</field>
        <field name="arch" type="xml">
            <pivot string="Legacy Invoice Analysis">
                <field name="amount_untaxed" type="measure"/>
                <field name="amount_tax" type="measure"/>
                <field name="amount_total" type="measure"/>
                <field name="quantity" type="measure"/>
                <field name="discount" type="measure"/>
                <field name="product_incentive" type="measure"/>
                <field name="product_point" type="measure"/>
                <field name="invoice_date" interval="month" type="col"/>
                <field name="partner_id" type="row"/>
            </pivot>
        </field>
    </record>

    <record id="view_legacy_invoice_graph" model="ir.ui.view">
        <field name="name">legacy.invoice.line.analysis.graph</field>
        <field name="model">legacy.invoice.line</field>
        <field name="arch" type="xml">
            <graph string="Legacy Invoice Analysis" type="bar">
                <field name="invoice_date" interval="month"/>
                <field name="amount_untaxed" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="action_legacy_invoice_analysis" model="ir.actions.act_window">
        <field name="name">Legacy Invoice Analysis</field>
        <field name="res_model">legacy.invoice.line</field>
        <field name="view_mode">graph,pivot,list</field>
        <field name="search_view_id" ref="view_legacy_invoice_analysis_search"/>
        <field name="context">{'search_default_legacy_analysis_group_month': 1, 'tradeline_groupby_expanded': 1, 'tradeline_time_ranges_native': 1, 'tradeline_time_ranges_ui_v2': 1}</field>
    </record>

    <record id="view_legacy_payment_link_list" model="ir.ui.view">
        <field name="name">legacy.invoice.payment.link.list</field>
        <field name="model">legacy.invoice.payment.link</field>
        <field name="arch" type="xml">
            <list string="Legacy Payments" create="false" edit="false" delete="false" export_xlsx="1">
                <field name="invoice_date"/>
                <field name="payment_date"/>
                <field name="invoice_id"/>
                <field name="partner_id"/>
                <field name="reference" optional="show"/>
                <field name="payment_method_name"/>
                <field name="payment_method_code" optional="hide"/>
                <field name="journal_id" optional="show"/>
                <field name="amount" sum="Total"/>
                <field name="invoice_type" optional="show"/>
                <field name="state" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_legacy_payment_link_pivot" model="ir.ui.view">
        <field name="name">legacy.invoice.payment.link.pivot</field>
        <field name="model">legacy.invoice.payment.link</field>
        <field name="arch" type="xml">
            <pivot string="Legacy Payment Analysis">
                <field name="amount" type="measure"/>
                <field name="invoice_date" interval="month" type="col"/>
                <field name="payment_method_name" type="row"/>
            </pivot>
        </field>
    </record>

    <record id="view_legacy_payment_link_graph" model="ir.ui.view">
        <field name="name">legacy.invoice.payment.link.graph</field>
        <field name="model">legacy.invoice.payment.link</field>
        <field name="arch" type="xml">
            <graph string="Legacy Payment Analysis" type="bar">
                <field name="invoice_date" interval="month"/>
                <field name="amount" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="view_legacy_payment_link_search" model="ir.ui.view">
        <field name="name">legacy.invoice.payment.link.search</field>
        <field name="model">legacy.invoice.payment.link</field>
        <field name="arch" type="xml">
            <search string="Legacy Payments">
                <field name="invoice_id"/>
                <field name="partner_id"/>
                <field name="reference"/>
                <field name="payment_method_name"/>
                <field name="journal_id"/>
                <field name="payment_date"/>
                <field name="invoice_date"/>
                <field name="state"/>
                <field name="invoice_type"/>
                <separator/>
                <filter name="tradeline_time_ranges_legacy_payment_invoice_date" string="Invoice Date" date="invoice_date"/>
                <filter name="tradeline_time_ranges_legacy_payment_date" string="Payment Date" date="payment_date"/>
                <separator/>
                <filter name="payment_open" string="Open Invoices" domain="[('state', '=', 'open')]"/>
                <filter name="payment_paid" string="Paid Invoices" domain="[('state', '=', 'paid')]"/>
                <group expand="0" string="Group By">
                    <filter name="payment_group_method" string="Payment Method" context="{'group_by': 'payment_method_name'}"/>
                    <filter name="payment_group_journal" string="Journal" context="{'group_by': 'journal_id'}"/>
                    <filter name="payment_group_partner" string="Customer" context="{'group_by': 'partner_id'}"/>
                    <filter name="payment_group_month" string="Invoice Month" context="{'group_by': 'invoice_date:month'}"/>
                    <filter name="payment_group_state" string="Invoice State" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_legacy_payment_link_analysis" model="ir.actions.act_window">
        <field name="name">Legacy Payment Analysis</field>
        <field name="res_model">legacy.invoice.payment.link</field>
        <field name="view_mode">graph,pivot,list</field>
        <field name="search_view_id" ref="view_legacy_payment_link_search"/>
        <field name="context">{'search_default_payment_group_month': 1, 'tradeline_groupby_expanded': 1, 'tradeline_time_ranges_native': 1, 'tradeline_time_ranges_ui_v2': 1}</field>
    </record>

    <record id="view_legacy_serial_ref_list" model="ir.ui.view">
        <field name="name">legacy.invoice.serial.ref.list</field>
        <field name="model">legacy.invoice.serial.ref</field>
        <field name="arch" type="xml">
            <list string="Legacy Serials" create="false" edit="false" delete="false" export_xlsx="1">
                <field name="invoice_date"/>
                <field name="invoice_id"/>
                <field name="partner_id"/>
                <field name="lot_name"/>
                <field name="item_code"/>
                <field name="qty_done" sum="Qty"/>
                <field name="product_category_id" optional="show"/>
                <field name="match_status"/>
                <field name="invoice_type" optional="show"/>
                <field name="state" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_legacy_serial_ref_pivot" model="ir.ui.view">
        <field name="name">legacy.invoice.serial.ref.pivot</field>
        <field name="model">legacy.invoice.serial.ref</field>
        <field name="arch" type="xml">
            <pivot string="Legacy Serial Analysis">
                <field name="qty_done" type="measure"/>
                <field name="invoice_date" interval="month" type="col"/>
                <field name="item_code" type="row"/>
                <field name="match_status" type="row"/>
            </pivot>
        </field>
    </record>

    <record id="view_legacy_serial_ref_graph" model="ir.ui.view">
        <field name="name">legacy.invoice.serial.ref.graph</field>
        <field name="model">legacy.invoice.serial.ref</field>
        <field name="arch" type="xml">
            <graph string="Legacy Serial Analysis" type="bar">
                <field name="invoice_date" interval="month"/>
                <field name="qty_done" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="view_legacy_serial_ref_search" model="ir.ui.view">
        <field name="name">legacy.invoice.serial.ref.search</field>
        <field name="model">legacy.invoice.serial.ref</field>
        <field name="arch" type="xml">
            <search string="Legacy Serials">
                <field name="invoice_id"/>
                <field name="partner_id"/>
                <field name="lot_name"/>
                <field name="item_code"/>
                <field name="product_category_id"/>
                <field name="invoice_date"/>
                <field name="match_status"/>
                <separator/>
                <filter name="tradeline_time_ranges_legacy_serial_invoice_date" string="Invoice Date" date="invoice_date"/>
                <separator/>
                <filter name="serial_verified" string="Verified" domain="[('match_status', '=', 'verified')]"/>
                <filter name="serial_candidate" string="Candidate" domain="[('match_status', '=', 'candidate')]"/>
                <group expand="0" string="Group By">
                    <filter name="serial_group_item" string="Item Code" context="{'group_by': 'item_code'}"/>
                    <filter name="serial_group_category" string="Category" context="{'group_by': 'product_category_id'}"/>
                    <filter name="serial_group_customer" string="Customer" context="{'group_by': 'partner_id'}"/>
                    <filter name="serial_group_month" string="Invoice Month" context="{'group_by': 'invoice_date:month'}"/>
                    <filter name="serial_group_status" string="Match Status" context="{'group_by': 'match_status'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_legacy_serial_ref_analysis" model="ir.actions.act_window">
        <field name="name">Legacy Serial Analysis</field>
        <field name="res_model">legacy.invoice.serial.ref</field>
        <field name="view_mode">graph,pivot,list</field>
        <field name="search_view_id" ref="view_legacy_serial_ref_search"/>
        <field name="context">{'search_default_serial_group_month': 1, 'tradeline_groupby_expanded': 1, 'tradeline_time_ranges_native': 1, 'tradeline_time_ranges_ui_v2': 1}</field>
    </record>

    <menuitem id="menu_legacy_invoice_analysis"
              name="Legacy Invoice Analysis"
              parent="menu_legacy_reporting_root"
              action="action_legacy_invoice_analysis"
              sequence="20"
              groups="account.group_account_readonly"/>

    <menuitem id="menu_legacy_payment_analysis"
              name="Legacy Payment Analysis"
              parent="menu_legacy_reporting_root"
              action="action_legacy_payment_link_analysis"
              sequence="30"
              groups="account.group_account_readonly"/>

    <menuitem id="menu_legacy_serial_analysis"
              name="Legacy Serial Analysis"
              parent="menu_legacy_reporting_root"
              action="action_legacy_serial_ref_analysis"
              sequence="40"
              groups="account.group_account_readonly"/>
</odoo>
