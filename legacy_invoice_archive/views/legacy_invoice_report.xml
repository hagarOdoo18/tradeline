<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_legacy_invoice" model="ir.actions.report">
        <field name="name">Legacy Invoice</field>
        <field name="model">legacy.invoice</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">legacy_invoice_archive.report_legacy_invoice_document</field>
        <field name="report_file">legacy_invoice_archive.report_legacy_invoice_document</field>
        <field name="binding_model_id" ref="model_legacy_invoice"/>
        <field name="binding_type">report</field>
        <field name="print_report_name">'Legacy Invoice - %s' % ((object.number or object.source_name or object.id))</field>
    </record>

    <record id="action_report_legacy_invoice_html" model="ir.actions.report">
        <field name="name">Legacy Invoice (HTML)</field>
        <field name="model">legacy.invoice</field>
        <field name="report_type">qweb-html</field>
        <field name="report_name">legacy_invoice_archive.report_legacy_invoice_document</field>
        <field name="report_file">legacy_invoice_archive.report_legacy_invoice_document</field>
        <field name="print_report_name">'Legacy Invoice - %s' % ((object.number or object.source_name or object.id))</field>
    </record>

    <template id="external_layout_standard_custom_legacy">
        <t t-call="web.external_layout">
            <t t-raw="0"/>
        </t>
    </template>

    <template id="new_report_invoice_document">
        <t t-call="legacy_invoice_archive.external_layout_standard_custom_legacy">
            <t t-set="o" t-value="o.with_context(lang='en_US')"/>
            <t t-set="partner" t-value="o.partner_id"/>
            <t t-set="print_summary" t-value="o.get_print_lines_summary()"/>
            <t t-set="lot_values" t-value="o.get_grouped_lot_values()"/>
            <t t-set="display_tax" t-value="', '.join(o.tax_line_ids.mapped('name')) or '-'"/>

            <div class="page">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div>
                        <h2 class="mb-0">Legacy Invoice</h2>
                        <div class="text-muted">
                            <span t-esc="o.number or o.source_name or '-'"/>
                        </div>
                    </div>
                    <div class="text-end">
                        <div><strong>State:</strong> <span t-esc="dict(o._fields['state'].selection).get(o.state, o.state or '-')"/></div>
                        <div><strong>Type:</strong> <span t-esc="dict(o._fields['invoice_type'].selection).get(o.invoice_type, o.invoice_type or '-')"/></div>
                        <div><strong>Source:</strong> <span t-esc="o.source_db"/> / <span t-esc="o.source_model"/> / <span t-esc="o.source_id"/></div>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-6">
                        <h5 class="mb-2">Bill To</h5>
                        <div><strong>Name:</strong> <span t-esc="partner.name or o.source_partner_name or '-'"/></div>
                        <div><strong>Phone:</strong> <span t-esc="partner.mobile or partner.phone or '-'"/></div>
                        <div><strong>Tax ID:</strong> <span t-esc="partner.vat or '-'"/></div>
                        <div t-if="partner.contact_address">
                            <strong>Address:</strong>
                            <span t-esc="partner.contact_address"/>
                        </div>
                    </div>
                    <div class="col-6">
                        <h5 class="mb-2">Invoice Info</h5>
                        <table class="table table-sm table-borderless mb-0">
                            <tbody>
                                <tr>
                                    <td><strong>Invoice Date</strong></td>
                                    <td class="text-end"><span t-field="o.invoice_date"/></td>
                                </tr>
                                <tr>
                                    <td><strong>Due Date</strong></td>
                                    <td class="text-end"><span t-field="o.due_date"/></td>
                                </tr>
                                <tr>
                                    <td><strong>Source Name</strong></td>
                                    <td class="text-end"><span t-esc="o.source_name or '-'"/></td>
                                </tr>
                                <tr>
                                    <td><strong>Discount Reason</strong></td>
                                    <td class="text-end"><span t-esc="o.discount_reason_normalized or '-'"/></td>
                                </tr>
                                <tr>
                                    <td><strong>Imported At</strong></td>
                                    <td class="text-end"><span t-field="o.imported_at"/></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

                <table class="table table-sm o_main_table" name="invoice_line_table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Item Code</th>
                            <th>Description</th>
                            <th class="text-end">Qty</th>
                            <th class="text-end">Unit Price</th>
                            <th class="text-end">Disc. %</th>
                            <th>Taxes</th>
                            <th class="text-end">Subtotal</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr t-foreach="print_summary['printed_lines']" t-as="line">
                            <td><span t-esc="line.sequence or ''"/></td>
                            <td><span t-esc="line.item_code or ''"/></td>
                            <td><span t-esc="line.name or ''"/></td>
                            <td class="text-end"><span t-esc="'%.2f' % (line.quantity or 0.0)"/></td>
                            <td class="text-end">
                                <span t-out="line.price_unit or 0.0"
                                      t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                            </td>
                            <td class="text-end"><span t-esc="'%.2f' % (line.discount or 0.0)"/></td>
                            <td><span t-esc="display_tax"/></td>
                            <td class="text-end">
                                <span t-out="line.price_subtotal or 0.0"
                                      t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                            </td>
                        </tr>
                    </tbody>
                </table>

                <div class="row justify-content-end">
                    <div class="col-5">
                        <table class="table table-sm" style="page-break-inside: avoid;">
                            <tbody>
                                <tr>
                                    <td><strong>Untaxed Amount</strong></td>
                                    <td class="text-end">
                                        <span t-out="print_summary['printed_untaxed']"
                                              t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                    </td>
                                </tr>
                                <tr>
                                    <td><strong>Tax</strong></td>
                                    <td class="text-end">
                                        <span t-out="print_summary['printed_tax']"
                                              t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                    </td>
                                </tr>
                                <tr class="border-top">
                                    <td><strong>Total</strong></td>
                                    <td class="text-end">
                                        <strong>
                                            <span t-out="print_summary['printed_total']"
                                                  t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                        </strong>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="mt-2" t-if="print_summary.get('printed_amount_words_en')">
                    <strong>Amount in Words:</strong>
                    <span t-esc="print_summary['printed_amount_words_en']"/>
                </div>

                <div class="mt-4" t-if="lot_values" style="page-break-inside: avoid;">
                    <h5 class="mb-2">Serial References</h5>
                    <table class="table table-sm o_main_table" name="invoice_serial_table">
                        <thead>
                            <tr>
                                <th>Product</th>
                                <th class="text-end">Qty</th>
                                <th>Serial Number(s)</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr t-foreach="lot_values" t-as="snln_line">
                                <td><span t-esc="snln_line['product_name']"/></td>
                                <td class="text-end">
                                    <span t-esc="'%.2f' % (snln_line['quantity'] or 0.0)"/>
                                    <t t-if="snln_line.get('uom_name')">
                                        <span t-esc="' %s' % snln_line['uom_name']"/>
                                    </t>
                                </td>
                                <td><span t-esc="snln_line['serials'] or '-'"/></td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <div class="mt-4" t-if="o.payment_link_ids" style="page-break-inside: avoid;">
                    <h5 class="mb-2">Payments</h5>
                    <table class="table table-sm o_main_table">
                        <thead>
                            <tr>
                                <th>Payment Date</th>
                                <th>Reference</th>
                                <th>Journal</th>
                                <th>Method</th>
                                <th class="text-end">Amount</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr t-foreach="o.payment_link_ids" t-as="pay">
                                <td><span t-field="pay.payment_date"/></td>
                                <td><span t-esc="pay.reference or pay.name or ''"/></td>
                                <td><span t-esc="pay.journal_id.display_name or pay.journal_name or pay.journal_code or ''"/></td>
                                <td><span t-esc="pay.payment_method_name or pay.payment_method_code or ''"/></td>
                                <td class="text-end">
                                    <span t-out="pay.amount or 0.0"
                                          t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <div class="mt-3" t-if="o.comment or o.print_notes or o.product_notes or o.notes_pos">
                    <h5 class="mb-2">Legacy Notes</h5>
                    <p class="mb-1" t-if="o.comment"><strong>Comment:</strong> <span t-esc="o.comment"/></p>
                    <p class="mb-1" t-if="o.print_notes"><strong>Print Notes:</strong> <span t-esc="o.print_notes"/></p>
                    <p class="mb-1" t-if="o.product_notes"><strong>Product Notes:</strong> <span t-esc="o.product_notes"/></p>
                    <p class="mb-1" t-if="o.notes_pos"><strong>POS Notes:</strong> <span t-esc="o.notes_pos"/></p>
                </div>
            </div>
        </t>
    </template>

    <template id="report_legacy_invoice_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="legacy_invoice_archive.new_report_invoice_document" t-lang="'en_US'"/>
            </t>
        </t>
    </template>
</odoo>
