<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="commotion_sales_action" model="ir.actions.act_window">
        <field name="name">Sales Commotion</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">sales.commotion</field>
        <field name="context">{'search_default_current':1, 'search_default_customer':1, 'group_by':[], 'group_by_no_leaf':1, 'search_default_year': 1,'group_by_branch_id':1}</field>
        <field name="view_mode">pivot</field>
    </record>

    <record id="commotion_sales_view_form" model="ir.ui.view">
        <field name="name">commotion_sales_view_form</field>
        <field name="model">sales.commotion</field>
        <field name="arch" type="xml">
            <pivot string="Commotion Analysis" disable_linking="True">
                <field name="categ_id" type="row"/>
                <field name="date" type="col"/>
                <field name="price_total" type="measure"/>
            </pivot>
        </field>
    </record>

    <menuitem id="sales_commotion_categ"
              name="Sales Commotion"
              parent="account.menu_finance_reports"
              action="commotion_sales_action"
              sequence="2"/>

    <record id="sales_commotion_report_search_inherit_filter_month" model="ir.ui.view">
        <field name="name">sales.commotion.report.search.filter.month</field>
        <field name="model">sales.commotion</field>
        <field name="priority" eval="8"/>
        <field name="arch" type="xml">
            <search string="Sales Commotion">
                <field name="date"/>
                <filter string="Tradeline Month"
                        name="tradeline_month"
                        domain="['&amp;', ('date', '&gt;=', (context_today() - relativedelta(months=1)).strftime('%Y-%m-21')), ('date', '&lt;', context_today().strftime('%Y-%m-21'))]"/>
            </search>
        </field>
    </record>

</odoo>
