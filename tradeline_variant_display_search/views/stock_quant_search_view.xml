<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_stock_quant_filter_product_first_apple" model="ir.ui.view">
            <field name="name">stock.quant.filter.product.first.apple</field>
            <field name="model">stock.quant</field>
            <field name="inherit_id" ref="stock.quant_search_view"/>
            <field name="arch" type="xml">
                <xpath expr="//search/field[@name='product_id'][1]" position="replace">
                    <field name="product_search_text" string="Product"/>
                    <field name="product_id" string="Product Variant"/>
                </xpath>
                <xpath expr="//search/field[not(@name='product_search_text')][1]" position="before">
                    <xpath expr="//search/field[@name='product_search_text'][1]" position="move"/>
                </xpath>
            </field>
        </record>

        <record id="stock_quant_custom_list.action_stock_quant_custom" model="ir.actions.act_window">
            <field name="search_view_id" ref="view_stock_quant_filter_product_first_apple"/>
        </record>
    </data>
</odoo>
