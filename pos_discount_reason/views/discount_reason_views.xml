<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_discount_reason_form_category_discount" model="ir.ui.view">
        <field name="name">discount.reason.form.category.discount</field>
        <field name="model">discount.reason</field>
        <field name="inherit_id" ref="base_tradeline.discount_reason_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='discount_percentage']" position="after">
                <field name="use_category_discount" readonly="state != 'new'"/>
            </xpath>

            <xpath expr="//sheet/group" position="after">
                <group string="Category Discount Rules" invisible="use_category_discount == False">
                    <field name="category_discount_line_ids" nolabel="1" readonly="state != 'new'">
                        <list editable="bottom">
                            <field name="sequence" optional="hide"/>
                            <field name="category_ids" widget="many2many_tags"/>
                            <field name="family_ids" widget="many2many_tags"/>
                            <field name="discount_percentage"/>
                        </list>
                    </field>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
