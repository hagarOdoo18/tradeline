<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-inherit="point_of_sale.ReceiptScreen" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('pos-receipt-container')]//OrderReceipt" position="attributes">
            <attribute name="basic_receipt">pos.get_order() and pos.get_order().as_gift</attribute>
        </xpath>
    </t>
</templates>

