                        <strong>فاتورة</strong>
                        <br/>
                        <strong> الخط الساخن : 19857</strong>
                        <!--                    <br/>-->


        </div>
         <div id="qrcode_eg" t-if="o.e_invoice_qr_code" class="text-right" style="font-size:10px; text-align:right;">
