<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="account.document_tax_totals_company_currency_template">
            <t t-set="currency" t-value="o.company_currency_id"/>
            <t t-set="same_tax_base" t-value="tax_totals['same_tax_base']"/>
            <div class="mb-2 mt-3 border p-2 avoid-page-break-inside totals_taxes_company_currency">
                <table class="o_total_table table table-borderless mb-0">
                    <p class="tax_computation_company_currency">
                        Taxes <span t-field="o.company_currency_id"/>
                    </p>
                    <t t-foreach="tax_totals['subtotals']" t-as="subtotal">
                        <tr class="o_subtotal">
                            <td>
                                <span t-out="subtotal['name']">الاجمالي غير شامل الضربيه</span>
                            </td>
                            <td class="text-end">
                                <span t-out="subtotal['base_amount']"
                                      t-options='{"widget": "monetary", "display_currency": currency}'
                                >27.00</span>
                            </td>
                        </tr>
                        <t t-foreach="subtotal['tax_groups']" t-as="tax_group">
                            <tr class="o_taxes">
                                <t t-if="same_tax_base or tax_group['display_base_amount'] is None">
                                    <td>
                                        <span class="text-nowrap" t-out="tax_group['group_name']"/>
                                    </td>
                                    <td class="text-end o_price_total">
                                        <span class="text-nowrap"
                                              t-out="tax_group['tax_amount']"
                                              t-options='{"widget": "monetary", "display_currency": currency}'
                                        >31.05</span>
                                    </td>
                                </t>
                                <t t-else="">
                                    <td>
                                        <span t-out="tax_group['group_name']">Tax 15%</span>
                                        <span> on </span>
                                        <span class="text-nowrap"
                                              t-out="tax_group['display_base_amount']"
                                              t-options='{"widget": "monetary", "display_currency": currency}'
                                        >27.00</span>
                                    </td>
                                    <td class="text-end o_price_total">
                                        <span class="text-nowrap"
                                              t-out="tax_group['tax_amount']"
                                              t-options='{"widget": "monetary", "display_currency": currency}'
                                        >4.05</span>
                                    </td>
                                </t>
                            </tr>
                        </t>
                    </t>
                    <!--Total amount with all taxes-->
                    <tr class="o_total">
                        <td><strong>Total</strong></td>
                        <td class="text-end">
                            <strong t-out="tax_totals['total_amount']"
                                    t-options='{"widget": "monetary", "display_currency": currency}'
                            >31.05</strong>
                        </td>
                    </tr>
                </table>
            </div>
        </template>

    <template id="account.document_tax_totals_template">
            <!--
                Generic template to display tax totals in pdf reports.
                Used by invoices, SO and PO.

                ARGUMENTS:
                - currency: The res.currency to use.
                - tax_totals: dict in the form generated by account.move's _get_tax_totals.
            -->
            <t t-set="same_tax_base" t-value="tax_totals['same_tax_base']"/>
            <t t-foreach="tax_totals['subtotals']" t-as="subtotal">
                <tr class="o_subtotal">
                    <td>
                        <span t-out="subtotal['name']">الاجمالي غير شامل الضربيه</span>
                    </td>
                    <td class="text-end">
                        <span t-att-class="oe_subtotal_footer_separator"
                              t-out="subtotal['base_amount_currency']"
                              t-options='{"widget": "monetary", "display_currency": currency}'
                        >27.00</span>
                    </td>
                </tr>

                <t t-foreach="subtotal['tax_groups']" t-as="tax_group">
                    <tr class="o_taxes">
                        <t t-if="same_tax_base or tax_group['display_base_amount_currency'] is None">
                            <td>
                                <span class="text-nowrap" t-out="tax_group['group_name']">Tax 15%</span>
                            </td>
                            <td class="text-end o_price_total">
                                <span class="text-nowrap"
                                      t-out="tax_group['tax_amount_currency']"
                                      t-options='{"widget": "monetary", "display_currency": currency}'
                                >1.05</span>
                            </td>
                        </t>
                        <t t-else="">
                            <td>
                                <span t-out="tax_group['group_name']">Tax 15%</span>
                                <span> on </span>
                                <span class="text-nowrap"
                                      t-out="tax_group['display_base_amount_currency']"
                                      t-options='{"widget": "monetary", "display_currency": currency}'
                                >27.00</span>
                            </td>
                            <td class="text-end o_price_total">
                                <span class="text-nowrap"
                                      t-out="tax_group['tax_amount_currency']"
                                      t-options='{"widget": "monetary", "display_currency": currency}'
                                >4.05</span>
                            </td>
                        </t>
                    </tr>
                </t>
            </t>

            <tr t-if="'cash_rounding_base_amount_currency' in tax_totals">
                <td>Rounding</td>
                <td class="text-end">
                    <span t-out="tax_totals['cash_rounding_base_amount_currency']"
                          t-options='{"widget": "monetary", "display_currency": currency}'
                    >0</span>
                </td>
            </tr>

            <!--Total amount with all taxes-->
            <tr class="o_total">
                <td><strong>الاجمالي</strong></td>
                <td class="text-end">
                    <strong t-out="tax_totals['total_amount_currency']"
                            t-options='{"widget": "monetary", "display_currency": currency}'
                    >31.05</strong>
                </td>
            </tr>
        </template>

    <template id="custom_product_serial" inherit_id="stock_account.stock_account_report_invoice_document">
                   <xpath expr="//table[@name='invoice_snln_table']" position="replace">

                        <t t-set="lot_values" t-value="o.get_grouped_lot_values()"/>

                            <table class="table table-sm mt-2" style="width: 50%;" name="invoice_snln_table">
                                <thead>
                                    <tr>
                                        <th>المنتج</th>
                                        <th class="text-end">الكميه</th>
                                        <th class="text-end">رقم السريال</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr t-foreach="lot_values" t-as="snln_line">
                                        <td><t t-esc="snln_line['product_name']"/></td>
                                        <td class="text-end">
                                            <t t-esc="snln_line['quantity']"/>
                                            <t t-esc="snln_line['uom_name']" groups="uom.group_uom"/>
                                        </td>
                                        <td class="text-end">
                                            <t t-esc="snln_line['serials']"/>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                   </xpath>


    </template>
    <template id="custom_invoice_header" inherit_id="account.report_invoice_document">
         <xpath expr="//div[@class='row']" position="replace">
         </xpath>
        <xpath expr="//div[@name='comment']" position="inside">

         </xpath>
         <xpath expr="//div[@id='right-elements']" position="replace">
             <div id="right-elements" t-attf-class="#{'col-5' if report_type != 'html' else 'col-12 col-md-5'} ms-5 d-inline-block float-end">
                                <div id="total" class="clearfix row mt-n3">
                                    <div class="ms-auto">
                                        <table class="o_total_table table table-borderless avoid-page-break-inside">

                                            <!-- Tax totals summary (invoice currency) -->
                                            <t t-if="o.tax_totals" t-call="account.document_tax_totals">
                                                <t t-set="tax_totals" t-value="o.tax_totals"/>
                                                <t t-set="currency" t-value="o.currency_id"/>
                                            </t>

                                            <!--Payments-->
                                            <t >
                                                <t >
                                                    <t t-set="payments_vals" t-value="o.sudo().invoice_payments_widget and o.sudo().invoice_payments_widget['content'] or []"/>
                                                    <t t-foreach="payments_vals" t-as="payment_vals">
                                                        <tr t-if="payment_vals['is_exchange'] == 0">
                                                            <td>
                                                                <i class="oe_form_field text-end oe_payment_label">

                                                                    دفعت في
                                                                    <t t-out="payment_vals['date']" t-options="{&quot;widget&quot;: &quot;date&quot;}">2021-09-19</t>
                                                                    <t t-if="payment_vals.get('pos_payment_name')">
                                                                            <t t-esc="payment_vals['pos_payment_name']"/>
                                                                     </t>
                                                                    <t t-else="">
                                                                            <t t-esc="payment_vals['journal_name']"/>
                                                                     </t>
                                                                </i>
                                                            </td>
                                                            <td class="text-end">
                                                                <span t-out="payment_vals['amount']" t-options="{&quot;widget&quot;: &quot;monetary&quot;, &quot;display_currency&quot;: o.currency_id}">20.00</span>
                                                            </td>
                                                        </tr>
                                                    </t>
                                                    <t t-if="len(payments_vals) &gt; 0">
                                                        <tr class="fw-bold">
                                                            <td>المبلغ المستحق</td>
                                                            <td class="text-end">
                                                                <span t-field="o.amount_residual">11.05</span>
                                                            </td>
                                                        </tr>
                                                    </t>
                                                </t>
                                            </t>
                                        </table>
                                    </div>
                                </div>
                                <div class="mb-2">
                                    <p class="text-end lh-sm" >
                                       <br/>
                                        <small class="text-muted lh-sm"><span t-field="o.amount_total_words">Thirty one dollar and Five cents</span></small>
                                    </p>
                                </div>

                                <!-- Tax totals summary (company currency) -->
                                <t t-if="o.tax_totals.get('display_in_company_currency')">
                                    <t t-set="tax_totals" t-value="o.tax_totals"/>
                                    <t t-call="account.document_tax_totals_company_currency_template"/>
                                </t>
                                <t t-else="">
                                    <div class="oe_structure"/>
                                </t>
                            </div>
         </xpath>


        <xpath expr="//div[@id='informations']" position="replace">

            <div id="informations_header"  style="font-size:9px;" class="row mt32 ">

                <div class="col-3" >
                    <strong>اسم العميل :</strong>
                    <br/>
                    <t t-esc="o.partner_id.name"  class="m-0"/>
                </div>

                <div class="col-3">
                    <strong>رقم الهاتف :</strong>
                    <br/>
                    <t t-esc="o.partner_id.mobile"  class="m-0"/>
                </div>

                <div class="col-2">
                    <strong>امر البيع :</strong>
                    <br/>
                    <t t-esc="o.invoice_origin"  class="m-0"/>
                </div>
                <div class="col-2" >
                    <strong>تاريخ الفاتورة :</strong>
                    <br/>
                    <t t-esc="o.invoice_date"  class="m-0"/>
                </div>
                <div class="col-2" >
                    <strong>العنوان :</strong>
                    <br/>
                    <t t-esc="o.partner_id.street"  class="m-0"/>
                </div>

            </div>
             <div id="informations" style="font-size:9px;"  class="row mt32">


                <div class="col-2" style="margin-top:5px;">
                    <strong>الشركه :</strong>
                    <br/>
                    <t t-esc="o.partner_id.parent_id.name"/>
                </div>
                <div class="col-2" style="margin-top:5px;">
                    <strong> الفرع:</strong>
                    <br/>
                    <t t-esc="o.branch_id.name"/>
                </div>
                <div class="col-2" style="margin-top:5px;">
                    <strong>كود البائع :</strong>
                    <br/>
                    <t t-esc="o.sales_rep_id.code"/>
                </div>

                <div class="col-3" style="margin-top:5px;">
                    <strong>الرقم المرجعي :</strong>
                    <br/>
                    <t t-esc="o.reference_number"/>
                </div>
                   <div class="col-3" t-if="o.partner_id.vat">
                        <strong>رقم التسجيل الضريبى :</strong>
                       <br/>
                        <p t-if="o.partner_id.vat" class="m-0" t-field="o.partner_id.vat"/>
                    </div>
            </div>
              <div id="informations" class="row mt32" style="font-size:9px;"  t-if="o.bank_id">

                <div class="col-2" style="margin-top:5px;">
                    <strong>Bank Name :</strong>
                    <br/>
                    <t t-esc="o.bank_id.name"/>
                </div>
                <div class="col-2" style="margin-top:5px;">
                    <strong>Bank Account Name :</strong>
                    <br/>
                    <t t-esc="o.bank_id.account_name"/>
                </div>
                 <div class="col-2" style="margin-top:5px;">
                    <strong>Bank Account Number:</strong>
                     <br/>
                    <t t-esc="o.bank_id.account_number"/>
                </div>
                <div class="col-2" style="margin-top:5px;">
                    <strong>Account currency:</strong>
                    <br/>
                    <t t-esc="o.bank_id.currency_id.name"/>
                </div>
                <div class="col-2" style="margin-top:5px;">
                    <strong>Swift Code :</strong>
                    <br/>
                    <t t-esc="o.bank_id.swift_code"/>
                </div>
                   <div class="col-2" style="margin-top:5px;"  name="po_field">
                        <strong>IBAN:</strong>
                       <br/>
                        <p class="m-0" t-field="o.bank_id.IBAN"/>
                    </div>
            </div>

        </xpath>
           <xpath expr="//table[@name='invoice_line_table']" position="replace">
               <br/>
                 <table class="table table-sm o_main_table" name="invoice_line_table">
                        <thead>
                            <tr>
                                <t t-set="colspan" t-value="6"/>
                                <th class="text-left">
                                    <span>كود المنتج</span>
                                </th>
                                <th class="text-left">
                                    <span>الصنف</span>
                                </th>

                                <th class="text-right">
                                    <span>الكمية</span>
                                </th>
                                <t t-if="o.get_gift_invoice()==false">

                                        <t>
                                            <th t-attf-class="text-right {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}">
                                                <span>سعر الوحدة</span>
                                            </th>
                                        </t>

                                        <th  t-attf-class="text-left {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}">
                                            <span>ضربية القيمة المضافة</span>
                                        </th>
                                        <!-- <th  t-attf-class="text-left {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}">-->
                                        <!--   <span>خصم(%)</span>-->
                                        <!--</th>-->
                                        <th class="text-right">
                                            <span groups="account.group_show_line_subtotals_tax_excluded">الاجمالى</span>
                                            <span groups="account.group_show_line_subtotals_tax_included">Total Price</span>
                                        </th>

                                </t>
                            </tr>
                        </thead>
                        <tbody class="invoice_tbody">
                            <t t-set="current_subtotal" t-value="0"/>
                                <t t-set="current_total" t-value="0"/>

                            <t t-set="lines" t-value="o.invoice_line_ids.sorted(key=lambda l: (-l.sequence, l.date, l.move_name, -l.id), reverse=True)"/>


                            <t t-foreach="lines" t-as="line">



                                <t t-set="current_subtotal" t-value="current_subtotal + line.price_subtotal" groups="account.group_show_line_subtotals_tax_excluded"/>
                                <t t-set="current_subtotal" t-value="current_subtotal + line.price_total" groups="account.group_show_line_subtotals_tax_included"/>

                                <tr t-att-class="'fw-bold o_line_section' if line.display_type == 'line_section' else 'fst-italic o_line_note' if line.display_type == 'line_note' else ''">
                                <t t-if="line.display_type == 'product'" name="account_invoice_line_accountable">

                                        <td name="account_invoice_line_code">
                                            <span t-field="line.product_id.barcode"/>
                                        </td>
                                        <td name="account_invoice_line_name">
                                            <span t-field="line.product_id.display_name"/>
                                        </td>

                                        <td class="text-right">
                                            <span t-esc="int(line.quantity)"/>
                                            <!--<span t-field="line.quantity"/>-->
<!--                                            <span t-field="line.uom_id" groups="uom.group_uom"/>-->
                                        </td>

                                        <t t-if="o.get_gift_invoice()==false">

                                                    <td t-attf-class="text-right {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}">
                                                        <span t-field="line.price_unit"/>
                                                    </td>
                                                  <t t-set="taxes" t-value="', '.join([(tax.invoice_label or tax.name) for tax in line.tax_ids])"/>
                                                <td name="td_taxes" t-attf-class="text-end {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }} {{ 'text-nowrap' if len(taxes) &lt; 10 else '' }}">
                                                <span t-out="taxes" id="line_tax_ids">Tax 15%</span>
                                            </td>
                                                <!--<td  t-attf-class="text-left {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}">-->
                                                <!--    <span t-esc="line.discount"/>-->
                                                <!--</td>-->
                                                <td class="text-right o_price_total">
                                                    <span t-field="line.price_subtotal" groups="account.group_show_line_subtotals_tax_excluded"/>
                                                    <span t-field="line.price_total" groups="account.group_show_line_subtotals_tax_included"/>
                                                </td>

                                        </t>
                                    </t>
                                    <t t-if="line.display_type == 'line_section'">
                                        <td colspan="99">
                                            <span t-field="line.name"/>
                                        </td>
                                        <t t-set="current_section" t-value="line"/>
                                        <t t-set="current_subtotal" t-value="0"/>
                                    </t>
                                    <t t-if="line.display_type == 'line_note'">
                                        <td colspan="99">
                                            <span t-field="line.name"/>
                                        </td>
                                    </t>
                                </tr>


                            </t>
                        </tbody>
                    </table>

        </xpath>

      <xpath expr="//div[@id='payment_term']" position="replace">
          <br/>
          <br/>
          <br/>

            <div style="width:100%; display:flex; justify-content:flex-end;">
           <div class="text-right" t-if="o.comment" name="comment" style="font-size:8px; text-align:right;">
                        <span t-field="o.comment" dir="rtl"/>
                    </div>
            </div>

      </xpath>
        <xpath expr="//t[@t-set='layout_document_title']" position="replace">

    <t t-set="layout_document_title">

        <!-- العنوان الرئيسي -->
         <div class="text-center" style="padding-left: 100px;font-size:10px; " name="hotline">
                        <strong>فاتورة</strong>
                        <br/>
                        <strong> الخط الساخن : 19857</strong>
                        <!--                    <br/>-->


        </div>
        <div style="width:100%; display:flex; justify-content:flex-end;">
            <div class="text-right" style="font-size:10px; text-align:right;">
                <strong>سجل تجارى : ٢٤٨.١ </strong><br/>
                <strong>بطاقة ضريبة :٠ -٦٤-٥٩٨-٢٥٤</strong><br/>
                <strong>ملف ضريبى :٠٠-٠٠-١٩١-٠٠١٦٩-٥-٥٥٥</strong>
            </div>
        </div>
        <div >
            <span t-if="not proforma"/>
            <span t-else="">PROFORMA</span>
            <span t-if="o.move_type == 'out_invoice' and o.state == 'posted'"></span>
            <span t-elif="o.move_type == 'out_invoice' and o.state == 'draft'">Draft Invoice</span>
            <span t-elif="o.move_type == 'out_invoice' and o.state == 'cancel'">Cancelled Invoice</span>
            <span t-elif="o.move_type == 'out_refund' and o.state == 'posted'">مرتجع</span>
            <span t-elif="o.move_type == 'out_refund' and o.state == 'draft'">Draft Credit Note</span>
            <span t-elif="o.move_type == 'out_refund' and o.state == 'cancel'">Cancelled Credit Note</span>
            <span t-elif="o.move_type == 'in_refund'">Vendor Credit Note</span>
            <span t-elif="o.move_type == 'in_invoice'">Vendor Bill</span>
            <span t-if="o.name and o.name != '/'" t-field="o.name"/>
        </div>

    </t>

      </xpath>


    </template>
</odoo>
