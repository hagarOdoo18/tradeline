<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <!-- زر يظهر في ProductScreen -->
    <t t-name="SerialSearchButton" owl="1">
        <button class="control-button">
            📦 Serial Control
        </button>
    </t>

    <!-- شاشة التحكم في السيريال -->
    <t t-name="SerialScreen" owl="1">
        <div class="serial-screen screen">
            <div class="screen-content">
                <h2>Select a Serial</h2>
                <ul>
                    <t t-foreach="state.serials" t-as="serial">
                        <li>
                            <button t-on-click="() => selectSerial(serial)">
                                <t t-esc="serial"/>
                            </button>
                        </li>
                    </t>
                </ul>
                <button class="button back" t-on-click="() => this.showScreen('ProductScreen')">
                    ⬅ Back
                </button>
            </div>
        </div>
    </t>

</templates>
