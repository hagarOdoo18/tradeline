<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <report
                id="action_report_transfer_request"
                model="transfer.request"
                string="Transfer Request"
                name="tradeline_warehouse_transfer.report_transfer_request"
                file="tradeline_warehouse_transfer.report_transfer_request"
                report_type="qweb-pdf"/>
         <template id="report_transfer_request_template">
        <t t-foreach="docs" t-as="o">
            <t t-call="tradeline_warehouse_transfer.report_transfer_request" />
        </t>
    </template>

        <template id="report_transfer_request">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="doc">
                    <t t-call="web.external_layout">
                        <div class="page">
                             <h2>Transfer Request</h2>
                            <p>Date: <t t-esc="doc.date"/></p>
                            <p>Number: <t t-esc="doc.name"/></p>
                            <p>Sales Rep: <t t-esc="doc.sales_rep.name"/></p>
                            <p>Source warehouse: <t t-esc="doc.from_warehouse.name"/></p>
                            <p>Receiving warehouse: <t t-esc="doc.to_warehouse.name"/></p>
                            <table  class="table table-sm">
                            <thead>
                                    <tr>
                                        <th><strong>Product</strong></th>
                                        <th><strong>Quantity</strong></th>

                                        <th width="15%" class="text-center" >
                                           <strong>Lot/Serial Number</strong>
                                        </th>

                                    </tr>
                            </thead>
                            <tbody>
                                    <t t-foreach="doc.lines" t-as="line">

                                            <tr>
                                                <td>
                                                    <span t-field="line.product_id.display_name"/><br/>

                                                </td>

                                                <td>

                                                    <span t-field="line.qty"/>

                                                </td>

                                                <td width="15%" class=" text-center h6" t-if="line.serial_id">
                                                    <!--<img t-if="has_serial_number and (ml.lot_id or ml.lot_name)" t-att-src="'/report/barcode/?type=%s&amp;value=%s&amp;width=%s&amp;height=%s&amp;humanreadable=1' % ('Code128', ml.lot_id.name, 600, 100)" style="width:100%;height:35px;" alt="Barcode"/>-->
                                                    <span  t-field="line.serial_id.name"/>
                                                </td>

                                            </tr>
                                    </t>
                                  </tbody>
                            </table>


                        </div>
                    </t>
                </t>
            </t>
        </template>

    </data>
</odoo>