<?xml version="1.0" encoding="utf-8"?>
<odoo>
        <record id="transfer_request_form_view" model="ir.ui.view">
            <field name="name">transfer.request.form</field>
            <field name="model">transfer.request</field>
            <field name="arch" type="xml">
                <form string="Transfer Request">
                    <header>
                        <field name="state" widget="statusbar" statusbar_visible="draft,approved,in_progress,received,completed,cancel"/>
                        <button name="approve_request" string="Approve" type="object"  invisible="state != 'draft'" groups="tradeline_warehouse_transfer.group_transfer_super_manger"/>
                        <button name="create_request" string="Create" type="object"  invisible="state != 'approved'"  groups="tradeline_warehouse_transfer.group_transfer_manger"/>
                        <button name="cancel" string="Cancel" type="object"  invisible="state != 'create'" groups="tradeline_warehouse_transfer.group_transfer_super_manger"/>
                        <button name="action_complete" string="Complete" type="object"  groups="tradeline_warehouse_transfer.group_transfer_super_manger"/>
                        <button name="set_draft" string="Set To Draft" type="object" invisible="state not in ['approved','cancel']"  groups="tradeline_warehouse_transfer.group_transfer_super_manger"/>
                        <button name="%(tradeline_warehouse_transfer.cancel_reason_action)d" invisible="state != 'draft'"  type="action" string="Cancel" groups="tradeline_warehouse_transfer.group_transfer_super_manger"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="action_view_transfer" type="object" class="oe_stat_button" icon="fa-truck" invisible="transfers_count == 0" >
                            <field name="transfers_count" widget="statinfo" string="Transfers"/>
                        </button>
                        </div>
                        <div class="oe_title oe_inline">
                            <label for="name" />
                            <h1>
                                <field name="name"/>
                            </h1>
                        </div>
                        <group string="Basic Info">
                            <group>
                                <field name="state" invisible="1"/>
                                <field name="date" readonly ="state != 'draft'"/>
                                <field name="sales_rep" readonly ="state != 'draft'" options="{'no_create': True, 'no_create_edit':True, 'no_open': True}" />
                            </group>
                            <group>
                                <field name="from_warehouse" readonly ="state != 'draft'"/>
                                <field name="to_warehouse" readonly="1"/>
                            </group>
                        </group>
                        <notebook>
                            <page name="lines" string="Lines">

                                <field name="lines" readonly ="state != 'draft'">
                                    <list editable="bottom">
                                        <field name="product_id" />
                                        <field name="item_code"/>
                                        <field name="tracking" column_invisible="1"/>
                                        <field name="serial_domain" column_invisible="1"/>
                                        <field name="serial_ids" widget="many2many_tags" domain="serial_domain" invisible="tracking != 'serial'"  required ="tracking == 'serial'"   options="{'no_create': True, 'no_create_edit':True, 'no_open': True}" />
                                        <field name="qty"/>
                                    </list>
                                </field>

                            </page>

                        </notebook>
                    </sheet>
                                     <chatter/>

                </form>
            </field>
        </record>



        <record id="transfer_request_view_list" model="ir.ui.view">
            <field name="name">transfer_request_view_list</field>
            <field name="model">transfer.request</field>
            <field name="arch" type="xml">
                <list string="transfer_request_list">
                    <field name="name"/>
                    <field name="date"/>
                     <field name="sales_rep"/>
                    <field name="from_warehouse"/>
                    <field name="to_warehouse"/>
                    <field name="state"/>
                </list>
            </field>
        </record>

    <record id="transfer_request_act_window" model="ir.actions.act_window">
            <field name="name">Transfer Request</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">transfer.request</field>
            <field name="view_mode">list,form,pivot</field>
            <field name="domain">[('state','!=','completed')]</field>

            <field name="help">
                Create Transfer Request
            </field>

        </record>


        <record id="transfer_completed_act_window" model="ir.actions.act_window">
            <field name="name">Transfer completed</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">transfer.request</field>
            <field name="view_mode">list,form,pivot</field>
            <field name="domain">[('state','=','completed')]</field>

            <field name="help">
                Create Transfer Request
            </field>

        </record>

     <record id="transfer_request_view_search" model="ir.ui.view">
            <field name="name">transfer_request_view_search</field>
            <field name="model">transfer.request</field>
            <field name="arch" type="xml">
            <search >
                <field name="name"/>
                <field name="lot_id"/>
            </search>
            </field>
    </record>


        <record id="transfer_create_act_window" model="ir.actions.act_window">
            <field name="name">Transfer created</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">transfer.request</field>
            <field name="view_mode">list,form,pivot</field>
            <field name="domain">[('state','=','create')]</field>

            <field name="help">
                Create Transfer Request
            </field>

        </record>

       <record id="transfer_Received_act_window" model="ir.actions.act_window">
            <field name="name">Transfer received</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">transfer.request</field>
            <field name="view_mode">list,form,pivot</field>
            <field name="domain">[('state','=','received')]</field>

            <field name="help">
                Create Transfer Request
            </field>

        </record>

        <menuitem id="transfer_request_root" name="Transfer Request" sequence="2" groups="group_transfer_user"/>
    <menuitem id="transfer_options_request_root" parent="transfer_request_root"  name="Transfers" sequence="2" groups="group_transfer_user"/>
        <menuitem name="Transfer Request" id="transfer_request_menu" parent="transfer_options_request_root" action="transfer_request_act_window" groups="group_transfer_user" sequence="1"/>
        <menuitem name="Transfer Completed" id="transfer_completed_menu" parent="transfer_options_request_root" action="transfer_completed_act_window" groups="tradeline_warehouse_transfer.group_transfer_manger" sequence="1"/>

    <menuitem name="Transfer Created" id="transfer_create_menu" parent="transfer_options_request_root" action="transfer_create_act_window" groups="group_transfer_user" sequence="1"/>

    <menuitem name="Transfer Received" id="transfer_receive_menu" parent="transfer_options_request_root" action="transfer_Received_act_window" groups="group_transfer_user" sequence="1"/>



</odoo>