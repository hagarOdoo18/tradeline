<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_pricelist_barcode_print_wizard_form" model="ir.ui.view">
        <field name="name">pricelist.barcode.print.wizard.form</field>
        <field name="model">pricelist.barcode.print.wizard</field>
        <field name="arch" type="xml">
            <form string="Print Barcode Labels">

                <header>
                    <button name="action_print"
                            string="Print Labels"
                            type="object"
                            class="btn-primary"
                            icon="fa-print"/>
                    <button name="action_close"
                            string="Close"
                            type="object"
                            class="btn-secondary"
                            icon="fa-times"/>
                </header>

                <sheet>

                    <!-- Title -->
                    <div class="oe_title">
                        <h1>
                            <field name="pricelist_id" readonly="1"
                                   options="{'no_open': True}"/>
                        </h1>
                        <h3>
                            <span class="text-muted">Currency: </span>
                            <field name="currency_id" readonly="1"/>
                        </h3>
                    </div>

                    <!-- Toolbar: Select All + Bulk qty setters -->
                    <group>
                        <group string="Selection">
                            <field name="select_all" widget="boolean_toggle"/>
                        </group>
                        <group string="Set # Labels for Selected">
                            <div class="o_row">
                                <button name="action_set_qty_all"
                                        string="× 1"
                                        type="object"
                                        class="btn btn-sm btn-outline-secondary"
                                        context="{'qty': 1}"/>
                                <button name="action_set_qty_all"
                                        string="× 2"
                                        type="object"
                                        class="btn btn-sm btn-outline-secondary"
                                        context="{'qty': 2}"/>
                                <button name="action_set_qty_all"
                                        string="× 5"
                                        type="object"
                                        class="btn btn-sm btn-outline-secondary"
                                        context="{'qty': 5}"/>
                                <button name="action_set_qty_all"
                                        string="× 10"
                                        type="object"
                                        class="btn btn-sm btn-outline-secondary"
                                        context="{'qty': 10}"/>
                            </div>
                        </group>
                    </group>

                    <!-- Lines -->
                    <field name="line_ids" widget="one2many_list" nolabel="1">
                        <list editable="bottom"
                              decoration-muted="not selected"
                              decoration-warning="not has_barcode and selected">
                            <field name="selected" widget="boolean_toggle"/>
                            <field name="product_id" force_save="1" readonly="1"/>
                            <field name="product_barcode" readonly="1" optional="show"/>
                            <field name="has_barcode" column_invisible="1"/>
                            <field name="price"/>
                            <field name="label_qty"
                                   string="# Labels"
                                   widget="integer"/>
                        </list>
                    </field>

                    <!-- Warning for products without barcode -->


                </sheet>
            </form>
        </field>
    </record>

    <!-- Action to open wizard -->
    <record id="action_pricelist_barcode_print_wizard" model="ir.actions.act_window">
        <field name="name">Print Barcode Labels</field>
        <field name="res_model">pricelist.barcode.print.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_pricelist_barcode_print_wizard_form"/>
        <field name="target">new</field>
    </record>

</odoo>
