<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_product_pricelist_form_barcode_btn" model="ir.ui.view">
        <field name="name">product.pricelist.form.barcode.print.button</field>
        <field name="model">product.pricelist</field>
        <field name="inherit_id" ref="product.product_pricelist_view"/>
        <field name="arch" type="xml">
           <xpath expr="//header" position="inside">
                <button name="%(pricelist_barcode_print.action_pricelist_barcode_print_wizard)d"
                        string="Print Labels"
                        type="action"
                        class="oe_stat_button"
                        icon="fa-barcode"/>
            </xpath>
        </field>
    </record>

</odoo>
