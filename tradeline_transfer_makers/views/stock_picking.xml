<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="stock_picking_form_inherit_transfer_maker" model="ir.ui.view">
            <field name="name">stock.picking.form.inh.transfer.maker</field>
            <field name="model">stock.picking</field>
            <field name="inherit_id" ref="stock.view_picking_form"/>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='partner_id']" position="after">
                    <field name="transfer_maker" invisible="picking_type_code  != 'internal'"  readonly="state == 'done'" options="{'no_create': True, 'no_create_edit':True, 'no_open': True}" />
                    <field name="validation_code" invisible="picking_type_code  != 'internal'"   readonly="state == 'done'"/>

                </xpath>
             <xpath expr="//button[@name='button_validate']" position="after">
                <button name="generate_code"  string="Generate Code" type="object"   invisible="picking_type_code  != 'internal' or state == 'done'"  />
             </xpath>

            </field>
        </record>
    </data>
</odoo>