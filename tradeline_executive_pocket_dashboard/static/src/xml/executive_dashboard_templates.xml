<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="tradeline_executive_pocket_dashboard.MainDashboard">
        <div class="tl-exec-pocket">
            <div class="tl-exec-header">
                <div class="tl-exec-title-block">
                    <h1>Executive Pocket Dashboard</h1>
                    <p>General to granular executive analytics with live FX watch.</p>
                </div>
                <div class="tl-exec-controls">
                    <div class="tl-control tl-company-control">
                        <span>Company</span>
                        <button type="button" class="tl-company-trigger" t-on-click="onToggleCompanyPicker">
                            <span class="tl-company-summary"><t t-esc="companySelectionSummary"/></span>
                            <span class="tl-company-caret">v</span>
                        </button>
                        <t t-if="state.companyPicker.open">
                            <div class="tl-company-popover">
                                <input
                                    type="text"
                                    placeholder="Search company..."
                                    t-model="state.companyPicker.search"
                                    t-on-input="onCompanySearchInput"
                                />
                                <div class="tl-company-actions">
                                    <button type="button" class="btn btn-sm btn-light" t-on-click="onSelectAllCompanies">All</button>
                                    <button type="button" class="btn btn-sm btn-light" t-on-click="onClearCompanySelection">Clear</button>
                                    <button type="button" class="btn btn-sm btn-primary" t-on-click="onApplyCompanySelection">Apply</button>
                                </div>
                                <div class="tl-company-list">
                                    <t t-foreach="filteredCompanyOptions" t-as="company" t-key="company.id">
                                        <label class="tl-company-item">
                                            <input
                                                type="checkbox"
                                                t-att-value="company.id"
                                                t-att-checked="state.companyPicker.draft_ids.includes(company.id) ? 'checked' : null"
                                                t-on-change="onDraftCompanyToggle"
                                            />
                                            <span><t t-esc="company.name"/></span>
                                        </label>
                                    </t>
                                </div>
                            </div>
                        </t>
                    </div>
                    <label class="tl-control">
                        <span>Start</span>
                        <input type="date" t-model="state.filters.start_date" t-on-change="onDateChange"/>
                    </label>
                    <label class="tl-control">
                        <span>End</span>
                        <input type="date" t-model="state.filters.end_date" t-on-change="onDateChange"/>
                    </label>
                    <label class="tl-control">
                        <span>Lens</span>
                        <select t-model="state.lens" t-on-change="onLensChange">
                            <option value="overview">Overview</option>
                            <option value="performance">Performance</option>
                            <option value="risk">Risk</option>
                            <option value="cash">Cash</option>
                        </select>
                    </label>
                </div>
                <div class="tl-active-companies">
                    <span class="tl-active-label">Active Companies</span>
                    <t t-if="selectedCompanyLabels.length">
                        <t t-foreach="selectedCompanyLabels" t-as="name" t-key="name_index" t-foreach-index="name_index">
                            <span class="tl-active-chip"><t t-esc="name"/></span>
                        </t>
                    </t>
                    <t t-else="">
                        <span class="tl-active-chip is-all">All accessible companies</span>
                    </t>
                </div>
            </div>

            <t t-if="state.loading">
                <div class="tl-exec-loading">Loading executive dashboard...</div>
            </t>
            <t t-elif="state.error">
                <div class="tl-exec-error"><t t-esc="state.error"/></div>
            </t>
            <t t-else="">
                <div class="tl-alert-ribbon">
                    <t t-foreach="alerts" t-as="alert" t-key="alert.label">
                        <span t-att-class="'tl-alert-pill ' + alert.severity">
                            <strong><t t-esc="alert.label"/>:</strong>
                            <t t-esc="alert.detail"/>
                        </span>
                    </t>
                </div>

                <div class="tl-metric-guide">
                    <div class="tl-guide-head">
                        <h2>Metric Definitions &amp; Data Sources</h2>
                        <span t-att-class="'tl-guide-badge ' + marginStatusClass"><t t-esc="marginStatusLabel"/></span>
                    </div>
                    <div class="tl-guide-sub">
                        COGS coverage: <strong><t t-esc="marginCoveragePct"/>%</strong> (<t t-esc="marginStatus.costed_lines || 0"/> / <t t-esc="marginStatus.product_lines || 0"/> lines)
                    </div>
                    <div class="tl-guide-sub"><t t-esc="marginStatusReasonText"/></div>
                    <div class="tl-guide-grid">
                        <div class="tl-guide-item">
                            <div class="tl-guide-title">Net Revenue</div>
                            <div class="tl-guide-body">Posted customer invoices/receipts minus posted refunds from <code>account.move</code> in selected scope.</div>
                        </div>
                        <div class="tl-guide-item">
                            <div class="tl-guide-title">Collections</div>
                            <div class="tl-guide-body">Posted inbound customer payments from <code>account.payment</code> in selected date range.</div>
                        </div>
                        <div class="tl-guide-item">
                            <div class="tl-guide-title">Overdue AR</div>
                            <div class="tl-guide-body">Positive residual balances on posted customer invoices with due date before selected end date.</div>
                        </div>
                        <div class="tl-guide-item">
                            <div class="tl-guide-title">Net Margin</div>
                            <div class="tl-guide-body">Strict real COGS only: line-level <code>price_subtotal - total_cost</code> from <code>account.move.line</code>. Hidden if coverage is incomplete.</div>
                        </div>
                        <div class="tl-guide-item">
                            <div class="tl-guide-title">Inventory Value</div>
                            <div class="tl-guide-body">Allocated using <code>stock.quant</code> on-hand quantities and <code>stock.valuation.layer</code> value/quantity.</div>
                        </div>
                        <div class="tl-guide-item">
                            <div class="tl-guide-title">Pipeline</div>
                            <div class="tl-guide-body">Active opportunities from <code>crm.lead</code>, with open and probability-weighted expected revenue.</div>
                        </div>
                        <div class="tl-guide-item">
                            <div class="tl-guide-title">FX Watch</div>
                            <div class="tl-guide-body">Yahoo Finance source with stale-safe fallback to last good cached value; never blocks dashboard loading.</div>
                        </div>
                        <div class="tl-guide-item">
                            <div class="tl-guide-title">Daily Sales Snapshot</div>
                            <div class="tl-guide-body">7-day posted sales trend from <code>account.move</code> (`out_invoice`, `out_receipt`, `out_refund`).</div>
                        </div>
                    </div>
                </div>

                <div class="tl-kpi-grid">
                    <t t-foreach="cards" t-as="card" t-key="card.key">
                        <div class="tl-kpi-card">
                            <div class="tl-kpi-label"><t t-esc="card.label"/></div>
                            <div class="tl-kpi-value">
                                <t t-if="card.unit === 'EGP'">
                                    <t t-esc="_formatCurrency(card.value)"/>
                                </t>
                                <t t-else="">
                                    <t t-esc="_formatNumber(card.value)"/>
                                </t>
                            </div>
                        </div>
                    </t>
                </div>

                <div class="tl-chart-grid">
                    <div class="tl-chart-card">
                        <h3>Top Drivers (<t t-esc="state.selectedDomain"/> / <t t-esc="selectedMetricLabel"/>)</h3>
                        <div class="tl-bar-chart">
                            <t t-foreach="topChartRows" t-as="item" t-key="item.dimension">
                                <div class="tl-bar-row">
                                    <div class="tl-bar-label"><t t-esc="_shorten(item.dimension, 28)"/></div>
                                    <div class="tl-bar-track">
                                        <div class="tl-bar-fill" t-att-style="'width:' + item.pct + '%'"/>
                                    </div>
                                    <div class="tl-bar-value"><t t-esc="_formatCell(item.metric, item.value)"/></div>
                                </div>
                            </t>
                        </div>
                    </div>
                    <div class="tl-chart-card">
                        <h3>Daily Sales Snapshot (Odoo)</h3>
                        <div class="tl-snapshot-stats">
                            <div class="tl-snapshot-stat">
                                <span>Today Revenue</span>
                                <strong><t t-esc="_formatCurrency(dailySnapshotStats.today_revenue || 0)"/></strong>
                            </div>
                            <div class="tl-snapshot-stat">
                                <span>7D Revenue</span>
                                <strong><t t-esc="_formatCurrency(dailySnapshotStats.total_net_revenue || 0)"/></strong>
                            </div>
                            <div class="tl-snapshot-stat">
                                <span>Avg Basket</span>
                                <strong><t t-esc="_formatCurrency(dailySnapshotStats.avg_basket || 0)"/></strong>
                            </div>
                        </div>
                        <div class="tl-snapshot-dod">
                            Day-over-day:
                            <span t-att-class="_trendClass(dailySnapshotStats.day_over_day_pct)">
                                <t t-esc="_formatPercentOrDash(dailySnapshotStats.day_over_day_pct)"/>
                            </span>
                        </div>
                        <div class="tl-snapshot-bars">
                            <t t-foreach="dailySnapshotBars" t-as="item" t-key="item.date">
                                <div class="tl-snapshot-row">
                                    <div class="tl-snapshot-day"><t t-esc="_formatDayLabel(item.date)"/></div>
                                    <div class="tl-snapshot-track">
                                        <div class="tl-snapshot-fill" t-att-style="'width:' + item.pct + '%'"/>
                                    </div>
                                    <div class="tl-snapshot-value"><t t-esc="_formatCurrency(item.value)"/></div>
                                    <div class="tl-snapshot-count"><t t-esc="_formatNumber(item.invoice_count)"/> inv</div>
                                </div>
                            </t>
                        </div>
                    </div>
                </div>

                <div class="tl-fx-panel">
                    <div class="tl-fx-head">
                        <h2>Currencies To Watch</h2>
                        <button class="btn btn-primary" t-on-click="onRefreshFx" t-att-disabled="state.refreshingFx">
                            <t t-if="state.refreshingFx">Refreshing...</t>
                            <t t-else="">Refresh FX</t>
                        </button>
                    </div>
                    <div class="tl-fx-grid">
                        <t t-foreach="fxCards" t-as="fx" t-key="fx.pair">
                            <div class="tl-fx-card" t-att-class="fx.is_stale ? 'is-stale' : 'is-fresh'">
                                <div class="tl-fx-pair"><t t-esc="fx.display_label || fx.pair"/></div>
                                <div class="tl-fx-rate"><t t-esc="_formatFxRate(fx.rate)"/></div>
                                <div class="tl-fx-egp">EGP</div>
                                <div class="tl-fx-meta">
                                    <span t-att-class="_trendClass(fx.change_pct)">
                                        1D <t t-esc="_formatPercentOrDash(fx.change_pct)"/>
                                    </span>
                                    <span>
                                        <t t-if="fx.is_stale">Stale</t>
                                        <t t-else="">Fresh</t>
                                    </span>
                                </div>
                                <div class="tl-fx-periods">
                                    <t t-foreach="_periodRows(fx.period_changes || {})" t-as="pc" t-key="pc.label">
                                        <span class="tl-fx-chip">
                                            <strong><t t-esc="pc.label"/></strong>
                                            <span t-att-class="_trendClass(pc.value)"><t t-esc="_formatPercentOrDash(pc.value)"/></span>
                                        </span>
                                    </t>
                                </div>
                                <div class="tl-fx-time">Updated <t t-esc="fx.age_minutes"/> min ago</div>
                            </div>
                        </t>
                    </div>
                </div>

                <div class="tl-drill-panel">
                    <div class="tl-drill-head">
                        <h2>Granular Drilldown</h2>
                        <div class="tl-drill-actions">
                            <button class="btn btn-light" t-if="hasSort" t-on-click="clearSort">Clear Sort</button>
                            <button class="btn btn-secondary" t-on-click="onOpenNativeView">Open Native View</button>
                        </div>
                    </div>

                    <div class="tl-drill-coverage">
                        <span class="tl-drill-badge">Records in selected domain: <strong><t t-esc="_formatNumber(selectedDomainCoverage)"/></strong></span>
                        <t t-if="selectedDomainDescription">
                            <span class="tl-drill-desc"><t t-esc="selectedDomainDescription"/></span>
                        </t>
                    </div>
                    <div class="tl-drill-sort-note"><t t-esc="sortSummary"/></div>

                    <div class="tl-drill-filters">
                        <label>
                            <span>Domain</span>
                            <select t-model="state.selectedDomain" t-on-change="onDomainChange">
                                <t t-foreach="availableDomains" t-as="domain" t-key="domain.key">
                                    <option t-att-value="domain.key"><t t-esc="domain.label"/></option>
                                </t>
                            </select>
                        </label>
                        <label>
                            <span>Group By</span>
                            <select t-model="state.selectedGroupBy" t-on-change="onGroupChange">
                                <t t-foreach="availableGroups" t-as="grp" t-key="grp.key">
                                    <option t-att-value="grp.key"><t t-esc="grp.label"/></option>
                                </t>
                            </select>
                        </label>
                        <label>
                            <span>Metric</span>
                            <select t-model="state.selectedMetric" t-on-change="onMetricChange">
                                <t t-foreach="availableMetrics" t-as="m" t-key="m.key">
                                    <option t-att-value="m.key"><t t-esc="m.label"/></option>
                                </t>
                            </select>
                        </label>
                    </div>

                    <t t-if="!hasRows">
                        <div class="tl-empty-state">
                            No rows for the current selection. Try broadening date/company filters or change Domain/Group/Metric.
                        </div>
                    </t>

                    <div class="tl-table-wrap">
                        <table class="table table-sm table-striped">
                            <thead>
                                <tr>
                                    <t t-foreach="drillColumns" t-as="column" t-key="column">
                                        <th>
                                            <button
                                                type="button"
                                                class="tl-table-sort-btn"
                                                t-att-class="state.sort.column === column ? 'is-active' : ''"
                                                t-att-data-column="column"
                                                t-on-click="onSortColumnClick"
                                            >
                                                <span><t t-esc="column"/></span>
                                                <span class="tl-sort-caret"><t t-esc="sortIcon(column)"/></span>
                                            </button>
                                        </th>
                                    </t>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="drillRows" t-as="row" t-key="row_index" t-foreach-index="row_index">
                                    <tr>
                                        <t t-foreach="drillColumns" t-as="column" t-key="column">
                                            <td><t t-esc="_formatCell(column, row[column])"/></td>
                                        </t>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>
                </div>
            </t>
        </div>
    </t>
</templates>
