<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_exec_dashboard" model="ir.module.category">
        <field name="name">Executive Dashboard</field>
        <field name="description">Executive analytics and pocket dashboard access</field>
        <field name="sequence">41</field>
    </record>

    <record id="group_exec_viewer" model="res.groups">
        <field name="name">Executive Dashboard Viewer</field>
        <field name="category_id" ref="tradeline_executive_pocket_dashboard.module_category_exec_dashboard"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_exec_branch_manager" model="res.groups">
        <field name="name">Executive Dashboard Branch Manager</field>
        <field name="category_id" ref="tradeline_executive_pocket_dashboard.module_category_exec_dashboard"/>
        <field name="implied_ids" eval="[(4, ref('tradeline_executive_pocket_dashboard.group_exec_viewer'))]"/>
    </record>

    <record id="group_exec_admin" model="res.groups">
        <field name="name">Executive Dashboard Admin</field>
        <field name="category_id" ref="tradeline_executive_pocket_dashboard.module_category_exec_dashboard"/>
        <field name="implied_ids" eval="[(4, ref('tradeline_executive_pocket_dashboard.group_exec_branch_manager'))]"/>
        <field name="users" eval="[(6, 0, [ref('base.user_admin')])]"/>
    </record>
</odoo>

