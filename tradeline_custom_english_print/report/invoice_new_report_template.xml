<?xml version="1.0" encoding="UTF-8"?>
    <odoo>

    <template id="external_layout_standard_custom">
			 <t t-if="not o and doc"><t t-set="o" t-value="doc"/></t>

            <t t-if="o and 'company_id' in o"><t t-set="company" t-value="o.company_id.sudo()"/></t><t t-if="not o or not 'company_id' in o"><t t-set="company" t-value="res_company"/></t>
			<div class="header">
                <div class="row">
                    <div class="col-3 mb4">
                            <img t-if="o.company_id.logo" t-att-src="image_data_uri(o.company_id.logo)"
                            style="max-height: 40pt; max-width: 100%;"
                             alt="Logo"/>


                    </div>
                    <div class="col-9 text-right" style="margin-top:22px;" t-field="company.report_header" name="moto"/>
                </div>
                <div t-if="company.logo or company.report_header" class="row zero_min_height">
                    <div class="col-12">
                        <div style="border-bottom: 1px solid black;"/>
                    </div>
                </div>
            </div>
			 <div class="article" t-att-data-oe-model="o and o._name" t-att-data-oe-id="o and o.id" t-att-data-oe-lang="o and o.env.context.get('lang')">
         	 	<t t-raw="0"/>
			</div>
			<div class="footer o_standard_footer">
				<div class="text-center" style="border-top: 1px solid black;">
					<ul class="list-inline mb4">
					<!-- using the list-inline-item class from bootstrap causes weird behaviours in pdf report
						 adding d-inline class fixes the problem-->
					<li t-if="o.company_id.mobile" class="list-inline-item d-inline">Mobile :
						<span class="o_force_ltr" t-field="o.company_id.mobile"/>
					</li>
					<li t-if="o.company_id.email" class="list-inline-item d-inline">Email :
						<span t-field="o.company_id.email"/>
					</li>
					<li t-if="o.company_id.website" class="list-inline-item d-inline">Website:
						<span t-field="o.company_id.website"/>
					</li>
					<!--                    <li t-if="company.vat" class="list-inline-item d-inline"><t t-esc="company.country_id.vat_label or 'Tax ID'"/>: <span t-field="company.vat"/></li>-->
				</ul>


                <div name="financial_infos">
                    <span t-field="company.report_footer"/>
                </div>

                <div t-if="report_type == 'pdf'" class="text-muted">
                    Page:
                    <span class="page"/>
                    /
                    <span class="topage"/>
                </div>
            </div>
        </div>
    	</template>
            <template id="tradeline_custom_english_print.new_report_invoice_document">
            <t t-call="web.html_container">
            <t t-call="tradeline_custom_english_print.external_layout_standard_custom">
            <t t-set="o" t-value="o.with_context(lang='en_US')"/>
            <t t-set="print_summary" t-value="o.get_print_lines_summary()"/>


            <div class="page" style="font-size:30px;">
                <div id="header_print" class="row mt25" dir="ltr">
                    <div class="col-4" style="font-size: 14px;" name="name_stores">
                        <strong>
                            <span t-field="o.company_id.name"/>
                        </strong>

                    </div>
                     <div class="col-4 " style="padding-left: 130px" name="hotline">

                        <strong>Hotline :</strong>
                        <!--                    <br/>-->
                        <strong>19857</strong>
                    </div>
                     <div id="informations_header" class="row mt32 ">
                          <strong>Commercial Registration:</strong>
                         <strong>24801</strong>
                            <br/>

                         <strong>Tax Card:</strong>
                         <strong>254-598-64-0</strong>
                             <br/>

                        <strong>Tax ID:</strong>
                         <strong>555-5-00169-191-00-00</strong>
                    </div>
                </div>

                  <div id="header_print" class="row mt32" dir="ltr">

                    <div class="col-5" style="font-size: 14px;" name="name_stores">

                        <strong t-if="o.name">Invoice Number :</strong>
                            <h3  t-if="o.name">

                                <span t-field="o.name"/>
                                <br/>
                            </h3>
                    </div>
                     <div class="col-4 " style="padding-left: 130px" name="hotline">
                     </div>

                    <div class="col-2">
                        <div class="pull-right mb32" name="right_box">
                            <center>
                                <img t-att-src="'/report/barcode/?type=%s&amp;value=%s&amp;width=%s&amp;height=%s' % ('Code128', o.barcode, 200, 100)"
                                     style="width:200px;height:50px;"/>
                                <div t-esc="o.barcode"/>
                            </center>
                        </div>
                    </div>


                </div>

                 <div id="informations" class="row mt32" style="font-size:9px;"  t-if="o.bank_id">

                <div class="col-2" style="margin-top:5px;">
                    <strong>Bank Name :</strong>
                    <br/>
                    <t t-esc="o.bank_id.name"/>
                </div>
                <div class="col-2" style="margin-top:5px;">
                    <strong>Bank Account Name :</strong>
                    <br/>
                    <t t-esc="o.bank_id.account_name"/>
                </div>
                 <div class="col-2" style="margin-top:5px;">
                    <strong>Bank Account Number:</strong>
                     <br/>
                    <t t-esc="o.bank_id.account_number"/>
                </div>
                <div class="col-2" style="margin-top:5px;">
                    <strong>Account currency:</strong>
                    <br/>
                    <t t-esc="o.bank_id.currency_id.name"/>
                </div>
                <div class="col-2" style="margin-top:5px;">
                    <strong>Swift Code :</strong>
                    <br/>
                    <t t-esc="o.bank_id.swift_code"/>
                </div>
                   <div class="col-2" style="margin-top:5px;"  name="po_field">
                        <strong>IBAN:</strong>
                       <br/>
                        <p class="m-0" t-field="o.bank_id.IBAN"/>
                    </div>
            </div>


                <div id="informations" class="row mt32">
                    <div class="col-3" name="invoice_partner">
                        <strong>Customer : </strong>
                        <p>
                            <span class="m-0" t-field="o.partner_id.name"/>

                        </p>
                    </div>
                    <div class="col-3" name="mobile_number">
                        <strong>Mobile Number:</strong>
                        <p class="m-0" t-field="o.partner_id.mobile"/>
                    </div>
                    <div class="col-3" >
                        <strong>Invoice Date:</strong>
                        <p class="m-0" t-field="o.invoice_date"/>
                    </div>


                    <div name="sales rep" class="col-3">
                        <strong>PO:</strong>
                         <p class="m-0" t-field="o.reference_number"/>
                    </div>
                </div>
                <div id="informations" class="row mt32">

                    <div class="col-3"  >
                            <strong>Billing Address:</strong>
                                    <p t-field="o.partner_id.street2" />
                    </div>
                    <div class="col-3" >
                        <strong>Tax ID :</strong>
                        <p class="m-0" t-field="o.partner_id.vat"/>
                    </div>
                    <div class="col-3">
                        <strong>Branch :</strong>
                        <p class="m-0" t-field="o.branch_id.name"/>
                    </div>
                </div>


                <t t-set="display_discount" t-value="any([l.discount for l in o.invoice_line_ids])"/>

                <table class="table table-sm o_main_table" name="invoice_line_table">
                    <thead>
                        <tr>
                            <t t-set="colspan" t-value="6"/>
                            <th class="text-left">
                                <span>Item Code</span>
                            </th>
                            <th class="text-left">
                                <span>Product</span>
                            </th>


                            <th class="text-right">
                                <span>QTY</span>
                            </th>
                            <th class="text-right">
                                <span>Unit Price</span>
                            </th>
                            <t t-if="o.get_gift_invoice()==false">

                                    <th
                                        t-attf-class="text-left {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}">
                                        <span>Tax</span>
                                    </th>
                                    <th class="text-right">
                                        <span groups="account.group_show_line_subtotals_tax_excluded">SubTotal</span>

                                    </th>
                            </t>
                        </tr>
                    </thead>

                <tbody class="invoice_tbody">
                            <t t-set="current_subtotal" t-value="0"/>
                                <t t-set="lines" t-value="print_summary['printed_lines']"/>

                            <t t-foreach="lines" t-as="line">



                                <t t-set="current_subtotal" t-value="current_subtotal + line.price_subtotal" groups="account.group_show_line_subtotals_tax_excluded"/>
                                <t t-set="current_subtotal" t-value="current_subtotal + line.price_total" groups="account.group_show_line_subtotals_tax_included"/>

                                <tr t-att-class="'fw-bold o_line_section' if line.display_type == 'line_section' else 'fst-italic o_line_note' if line.display_type == 'line_note' else ''">
                                <t t-if="line.display_type == 'product'" name="account_invoice_line_accountable">

                                        <td name="account_invoice_line_code">
                                            <span t-field="line.product_id.barcode"/>
                                        </td>
                                        <td name="account_invoice_line_name">
                                            <span t-field="line.product_id.display_name"/>
                                        </td>

                                        <td class="text-right">
                                            <span t-esc="int(line.quantity)"/>
                                            <!--<span t-field="line.quantity"/>-->
<!--                                            <span t-field="line.uom_id" groups="uom.group_uom"/>-->
                                        </td>

                                        <t t-if="o.get_gift_invoice()==false">

                                                    <td t-attf-class="text-right {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}">
                                                        <span t-field="line.price_unit"/>
                                                    </td>
                                                  <t t-set="taxes" t-value="', '.join([(tax.invoice_label or tax.name) for tax in line.tax_ids])"/>
                                                <td name="td_taxes" t-attf-class="text-end {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }} {{ 'text-nowrap' if len(taxes) &lt; 10 else '' }}">
                                                <span t-out="taxes" id="line_tax_ids">Tax 15%</span>
                                            </td>
                                                <!--<td  t-attf-class="text-left {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}">-->
                                                <!--    <span t-esc="line.discount"/>-->
                                                <!--</td>-->
                                                <td class="text-right o_price_total">
                                                    <span t-field="line.price_subtotal" groups="account.group_show_line_subtotals_tax_excluded"/>
                                                    <span t-field="line.price_total" groups="account.group_show_line_subtotals_tax_included"/>
                                                </td>

                                        </t>
                                    </t>
                                    <t t-if="line.display_type == 'line_section'">
                                        <td colspan="99">
                                            <span t-field="line.name"/>
                                        </td>
                                        <t t-set="current_section" t-value="line"/>
                                        <t t-set="current_subtotal" t-value="0"/>
                                    </t>
                                    <t t-if="line.display_type == 'line_note'">
                                        <td colspan="99">
                                            <span t-field="line.name"/>
                                        </td>
                                    </t>
                                </tr>


                            </t>
                        </tbody>
                    </table>

                <div class="clearfix" t-if="o.get_gift_invoice()==false">
                    <div id="total" class="row">
                        <div t-attf-class="#{'col-4' if report_type != 'html' else 'col-sm-7 col-md-5'} ml-auto">
                                <table class="table table-sm;page-break-inside: avoid;">
                                    <tr class="border-black o_subtotal" style="">
                                        <td><strong>Untaxed Amount </strong></td>
                                           <td class="text-right">
                                            <span t-out="print_summary['printed_untaxed']" t-options='{"widget": "monetary", "display_currency": o.currency_id}'>0.00</span>
                                        </td>

                                    </tr>
                                    <tr class="border-black o_subtotal">
                                        <td><strong>Tax</strong></td>
                                        <td class="text-right">
                                            <span t-out="print_summary['printed_tax']" t-options='{"widget": "monetary", "display_currency": o.currency_id}'>0.00</span>
                                        </td>
                                    </tr>


                                    <tr class="border-black o_total">
                                        <td><strong>Total</strong></td>
                                        <td class="text-right">
                                            <span t-out="print_summary['printed_total']" t-options='{"widget": "monetary", "display_currency": o.currency_id}'>0.00</span>
                                        </td>
                                    </tr>
                                </table>
                        </div>
                    </div>
                </div>
                <br/>

                <p class="text-right" t-if="o.get_gift_invoice()==false">
                    <t t-esc="print_summary['printed_amount_words_en']"/>
                </p>

                <t t-if="o.get_grouped_lot_values()">
<!--                <t t-set="has_serial_number" t-value="o.get_move_lines_ids().mapped('lot_id')"/>-->

                  <t t-set="lot_values" t-value="o.get_grouped_lot_values()"/>

                            <table class="table table-sm mt-2" style="width: 50%;" name="invoice_snln_table">
                                <thead>
                                    <tr>
                                        <th>Product</th>
                                        <th class="text-end">QTY</th>
                                        <th class="text-end">Serial Number</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr t-foreach="lot_values" t-as="snln_line">
                                        <td><t t-esc="snln_line['product_name']"/></td>
                                        <td class="text-end">
                                            <t t-esc="snln_line['quantity']"/>
                                            <t t-esc="snln_line['uom_name']" groups="uom.group_uom"/>
                                        </td>
                                        <td class="text-end">
                                            <t t-esc="snln_line['serials']"/>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>


                </t>


<!--                <p class="text-left" t-if="o.note" name="notes" style="font-size:9px">-->
<!--                        <span>Notes:</span>-->
<!--                        <span t-field="o.note"/>-->
<!--                </p>-->



<!--                <br></br>-->



                <p t-if="o.fiscal_position_id.note" name="note">
                    <span t-field="o.fiscal_position_id.note"/>
                </p>
                <div id="qrcode"
                     t-if="(o.partner_id.country_id.code in ['BE', 'AT', 'DE', 'FI', 'NL']) and (o.company_id.qr_code) and (o.currency_id.name == 'EUR') and (o.partner_bank_id.acc_number != False)">
                    <p t-if="(o.partner_bank_id.qr_code_valid)">
                        <strong class="text-center">Scan me with your banking app.</strong>
                        <br/>
                        <br/>
                        <img class="border border-dark rounded"
                             t-att-src="o.partner_bank_id.build_qr_code_url(o.residual,(o.reference) if (o.reference) else o.number)"/>
                    </p>
                    <p t-if="(o.partner_bank_id.qr_code_valid == False)">
                        <strong class="text-center">The SEPA QR Code informations are not set correctly.</strong>
                        <br/>
                    </p>
                </div>
                <p dir="rtl" class="text-right">
                    <b>Signature : -------------------------------</b>
                </p>
                </div>
             </t>
             </t>
<!--             </t>-->
        </template>


        <template id="new_report_invoice">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="o">
                    <t t-set="lang" t-value="o.user_id.lang if o.move_type in ('out_invoice', 'out_refund') else o.partner_id.lang"/>
                    <t t-call="tradeline_custom_english_print.new_report_invoice_document" t-lang="en_US"/>
                </t>
            </t>
        </template>


             <record id="action_report_transfer_request" model="ir.actions.report">
                <field name="name">English Invoice</field>
                <field name="model">account.move</field>
                <field name="report_type">qweb-pdf</field>
                <field name="report_name">tradeline_custom_english_print.new_report_invoice</field>
                <field name="report_file">tradeline_custom_english_print.new_report_invoice</field>
                <field name="print_report_name">'English Invoice - %s ' % ((object.name or 'English Invoice').replace('/',''))</field>
                <field name="binding_model_id" ref="account.model_account_move"/>
                <field name="binding_type">report</field>
            </record>


</odoo>
