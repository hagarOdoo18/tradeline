        <field name="res_model">legacy.sale.order.line</field>
        <field name="view_mode">list,form,pivot,graph</field>
        <field name="view_id" ref="view_legacy_sale_order_line_list"/>
        <field name="search_view_id" ref="view_legacy_sale_order_line_search"/>
