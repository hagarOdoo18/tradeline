    <record id="view_legacy_sale_order_line_form" model="ir.ui.view">
        <field name="name">legacy.sale.order.line.form</field>
        <field name="model">legacy.sale.order.line</field>
        <field name="arch" type="xml">
            <form string="Legacy Sale Order Line" create="false" edit="false" delete="false">
                <sheet>
                    <group>
                        <group>
                            <field name="order_id"/>
                            <field name="order_date"/>
                            <field name="source_customer_name"/>
                            <field name="customer_mobile"/>
                            <field name="source_salesperson_name"/>
                            <field name="source_sales_rep_name"/>
                            <field name="status_quotation"/>
                            <field name="status_sale"/>
                        </group>
                        <group>
                            <field name="item_code"/>
                            <field name="product_name"/>
                            <field name="description"/>
                            <field name="qty_ordered"/>
