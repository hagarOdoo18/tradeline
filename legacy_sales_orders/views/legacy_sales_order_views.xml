    <record id="view_legacy_sale_order_line_pivot" model="ir.ui.view">
        <field name="name">legacy.sale.order.line.pivot</field>
        <field name="model">legacy.sale.order.line</field>
        <field name="arch" type="xml">
            <pivot string="Legacy Sale Order Lines">
                <field name="qty_ordered" type="measure"/>
                <field name="price_subtotal" type="measure"/>
                <field name="amount_total_line" type="measure"/>
                <field name="payment_amount_line" type="measure"/>
