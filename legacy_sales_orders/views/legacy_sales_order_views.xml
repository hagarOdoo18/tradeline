                    <filter name="legacy_sale_order_lines_group_category" string="Product Category" context="{'group_by': 'product_category_name'}"/>
                    <filter name="legacy_sale_order_lines_group_family" string="Family" context="{'group_by': 'source_family_name'}"/>
