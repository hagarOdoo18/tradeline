<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ══════════════════════════════════════════════════════ -->
    <!--  pos.serial.history — Views                           -->
    <!-- ══════════════════════════════════════════════════════ -->

    <record id="view_pos_serial_history_list" model="ir.ui.view">
        <field name="name">pos.serial.history.list</field>
        <field name="model">pos.serial.history</field>
        <field name="arch" type="xml">
            <list string="سجل الأرقام التسلسلية"
                  decoration-success="operation == 'sale'"
                  decoration-warning="operation == 'return'">
                <field name="date"/>
                <field name="lot_id"/>
                <field name="operation"/>
                <field name="order_id"/>
                <field name="user_id"/>
                <field name="note"/>
            </list>
        </field>
    </record>

    <record id="action_pos_serial_history" model="ir.actions.act_window">
        <field name="name">سجل الأرقام التسلسلية</field>
        <field name="res_model">pos.serial.history</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ══════════════════════════════════════════════════════ -->
    <!--  stock.lot — Form                                     -->
    <!-- ══════════════════════════════════════════════════════ -->

    <record id="view_production_lot_form_inherit" model="ir.ui.view">
        <field name="name">stock.lot.form.inherit.pos.serial</field>
        <field name="model">stock.lot</field>
        <field name="inherit_id" ref="stock.view_production_lot_form"/>
        <field name="arch" type="xml">

            <!-- Smart Button -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_serial_history"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-history"
                        invisible="history_count == 0">
                    <field name="history_count" widget="statinfo" string="عمليات POS"/>
                </button>
            </xpath>

            <!-- بانر مباع -->
            <xpath expr="//sheet" position="before">
                <div class="alert alert-danger" role="alert"
                     invisible="serial_status != 'sold'">
                    <i class="fa fa-exclamation-circle me-2"/>
                    <strong>مباع:</strong> هذا الرقم التسلسلي مباع حالياً في POS ولم يُرتجع بعد.
                </div>
                <!-- بانر مرتجع -->
                <div class="alert alert-warning" role="alert"
                     invisible="serial_status != 'returned'">
                    <i class="fa fa-undo me-2"/>
                    <strong>مرتجع:</strong> تم إرجاع هذا الرقم التسلسلي وهو متاح للبيع مجدداً.
                    (عدد مرات الإرجاع: <field name="return_count" readonly="1" nolabel="1"/>)
                </div>
            </xpath>

            <!-- حقول الحالة -->
            <xpath expr="//group[1]" position="inside">
                <field name="serial_status" widget="badge"
                       decoration-success="serial_status == 'available'"
                       decoration-danger="serial_status == 'sold'"
                       decoration-warning="serial_status == 'returned'"/>
                <field name="return_count"
                       readonly="1"
                       invisible="return_count == 0"/>
                <field name="pos_order_line_id"
                       readonly="1"
                       invisible="serial_status == 'available'"/>
            </xpath>

            <!-- تاب السجل -->
            <xpath expr="//notebook" position="inside">
                <page string="سجل عمليات POS"
                      name="serial_history"
                      invisible="history_count == 0">
                    <field name="serial_history_ids" readonly="1">
                        <list decoration-success="operation == 'sale'"
                              decoration-warning="operation == 'return'">
                            <field name="date"/>
                            <field name="operation"/>
                            <field name="order_id"/>
                            <field name="user_id"/>
                            <field name="note"/>
                        </list>
                    </field>
                </page>
            </xpath>

        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════ -->
    <!--  stock.lot — List                                     -->
    <!-- ══════════════════════════════════════════════════════ -->

    <record id="view_production_lot_tree_inherit" model="ir.ui.view">
        <field name="name">stock.lot.list.inherit.pos.serial</field>
        <field name="model">stock.lot</field>
        <field name="inherit_id" ref="stock.view_production_lot_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//list" position="inside">
                <field name="serial_status"
                       optional="show"
                       widget="badge"
                       decoration-success="serial_status == 'available'"
                       decoration-danger="serial_status == 'sold'"
                       decoration-warning="serial_status == 'returned'"/>
                <field name="return_count" optional="show"/>
            </xpath>
        </field>
    </record>

