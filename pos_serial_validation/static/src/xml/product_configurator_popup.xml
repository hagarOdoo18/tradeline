<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t
        t-name="pos_serial_validation.ProductConfiguratorPopup"
        t-inherit="point_of_sale.ProductConfiguratorPopup"
        t-inherit-mode="extension"
        owl="1"
    >
        <xpath expr="//div[@t-ref='input-area']" position="inside">
            <div t-if="isStockBlocked" class="alert alert-danger mt-3">
                <span t-esc="stockBlockedMessage" />
            </div>
        </xpath>
        <xpath expr="//button[@t-on-click='confirm']" position="attributes">
            <attribute name="t-att-class">{'disabled': isArchivedCombination() || isStockBlocked}</attribute>
        </xpath>
    </t>
</templates>
