<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
         <record id="tradeline_sent_tvc_invoice_cron" forcecreate='True' model="ir.cron">
            <field name="name">Cron Send TVC Invoices</field>
            <field eval="False" name="active"/>
            <field name="user_id" ref="base.user_admin"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="model_id" ref="account.model_account_move"/>
            <field name="state">code</field>
            <field name="code">model.sent_TVC_invoice()</field>
         </record>
         <record id="tradeline_sent_tvc_credit_cron" forcecreate='True' model="ir.cron">
            <field name="name">Cron Send TVC Credit</field>
            <field eval="False" name="active"/>
            <field name="user_id" ref="base.user_admin"/>
            <field name="interval_number">30</field>
            <field name="interval_type">minutes</field>
            <field name="model_id" ref="account.model_account_move"/>
            <field name="state">code</field>
            <field name="code">model.sent_TVC_credit()</field>
         </record>
         <record id="tradeline_sent_tvc_point_cron" forcecreate='True' model="ir.cron">
            <field name="name">Cron Send TVC Point</field>
            <field eval="False" name="active"/>
            <field name="user_id" ref="base.user_admin"/>
            <field name="interval_number">15</field>
            <field name="interval_type">minutes</field>
            <field name="model_id" ref="account.model_account_move"/>
            <field name="state">code</field>
            <field name="code">model.sent_tvc_point()</field>
         </record>
