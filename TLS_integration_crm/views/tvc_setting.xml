<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>


        <record id="tvc_setting_view_tree" model="ir.ui.view">
            <field name="name">tvc_setting_view_tree</field>
            <field name="model">tvc.setting</field>
            <field name="arch" type="xml">
                <list string="tvc_setting_tree" create="1" editable="bottom"  edit='1' delete="1" import="0">
                    <field name="from_date"/>
                    <field name="to_date"/>
                    <field name="exel_Sheet"/>
                    <field name="offer"/>
                    <field name="offer_key"/>
                    <field name="amount"/>
                    <field name="amount"/>
                    <field name="invoice_id" options="{'no_create': True, 'no_create_edit':True, 'no_open': True}"/>
                    <field name="order_id" options="{'no_create': True, 'no_create_edit':True, 'no_open': True}"/>
                    <button name="sent_TVC_invoice" string="Sent TVC Invoices" type="object" />
                    <button name="import_excel" string="Import Excel" type="object" />
                </list>
            </field>
        </record>

        <record id="action_open_tvc_settings" model="ir.actions.act_window">
            <field name="name">Setting</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">tvc.setting</field>
            <field name="view_mode">list</field>
            <field name="view_id" ref="tvc_setting_view_tree"/>

        </record>


    </data>
</odoo>