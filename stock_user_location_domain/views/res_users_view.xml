<odoo>
    <record id="view_users_form_stock_location" model="ir.ui.view">
        <field name="name">res.users.form.stock.location</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <notebook position="inside">
                <page string="Stock Locations">
                    <group name="Locations">
                                            <field name="stock_location_ids" widget="many2many_tags"/>

                    </group>
                </page>
            </notebook>
        </field>
    </record>
</odoo>
