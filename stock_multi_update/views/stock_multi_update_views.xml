<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ════════════════════════════════
         FORM VIEW
    ════════════════════════════════ -->
    <record id="view_stock_multi_update_form" model="ir.ui.view">
        <field name="name">stock.multi.update.form</field>
        <field name="model">stock.multi.update</field>
        <field name="arch" type="xml">
            <form string="Multi Product Update">

                <header>
                    <button name="action_apply"
                            string="Apply Update"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"
                            confirm="This will update stock quantities. Are you sure?"/>
                    <button name="action_cancel"
                            string="Cancel"
                            type="object"
                            invisible="state != 'draft'"/>
                    <button name="action_open_import_wizard" string="⬆ Import from Excel" type="object" invisible="state != 'draft'"/>

                    <button name="action_reset_draft"
                            string="Reset to Draft"
                            type="object"
                            invisible="state != 'cancelled'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,done"/>
                </header>

                <sheet>
                    <div class="oe_button_box" name="button_box"/>

                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>

                    <group>
                        <group string="Update Info">
                            <field name="date"/>
                            <field name="location_id" options="{'no_create': True}"/>
                        </group>
                        <group string="Summary" invisible="state == 'draft'">
                            <field name="total_lines" string="Lines"/>
                            <field name="total_add" string="Total Added"/>
                            <field name="total_sub" string="Total Subtracted"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Product Lines" name="lines">
                            <field name="line_ids" widget="one2many" nolabel="1"
                                   readonly="state in ('done','cancelled')">
                                <list editable="bottom"
                                      decoration-success="operation == 'add'"
                                      decoration-danger="operation == 'subtract'"
                                      decoration-warning="tracking in ('serial','lot') and not lot_id and not lot_name">
                                    <control>
                                        <create string="Add a product line"/>
                                    </control>
                                    <field name="sequence" widget="handle"/>
                                    <field name="product_id" required="1"
                                           options="{'no_create': False}"/>
                                    <field name="product_uom_id" optional="show" readonly="1"/>
                                    <field name="tracking" column_invisible="1"/>
                                    <field name="lot_id"
                                           optional="show"
                                           domain="[('product_id', '=', product_id)]"
                                           context="{'default_product_id': product_id}"
                                           invisible="tracking == 'none' or not tracking"/>
                                    <field name="lot_name"
                                           optional="show"
                                           string="New Lot/Serial"
                                           invisible="tracking == 'none' or not tracking or lot_id"/>
                                    <field name="operation" widget="badge"
                                           decoration-success="operation == 'add'"
                                           decoration-danger="operation == 'subtract'"/>
                                    <field name="qty" string="Qty" required="1"/>

                                    <!-- Draft: show live preview -->
                                    <field name="qty_on_hand"
                                           string="Current Qty"
                                           readonly="1"
                                           optional="show"
                                           invisible="state == 'done'"/>
                                    <field name="qty_after_preview"
                                           string="Expected After"
                                           readonly="1"
                                           optional="show"
                                           decoration-danger="qty_after_preview &lt; 0"
                                           invisible="state == 'done'"/>

                                    <!-- Done: show stored snapshot -->
                                    <field name="qty_before"
                                           string="Qty Before"
                                           readonly="1"
                                           optional="show"
                                           invisible="state != 'done'"/>
                                    <field name="qty_after"
                                           string="Qty After"
                                           readonly="1"
                                           optional="show"
                                           decoration-success="qty_after &gt; qty_before"
                                           decoration-danger="qty_after &lt; qty_before"
                                           invisible="state != 'done'"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="notes" placeholder="Internal notes..."/>
                        </page>
                    </notebook>
                </sheet>

                <chatter/>
            </form>
        </field>
    </record>

    <!-- ════════════════════════════════
         LIST (TREE) VIEW
    ════════════════════════════════ -->
    <record id="view_stock_multi_update_list" model="ir.ui.view">
        <field name="name">stock.multi.update.list</field>
        <field name="model">stock.multi.update</field>
        <field name="arch" type="xml">
            <list string="Multi Product Updates"
                  decoration-muted="state == 'cancelled'"
                  decoration-success="state == 'done'">
                <field name="name"/>
                <field name="date"/>
                <field name="location_id"/>
                <field name="total_lines" string="Lines"/>
                <field name="total_add" string="Total Added" optional="show"/>
                <field name="total_sub" string="Total Subtracted" optional="show"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'done'"
                       decoration-warning="state == 'draft'"
                       decoration-danger="state == 'cancelled'"/>
            </list>
        </field>
    </record>


    <!-- ════════════════════════════════
         ACTION
    ════════════════════════════════ -->
    <record id="action_stock_multi_update" model="ir.actions.act_window">
        <field name="name">Multi Product Update</field>
        <field name="res_model">stock.multi.update</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_filter_draft': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first multi-product update
            </p>
            <p>
                Add or subtract quantities for multiple products at once, with lot/serial support.
            </p>
        </field>
    </record>

    <!-- Sequence for auto-naming -->
    <record id="seq_stock_multi_update" model="ir.sequence">
        <field name="name">Stock Multi Update</field>
        <field name="code">stock.multi.update</field>
        <field name="prefix">SMU/%(year)s/</field>
        <field name="padding">4</field>
        <field name="company_id" eval="False"/>
    </record>

</odoo>
