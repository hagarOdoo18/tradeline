<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ════════════════════════════════
         IMPORT WIZARD FORM VIEW
    ════════════════════════════════ -->
    
    <record id="view_stock_multi_update_import_wizard_form" model="ir.ui.view">
        <field name="name">stock.multi.update.import.wizard.form</field>
        <field name="model">stock.multi.update.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Import Lines from Excel">
                <sheet>
                      <div invisible="state != 'upload'">
                        <div class="oe_title">
                            <h1>Import from Excel</h1>
                            <p class="text-muted">
                                Upload an Excel file (.xlsx) to bulk-import product lines.
                                Required columns: <strong>Product</strong>, <strong>Qty</strong>, <strong>Operation</strong>.
                                Optional: Lot/Serial, Note.
                            </p>
                        </div>

                        <group>
                            <group string="Upload File">
                                <field name="update_id" invisible="1"/>
                                <field name="state" invisible="1"/>
                                <field name="excel_file"
                                       widget="binary"
                                       filename="excel_filename"
                                       required="1"/>
                                <field name="excel_filename" invisible="1"/>
                            </group>
                        </group>


                    </div>
                     <div invisible="state != 'preview'">
                        <div class="oe_title">
                            <h1>Preview Import</h1>
                        </div>

                        <!-- FIX: use plain fields in a group, not inside span tags -->
                        <group string="Summary">
                            <field name="success_count" string="Valid Lines" readonly="1"/>
                            <field name="error_count"   string="Error Lines" readonly="1"/>
                        </group>

                        <div class="alert alert-warning" role="alert"
                             invisible="error_count == 0">
                            Lines with errors will be <strong>skipped</strong>.
                            Fix the Excel file and click "Re-upload" to retry.
                        </div>

                        <div class="alert alert-success" role="alert"
                             invisible="error_count != 0">
                            All lines are valid and ready to import.
                        </div>
                     </div>
                     <field name="preview_line_ids" nolabel="1" readonly="1">
                            <list decoration-danger="status == 'error'"
                                  decoration-success="status == 'ok'">
                                <field name="row_num"     string="Row"/>
                                <field name="product_id"  string="Product"/>
                                <field name="product_raw" string="Raw Input" optional="hide"/>
                                <field name="lot_serial"  string="Lot / Serial" optional="show"/>
                                <field name="operation"
                                       widget="badge"
                                       decoration-success="operation == 'add'"
                                       decoration-danger="operation == 'subtract'"/>
                                <field name="qty" string="Qty"/>
                                <field name="note" optional="show"/>
                                <field name="status"
                                       widget="badge"
                                       decoration-success="status == 'ok'"
                                       decoration-danger="status == 'error'"/>
                                <field name="error_msg" string="Error Detail" optional="show"/>
                            </list>
                        </field>
                </sheet>
                                <footer>
                    <!-- Step 1 actions -->
                    <button name="action_parse"
                            string="Parse File"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'upload'"/>

                    <!-- Step 2 actions -->
                    <!-- FIX: removed invalid close="1"; dialog closes via Python returning act_window -->
                    <button name="action_import"
                            string="Import Valid Lines"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'preview' or success_count == 0"
                            confirm="Import all valid lines into the update order?"/>
                                </footer>
            </form>
        </field>
    </record>

    <!-- ════════════════════════════════
         ACTION
    ════════════════════════════════ -->
    <record id="action_stock_multi_update_import_wizard" model="ir.actions.act_window">
        <field name="name">Import Lines from Excel</field>
        <field name="res_model">stock.multi.update.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="view_id" ref="view_stock_multi_update_import_wizard_form"/>
    </record>

</odoo>