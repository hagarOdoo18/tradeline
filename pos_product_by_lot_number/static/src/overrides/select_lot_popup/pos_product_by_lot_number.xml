<templates id="template" xml:space="preserve">
    
    <t t-name="pos_product_by_lot_number.EditListPopup" t-inherit="point_of_sale.EditListPopup" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('edit-list-inputs')]" position="after">
            <div class="error-message d-none">
                <div class="lot-warning text-danger fs-3" style=" text-align:center;">Some of the lot/serial numbers do not exist!</div>
                <div class="check-input">
                    <div class="fs-4" style="display:flex;justify-content:center;">
                        <span id="check_content">Do you want to continue with the same?</span>
                        <select class="select-input w-auto ms-2">
                            <option name="no" value="no" class="selected_option">No</option>
                            <option name="yes" value="yes" class="selected_option">Yes</option>
                        </select>
                    </div>
                </div>
            </div>
        </xpath>
    </t>

</templates>
