<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="integration_mall_line_action" model="ir.actions.act_window">
            <field name="name">configuration Day Line</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">config.day.line</field>
            <field name="view_mode">list</field>
            <field name="context">{"search_default_branch":1,
                "search_default_date_month":1
                }</field>
        </record>
        <record id="integration_mall_line_view_search" model="ir.ui.view">
           <field name="name">Integration Search Line</field>
           <field name="model">config.day.line</field>
            <field name="arch" type="xml">
                <search string="">
                    <field name="date"/>
                    <field name="branch_id"/>
                    <filter string="branch" name="branch" context="{'group_by':'branch_id'}"/>
                    <filter string="Date" name="date_month" context="{'group_by':'date:month'}"/>



            </search>
           </field>
        </record>

        <record id="integration_mall_line_view_list" model="ir.ui.view">
            <field name="name">integration.mall.line.view.list</field>
            <field name="model">config.day.line</field>
            <field name="arch" type="xml">
                <list string="integration_mall_list">
                        <field name="date"/>
                        <field name="invoices_number"/>
                        <field name="branch_id"/>
                        <field name="untaxed_amount" sum="Total" groups="tradeline_mall_integration.group_manager_integration_mall"  string="Old Untaxed Amount"/>
                        <field name="tax_amount" sum="Total" groups="tradeline_mall_integration.group_manager_integration_mall" string="Old Tax Amount"/>
                       <field name="total_amount" sum="Total" groups="tradeline_mall_integration.group_manager_integration_mall" string="Old Total Amount"/>
                       <field name="new_untaxed_amount" sum="Total" string="Untaxed Amount"/>
                       <field name="new_tax_amount" sum="Total" string="Tax Amount"/>
                       <field name="new_total_amount" sum="Total" string="Total Amount"/>
                </list>
            </field>
        </record>

    </data>
</odoo>