<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="integration_mall_base_integration" model="ir.actions.act_window">
            <field name="name">Base Integration</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">base.integration</field>
            <field name="view_mode">list,form</field>
        </record>

        <record id="integration_mall_base_integration_form" model="ir.ui.view">
            <field name="name">base.integration.view.form</field>
            <field name="model">base.integration</field>
            <field name="arch" type="xml">
                <form string="base_integration_form">
                    <sheet>

                        <header>
                            <button type="object" name="get_token" string="Generate Token"
                                  />
                        </header>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="branch"/>
                                <field name="base_url"/>
                                <field name="end_point"/>
                                <field name="user"/>
                                <field name="password" password="True"/>
                                <field name="store_id"/>
                                <field name="x_api_key"/>
                                <field name="authorization"/>
                                <field name="content_type"/>
                                <field name="store_key"/>
                            </group>
                            <group>
                                <field name="token" readonly="1"/>
                            </group>
                        </group>

                    </sheet>
                </form>
            </field>
        </record>

        <record id="integration_base_integration_view_list" model="ir.ui.view">
            <field name="name">base.integration.view.list</field>
            <field name="model">base.integration</field>
            <field name="arch" type="xml">
                <list string="base_integration_list">
                    <field name="name"/>
                </list>
            </field>
        </record>

    </data>
</odoo>