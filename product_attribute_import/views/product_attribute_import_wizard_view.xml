<odoo>
    <record id="view_product_attribute_import_wizard_form" model="ir.ui.view">
        <field name="name">product.attribute.import.wizard.form</field>
        <field name="model">product.attribute.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Import Product Attributes" create="false" edit="false">
                <group>
                    <field name="file" filename="filename"/>
                </group>
                <footer>
                    <button name="action_import_attributes" string="Import" type="object" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_product_attribute_import_wizard" model="ir.actions.act_window">
        <field name="name">Import Product Attributes</field>
        <field name="res_model">product.attribute.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem
        id="menu_product_attribute_import_wizard"
        name="Import Attributes"
        parent="stock.menu_stock_inventory_control"
        action="action_product_attribute_import_wizard"
        sequence="30"/>
</odoo>
