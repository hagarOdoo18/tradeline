<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <data>
        <record id="cron_pull_today_attendance" model="ir.cron">
            <field name="name">Biotime: Pull Today Attendance</field>
            <field name="model_id" ref="model_biotime_config" />
            <field name="user_id" ref="base.user_root" />
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
            <field name="active" eval="True" />
            <field name="state">code</field>
            <field name="code">model.cron_get_today_attendance()</field>
        </record>


        <record id="cron_pull_attendance" model="ir.cron">
            <field name="name">Biotime: Pull  Attendance</field>
            <field name="model_id" ref="model_biotime_transaction" />
            <field name="user_id" ref="base.user_root" />
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
            <field name="active" eval="True" />
            <field name="state">code</field>
            <field name="code">model.process_attendance_from_biotime()</field>
        </record>


             <record model="ir.actions.server" id="action_get_employees">
            <field name="name">Link By Employee</field>
            <field name="model_id" ref="model_biotime_employee"/>
            <field name="binding_model_id" ref="model_biotime_employee" />
            <field name="binding_type">action</field>
            <field name="state">code</field>
            <field name="code">
if records:
    records.get_employee()
            </field>
        </record>

             <record model="ir.actions.server" id="action_sync_attendance">
            <field name="name">sync Attendance</field>
            <field name="model_id" ref="model_biotime_transaction"/>
            <field name="binding_model_id" ref="model_biotime_transaction" />
            <field name="binding_type">action</field>
            <field name="state">code</field>
            <field name="code">
if records:
    records.process_attendance_from_biotime()
            </field>
        </record>
    </data>
</odoo>