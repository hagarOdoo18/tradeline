<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_payment_report_line_list" model="ir.ui.view">
        <field name="name">payment.report.line.list</field>
        <field name="model">payment.report.line</field>
        <field name="arch" type="xml">
            <list string="Payment Report"
                  create="false" edit="false" delete="false">
                <field name="branch_name"/>
                <field name="date"/>
                <field name="invoice_name"/>
                <field name="sale_order_name"/>
                <field name="partner_name"/>
                <field name="journal_name"/>
                <field name="source_type"/>
                <field name="amount"/>
            </list>
        </field>
    </record>

    <record id="view_payment_report_line_search" model="ir.ui.view">
        <field name="name">payment.report.line.search</field>
        <field name="model">payment.report.line</field>
        <field name="arch" type="xml">
            <search string="Payment Report">
                <field name="branch_name"/>
                <field name="partner_name"/>
                <field name="invoice_name"/>
                <field name="sale_order_name"/>
                <field name="journal_name"/>
                <filter name="filter_invoice" string="Invoices"
                        domain="[('source_type', 'in', ['invoice', 'invoice_pos'])]"/>
                <filter name="filter_credit" string="Credit Notes"
                        domain="[('source_type', 'in', ['credit', 'credit_pos'])]"/>
                <filter name="filter_order" string="Order Payments"
                        domain="[('source_type', '=', 'order_payment')]"/>
            </search>
        </field>
    </record>

    <record id="action_payment_report_line" model="ir.actions.act_window">
        <field name="name">Payment Report</field>
        <field name="res_model">payment.report.line</field>
        <field name="view_mode">list</field>
        <field name="search_view_id" ref="view_payment_report_line_search"/>
    </record>

</odoo>
