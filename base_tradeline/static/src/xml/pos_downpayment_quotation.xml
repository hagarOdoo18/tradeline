<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="base_tradeline.ControlButtonsDownpaymentQuotation"
       t-inherit="point_of_sale.ControlButtons"
       t-inherit-mode="extension">
        <xpath expr="//OrderlineNoteButton" position="after">
            <button class="btn btn-secondary control-button downpayment-quotation-btn"
                    t-on-click="() => this.selectDownpaymentQuotation()"
                    style="background-color: #0b7285; color: #fff;">
                <i class="fa fa-list-alt"/>
                <br/>Downpayment Quotes
                <t t-if="env.services.pos.get_order() and env.services.pos.get_order().downpayment_quotation_name">
                    <br/>
                    <small t-esc="env.services.pos.get_order().downpayment_quotation_name"/>
                </t>
            </button>
        </xpath>
    </t>
</templates>
