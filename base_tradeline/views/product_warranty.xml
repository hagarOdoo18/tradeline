<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="product_warranty_form_view" model="ir.ui.view">
            <field name="name">product.warranty.form</field>
            <field name="model">product.warranty</field>
            <field name="arch" type="xml">
                <form string="warranty">
                    <sheet>

                        <group>
                            <group>
                                <field name="name"/>
                                <field name="categ_ids"  widget="many2many_tags"/>
                              
                            </group>
                           
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="warranty_list_view" model="ir.ui.view">
            <field name="name">product.warranty.list</field>
            <field name="model">product.warranty</field>
            <field name="arch" type="xml">
                <list string="warranty">
                    <field name="name"/>
                </list>
            </field>
        </record>

       

        <record id="warranty_act_window" model="ir.actions.act_window">
            <field name="name">Warranty</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">product.warranty</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    There is no examples click here to add new warranty.
                </p>
            </field>
        </record>


    </data>
</odoo>