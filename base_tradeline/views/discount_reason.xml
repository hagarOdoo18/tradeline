<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="discount_reason_form_view" model="ir.ui.view">
            <field name="name">discount.reason.form</field>
            <field name="model">discount.reason</field>
            <field name="arch" type="xml">
                <form string="Discount Reason">
                    <header>
                        <button name="action_run" string="Run" class="oe_highlight" invisible="state != 'new'" type="object"/>
                        <button name="set_draft" string="Set TO Draft" class="oe_highlight" invisible="state != 'stopped'" type="object"/>
                        <button name="action_stop" string="Stop" class="oe_highlight" invisible="state != 'run'" type="object"/>
                        <button name="action_new" string="Set New" class="oe_highlight" invisible="state != 'run'" type="object"/>
                        <field name="state" widget="statusbar" statusbar_visible="new,run,stopped"/>
                    </header>
                    <sheet>

                        <group>
                            <group>
                                <field name="name" readonly="state != 'new'"/>
                                <field name="start_date" readonly="state != 'new'"/>
                                <field name="end_date" readonly="state != 'new'"/>
                            </group>
                            <group>
                                <field name="company_ids" widget="many2many_tags" readonly="state != 'new'"/>
                                <field name="discount_percentage" readonly="state != 'new'"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="discount_reason_list_view" model="ir.ui.view">
            <field name="name">discount.reason.list</field>
            <field name="model">discount.reason</field>
            <field name="arch" type="xml">
                <list string="Discount Reason">
                    <field name="name"/>
                    <field name="state"/>
                </list>
            </field>
        </record>

       

        <record id="discount_reason_act_window" model="ir.actions.act_window">
            <field name="name">Discount Reason</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">discount.reason</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    There is no examples click here to add new Discount Reason.
                </p>
            </field>
        </record>


    </data>
</odoo>