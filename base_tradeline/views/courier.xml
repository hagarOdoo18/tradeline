<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="courier_form_view" model="ir.ui.view">
            <field name="name">courier.courier.form</field>
            <field name="model">courier.courier</field>
            <field name="arch" type="xml">
                <form string="Courier">
                    <sheet>

                        <group>
                            <group>
                                <field name="name"/>
                              
                            </group>
                           
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="courier_list_view" model="ir.ui.view">
            <field name="name">courier.courier.list</field>
            <field name="model">courier.courier</field>
            <field name="arch" type="xml">
                <list string="courier">
                    <field name="name"/>
                </list>
            </field>
        </record>

       

        <record id="courier_act_window" model="ir.actions.act_window">
            <field name="name">Courier</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">courier.courier</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    There is no examples click here to add new Courier.
                </p>
            </field>
        </record>


    </data>
</odoo>