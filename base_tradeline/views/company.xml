<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="res_company_form_inherit_sale_comment" model="ir.ui.view">
            <field name="name">res.company.form.inh</field>
            <field name="model">res.company</field>
            <field name="inherit_id" ref="base.view_company_form"/>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
              <xpath expr="//notebook" position="inside">
                   <page name="sale_note_ar" string="Sale Note AR">

                           <field name="sale_note" type="html"/>

                   </page>
                  <page name="sale_note_en" string="Sale Note EN">

                           <field name="sale_note_en" type="html"/>

                   </page>
                </xpath>

            </field>
        </record>
    </data>
</odoo>