<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="stock_lot_item_code_form" model="ir.ui.view">
            <field name="name">stock.lot.item.code.form</field>
            <field name="model">stock.lot</field>
            <field name="inherit_id" ref="stock.view_production_lot_form"/>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='ref']" position="after">
                    <field name="item_code" readonly="1"/>
                </xpath>

            </field>
        </record>
        <record id="stock_lot_item_code_list" model="ir.ui.view">
            <field name="name">stock.lot.item.code.list</field>
            <field name="model">stock.lot</field>
            <field name="inherit_id" ref="stock.view_production_lot_tree"/>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='ref']" position="after">
                    <field name="item_code" />
                </xpath>

            </field>
        </record>
    </data>
</odoo>