<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
         <record model="ir.ui.view" id="product_family_list">
      <field name="name">product family list view</field>
      <field name="model">product.family</field>
      <field name="arch" type="xml">
        <list>
          <field name="name"/>
        </list>
      </field>
    </record>

    <record model="ir.ui.view" id="product_family_form">
      <field name="name">product family form view</field>
      <field name="model">product.family</field>
      <field name="arch" type="xml">
        <form>
          <sheet>
            <group>
              <field name="name"/>
            </group>
          </sheet>
        </form>
      </field>
    </record>

    <!-- actions opening views on models -->
    <record model="ir.actions.act_window" id="product_family_act">
      <field name="name">Product Family</field>
      <field name="res_model">product.family</field>
      <field name="view_mode">list,form</field>
    </record>




    </data>
</odoo>