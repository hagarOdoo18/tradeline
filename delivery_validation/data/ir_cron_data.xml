<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!--
            Cron Job: Auto-Validate Deliveries & Receipts
            ──────────────────────────────────────────────
            Runs every 1 minute.
            Targets stock.picking with type = outgoing (delivery) or incoming (receipt)
            that are PENDING and were created more than 5 minutes ago.
        -->
        <record id="cron_auto_validate_stock_pickings" model="ir.cron">
            <field name="name">Auto-Validate Pending Deliveries &amp; Receipts (5 min)</field>
            <field name="model_id" ref="stock.model_stock_picking"/>
            <field name="state">code</field>
            <field name="code">model.action_auto_validate_pending_pickings()</field>
            <field name="interval_number">10</field>
            <field name="interval_type">minutes</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
            <field name="priority">5</field>
        </record>

    </data>
</odoo>
