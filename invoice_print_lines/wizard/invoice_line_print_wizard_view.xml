<odoo>
    <record id="view_invoice_line_print_wizard_form" model="ir.ui.view">
        <field name="name">invoice.line.print.wizard.form</field>
        <field name="model">invoice.line.print.wizard</field>
        <field name="arch" type="xml">
            <form string="Print Lines">
                <group>
                    <field name="move_id"/>
                    <field name="line_ids">
                        <list create="0" editable="bottom" edit="1">
                            <field name="allow_print"/>
                            <field name="name"/>
                            <field name="quantity"/>
                            <field name="move_line_id" readonly="1" force_save="1" invisible="1"/>
                        </list>
                    </field>
                </group>
                <footer>
                    <button name="action_apply" type="object" string="Apply" class="btn-primary"/>
                    <button special="cancel" string="Cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
