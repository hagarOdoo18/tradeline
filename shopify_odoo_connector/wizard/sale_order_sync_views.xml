<?xml version="1.0" encoding="utf-8"?>
<odoo>
<!--    form view for sale order sync-->
    <record id="sale_order_sync_view_form" model="ir.ui.view">
        <field name="name">sale.order.sync.view.form</field>
        <field name="model">sale.order.sync</field>
        <field name="arch" type="xml">
            <form string="Sync orders">
                <group>
                    <field name="import_orders"/>
                    <field name="type_order" invisible="import_orders != 'odoo'"/>
                    <field name="draft" invisible="1"/>
                    <field name="shopify_instance_id"/>
                </group>
                <footer>
                    <button name="sync_orders" string="Sync orders"
                            class="btn-primary" type="object"/>
                    <button string="Cancel" class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
<!--    action for sale_order_sync-->
    <record id="sale_order_sync_action" model="ir.actions.act_window">
        <field name="name">Sync orders</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">sale.order.sync</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="sale_order_sync_view_form"/>
        <field name="target">new</field>
    </record>
<!--    menu for sale_order_sync-->
    <menuitem
            id="sale_order_sync_menu"
            action="sale_order_sync_action"
            name="Sync orders"
            parent="shopify_odoo_connector.sale_order_menu_root"
            sequence="3"/>
</odoo>
