<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
<!--    form view for sync inventory-->
    <record id="sync_inventory_view_form" model="ir.ui.view">
        <field name="name">sync.inventory.view.form</field>
        <field name="model">sync.inventory</field>
        <field name="arch" type="xml">
            <form string="Sync Inventory">
                <group>
                    <field name="shopify_instance_id"/>
                    <field name="import_inventory"
                           widget="radio"
                           options="{'horizontal': true}"/>
                    <field name="warehouse_ids"
                           widget="many2many_tags"
                           string="Warehouses to Push / Pull"/>
                </group>
                <div class="alert alert-info" role="alert"
                     invisible="import_inventory != 'shopify'">
                    Selected warehouses' on-hand quantities will be pushed
                    to all active Shopify locations.
                </div>
                <div class="alert alert-info" role="alert"
                     invisible="import_inventory != 'odoo'">
                    Shopify inventory quantities will be applied to all
                    selected warehouses in Odoo.
                </div>
                <footer>
                    <button name="sync_inventory"
                            string="Push to Shopify"
                            class="btn-primary"
                            type="object"
                            invisible="import_inventory != 'shopify'"/>
                    <button name="sync_inventory"
                            string="Pull from Shopify"
                            class="btn-primary"
                            type="object"
                            invisible="import_inventory != 'odoo'"/>
                    <button string="Cancel" class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
<!--   action for sync inventory -->
    <record id="sync_inventory_action" model="ir.actions.act_window">
        <field name="name">Sync Inventory</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">sync.inventory</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="sync_inventory_view_form"/>
        <field name="target">new</field>
    </record>
<!--    menu for sync inventory-->
    <menuitem
            id="sync_inventory_menu_action"
            action="sync_inventory_action"
            name="Sync Inventory"
            parent="shopify_odoo_connector.product_template_menu_root"
            sequence="5"/>
</odoo>